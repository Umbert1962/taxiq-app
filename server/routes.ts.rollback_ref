async function sendPushNotification(driverId: string, payload: { title: string; body: string; data?: any; tag?: string }) {
  const isHighPriority = payload.data?.type === 'ride_request' || payload.data?.type === 'NEW_RIDE_REQUEST' || payload.data?.type === 'phone_order';
  
  // 1. Send via FCM (native apps + FCM web tokens)
  if (isFCMReady()) {
    try {
      const fcmTokensList = await storage.getFcmTokensByUserId(driverId, 'driver');
      if (fcmTokensList.length > 0) {
        const tokens = fcmTokensList.map(t => t.token);
        const fcmData: Record<string, string> = {};
        if (payload.data) {
          Object.entries(payload.data).forEach(([key, value]) => {
            fcmData[key] = String(value);
          });
        }
        
        console.log(`[FCM_SEND] driver=${driverId}, tokens=${tokens.length}, highPriority=${isHighPriority}`);
        
        const result = await sendFCMNotification(
          tokens,
          { title: payload.title, body: payload.body, data: fcmData },
          isHighPriority
        );
        
        for (const expiredToken of result.expiredTokens) {
          await storage.deleteFcmToken(expiredToken);
        }
        
        console.log(`[FCM_DONE] driver=${driverId}, sent=${result.success}, failed=${result.failure}, expired=${result.expiredTokens.length}`);
      }
    } catch (error) {
      console.error("[FCM_ERROR] Error sending FCM:", error);
    }
  }
  
  // 2. Send via Web Push (VAPID - for browsers without FCM)
  if (vapidPublicKey && vapidPrivateKey) {
    try {
      const subscriptions = await storage.getDriverPushSubscriptions(driverId);
      
      if (subscriptions.length === 0 && !isFCMReady()) {
        console.log(`No push subscriptions for driver ${driverId}`);
        return;
      }

      if (subscriptions.length > 0) {
        const notificationPayload = {
          ...payload,
          tag: payload.tag || 'taxiq-ride-' + Date.now(),
        };
        
        console.log(`[WEBPUSH] Sending to driver ${driverId}, ${subscriptions.length} subscription(s)`);
        
        for (const subscription of subscriptions) {
          try {
            await webpush.sendNotification(
              {
                endpoint: subscription.endpoint,
                keys: {
                  p256dh: subscription.p256dh,
                  auth: subscription.auth
                }
              },
              JSON.stringify(notificationPayload),
              {
                urgency: 'high',
                TTL: 86400,
                headers: {
                  'Urgency': 'high',
                }
              }
            );
            console.log(`[WEBPUSH_SENT] driver=${driverId}, endpoint=${subscription.endpoint.substring(0, 60)}...`);
          } catch (error: any) {
            if (error.statusCode === 404 || error.statusCode === 410) {
              await storage.deletePushSubscription(subscription.endpoint);
              console.log(`[WEBPUSH_EXPIRED] Removed expired subscription for driver ${driverId}`);
            } else {
              console.error(`[WEBPUSH_ERROR] driver=${driverId}, error=${error.message}, statusCode=${error.statusCode}`);
            }
          }
        }
      }
    } catch (error) {
      console.error("Error sending web push notifications:", error);
    }
  }
}

const rideNotifiedDrivers = new Map<string, Set<string>>();

async function getBusyDriverIds(): Promise<Set<string>> {
  const activeRides = await db.select({ driverId: rides.driverId })
    .from(rides)
    .where(
      and(
        inArray(rides.status, ["accepted", "in_progress"]),
        isNotNull(rides.driverId)
      )
    );
  return new Set(activeRides.map(r => r.driverId!).filter(Boolean));
}

function logSearchMetrics(metrics: SearchMetrics): void {
  console.log(`[SEARCH_METRICS] ride_id=${metrics.rideId} mode=${metrics.searchMode} radius_km=${metrics.usedRadius} found=${metrics.driversFoundCount} online=${metrics.onlineCount} offline=${metrics.offlineCount} fallback=${metrics.fallbackActivated}`);
}

async function setOfferExpiry(rideId: string): Promise<void> {
  const expiresAt = new Date(Date.now() + OFFER_TIMEOUT_SECONDS * 1000);
  await storage.updateRide(rideId, { offerExpiresAt: expiresAt });
}

async function clearOfferExpiry(rideId: string): Promise<void> {
  await storage.updateRide(rideId, { offerExpiresAt: null });
}

async function searchAndNotifyDrivers(
  rideId: string,
  pickupLat: number,
  pickupLng: number,
  pickupAddress: string,
  destination: string,
  estimatedPrice?: string | number | null,
  orderSource?: string,
  passengerId?: string | null
): Promise<SearchResult | null> {
  const ride = await storage.getRide(rideId);
  if (!ride) return null;

  if (!ride.searchStartedAt) {
    await storage.updateRide(rideId, { searchStartedAt: new Date() });
  }

  const notifCount: Record<string, number> = (ride.driverNotificationCount as Record<string, number>) || {};

  const resolvedPassengerId = passengerId || ride.passengerId;
  let favoriteDriverIds = new Set<string>();
  if (resolvedPassengerId) {
    try {
      const favIds = await storage.getFavoriteDriverIds(resolvedPassengerId);
      favoriteDriverIds = new Set(favIds);
    } catch (err: any) {
      console.error(`[FAVORITES_FETCH_ERROR] passenger_id=${resolvedPassengerId} error=${err.message}`);
    }
  }

  const allDrivers = await storage.getAllDrivers();
  const busyDriverIds = await getBusyDriverIds();

  const driversForSearch: DriverForSearch[] = allDrivers.map(d => ({
    id: d.id,
    currentLat: d.currentLat,
    currentLng: d.currentLng,
    isOnline: d.isOnline,
    subscriptionStatus: d.subscriptionStatus,
    isBlocked: d.isBlocked,
  }));

  const busyDriverIdsList = Array.from(busyDriverIds);
  const sqlLongCandidatesRaw = await storage.getEligibleDriversCandidates(
    pickupLat, pickupLng, LONG_PICKUP_MAX_DISTANCE_KM, busyDriverIdsList, LONG_PICKUP_DRIVER_LIMIT
  );
  const sqlLongCandidates: DriverForSearch[] = sqlLongCandidatesRaw.map(d => ({
    id: d.id,
    currentLat: d.currentLat,
    currentLng: d.currentLng,
    isOnline: d.isOnline,
    subscriptionStatus: d.subscriptionStatus,
    isBlocked: d.isBlocked,
  }));

  const { result, metrics } = searchDriversWithGuard(rideId, driversForSearch, pickupLat, pickupLng, busyDriverIds, sqlLongCandidates, favoriteDriverIds);
  logSearchMetrics(metrics);

  if (!result) {
    return null;
  }

  if (!rideNotifiedDrivers.has(rideId)) {
    rideNotifiedDrivers.set(rideId, new Set());
  }
  const notifiedSet = rideNotifiedDrivers.get(rideId)!;

  const allSelectedDriverIds = [...result.onlineDriverIds, ...result.offlineDriverIds];
  const priceText = estimatedPrice ? `. Cena: ${estimatedPrice} PLN` : '';
  const isLongPickup = result.mode === "long_pickup";

  let notifiedCount = 0;
  let skippedCount = 0;
  let spamBlockedCount = 0;

  for (const driverId of result.onlineDriverIds) {
    if (notifiedSet.has(driverId)) { skippedCount++; continue; }
    if ((notifCount[driverId] || 0) >= MAX_DRIVER_NOTIFICATIONS_PER_RIDE) { spamBlockedCount++; continue; }
    notifiedSet.add(driverId);
    notifCount[driverId] = (notifCount[driverId] || 0) + 1;
    notifiedCount++;
    await sendPushNotification(driverId, {
      title: isLongPickup ? "Możliwy długi kurs!" : "Nowe zlecenie w pobliżu!",
      body: `${pickupAddress} → ${destination}${priceText}`,
      data: { rideId, type: "ride_request", pickup: pickupAddress, destination, price: estimatedPrice || '' },
      tag: 'taxiq-ride-request-' + rideId
    });
  }

  for (const driverId of result.offlineDriverIds) {
    if (notifiedSet.has(driverId)) { skippedCount++; continue; }
    if ((notifCount[driverId] || 0) >= MAX_DRIVER_NOTIFICATIONS_PER_RIDE) { spamBlockedCount++; continue; }
    notifiedSet.add(driverId);
    notifCount[driverId] = (notifCount[driverId] || 0) + 1;
    notifiedCount++;
    await sendPushNotification(driverId, {
      title: isLongPickup ? "Możliwy długi kurs – sprawdź aplikację" : "Nowe zlecenie w Twojej okolicy – otwórz aplikację",
      body: `${pickupAddress} → ${destination}${priceText}`,
      data: { rideId, type: "ride_request", pickup: pickupAddress, destination, price: estimatedPrice || '' },
      tag: 'taxiq-ride-request-' + rideId
    });
  }

  await storage.updateRide(rideId, { driverNotificationCount: notifCount });

  if (skippedCount > 0 || spamBlockedCount > 0) {
    console.log(`[SEARCH_DEDUP] ride_id=${rideId} notified=${notifiedCount} skipped_duplicates=${skippedCount} spam_blocked=${spamBlockedCount}`);
  }

  if (orderSource !== "phone" && notifiedCount > 0) {
    await setOfferExpiry(rideId);
    console.log(`[OFFER_EXPIRY_SET] ride_id=${rideId} timeout=${OFFER_TIMEOUT_SECONDS}s`);
  }

  return result;
}

interface BusinessSession {
  type: "company" | "employee";
  id: string;
  companyId: string;
  role?: string;
}

declare global {
  namespace Express {
    interface Request {
      businessSession?: BusinessSession;
    }
  }
}

const businessSessions = new Map<string, BusinessSession>();

// Helper function to invalidate previous business sessions for single session enforcement
function invalidateBusinessSessions(userId: string, userType: "employee" | "company") {
  // Find and delete all existing sessions for this user
  const tokensToDelete: string[] = [];
  businessSessions.forEach((session, token) => {
    if (session.type === userType && session.id === userId) {
      tokensToDelete.push(token);
    }
  });
  tokensToDelete.forEach(token => businessSessions.delete(token));
}

function generateToken(): string {
  return Math.random().toString(36).substring(2) + Date.now().toString(36);
}

function requireBusinessAuth(req: Request, res: Response, next: NextFunction) {
  const tokenHeader = req.headers["x-business-token"];
  const token = Array.isArray(tokenHeader) ? tokenHeader[0] : tokenHeader;
  if (!token) {
    return res.status(401).json({ error: "Authentication required" });
  }
  const session = businessSessions.get(token);
  if (!session) {
    return res.status(401).json({ error: "Invalid or expired session" });
  }
  req.businessSession = session;
  next();
}

function requireCompanyAccess(req: Request, res: Response, next: NextFunction) {
  const session = req.businessSession;
  const requestedCompanyId = req.params.id || req.params.companyId;
  if (session && requestedCompanyId && session.companyId !== requestedCompanyId) {
    return res.status(403).json({ error: "Access denied" });
  }
  next();
}

import { setupAuth, registerAuthRoutes } from "./replit_integrations/auth";

function isDriverProfileComplete(driver: any): boolean {
  return !!(
    driver.firstName &&
    driver.lastName &&
    driver.phone &&
    driver.vehiclePlate &&
    driver.vehicleModel &&
    driver.vehicleColor &&
    driver.taxiLicenseNumber &&
    Array.isArray(driver.languages) && driver.languages.length > 0 &&
    driver.photoVerifiedAt &&
    driver.phoneVerifiedAt &&
    driver.termsAcceptedAt
  );
}

export async function registerRoutes(
  httpServer: Server,
  app: Express
): Promise<Server> {
  
  if (process.env.REPLIT === "true" || process.env.REPL_ID) {
    await setupAuth(app);
    registerAuthRoutes(app);
  }
  
  // Redirects for old -login URLs (backwards compatibility)
  app.get("/driver-login", (_req, res) => res.redirect(301, "/driver"));
  app.get("/business-login", (_req, res) => res.redirect(301, "/business"));
  app.get("/admin-login", (_req, res) => res.redirect(301, "/admin"));

  // Register Object Storage routes for permanent file storage
  registerObjectStorageRoutes(app);
  const objectStorageService = new ObjectStorageService();
  
  // Serve AAB download
  app.get("/download/taxiq-driver-v3.aab", (_req, res) => {
    const aabPath = path.join(process.cwd(), 'taxiq-driver-v3.aab');
    res.download(aabPath, 'taxiq-driver-v3.aab');
  });

  // NEW Driver AAB with package name pl.com.taxiq.driver
  app.get("/download/taxiq-driver-new.aab", (_req, res) => {
    const aabPath = path.join(process.cwd(), 'taxiq-driver-new.aab');
    res.download(aabPath, 'taxiq-driver-new.aab');
  });

  // Signed Driver AAB - latest version
  app.get("/download/TaxiQ-Driver-signed.aab", (_req, res) => {
    const aabPath = path.join(process.cwd(), 'client', 'public', 'downloads', 'TaxiQ-Driver-signed.aab');
    res.download(aabPath, 'TaxiQ-Driver-signed.aab');
  });

  // Feb 5 Driver AAB - use /api prefix to bypass CDN cache
  app.get("/api/get-driver-aab", (_req, res) => {
    const aabPath = path.join(process.cwd(), 'driver-app-feb5.aab');
    console.log("Serving AAB from:", aabPath);
    res.download(aabPath, 'TaxiQ-Driver-signed.aab', (err) => {
      if (err) console.error("Download error:", err);
    });
  });

  // PWABuilder Driver AAB - FINAL VERSION
  app.get("/download/taxiq-driver-final.aab", (_req, res) => {
    const aabPath = path.join(process.cwd(), 'taxiq-driver-pwabuilder.aab');
    res.download(aabPath, 'TaxiQ-Driver.aab');
  });

  app.get("/api/get-passenger-aab", (_req, res) => {
    res.set('Cache-Control', 'no-store, no-cache, must-revalidate');
    res.set('Content-Type', 'application/octet-stream');
    res.set('Content-Disposition', 'attachment; filename="TaxiQ-Passenger-v6.aab"');
    const aabPath = path.join(process.cwd(), 'passenger-v6.aab');
    if (!fs.existsSync(aabPath)) {
      return res.status(404).json({ error: "Plik nie znaleziony" });
    }
    res.sendFile(aabPath);
  });

  app.get("/download/TaxiQ-Passenger.aab", (_req, res) => {
    res.set('Cache-Control', 'no-store, no-cache, must-revalidate');
    const aabPath = path.join(process.cwd(), 'client', 'public', 'download', 'TaxiQ-Passenger.aab');
    if (!fs.existsSync(aabPath)) {
      return res.status(404).json({ error: "Plik nie znaleziony" });
    }
    res.download(aabPath, 'TaxiQ-Passenger.aab');
  });

  // Download TaxiQ Platform ZIP for iOS build
  app.get("/download/TaxiQ-Platform.zip", (_req, res) => {
    const zipPath = path.join(process.cwd(), 'client', 'public', 'download', 'TaxiQ-Platform.zip');
    if (!fs.existsSync(zipPath)) {
      return res.status(404).json({ error: "Plik ZIP nie jest dostępny" });
    }
    res.download(zipPath, 'TaxiQ-Platform.zip');
  });

  app.get("/download/TaxiQ-iOS-Build.zip", (_req, res) => {
    res.set('Cache-Control', 'no-store, no-cache, must-revalidate');
    res.set('Pragma', 'no-cache');
    const zipPath = path.join(process.cwd(), 'TaxiQ-iOS-Build.zip');
    if (!fs.existsSync(zipPath)) {
      return res.status(404).json({ error: "Plik ZIP nie jest dostępny" });
    }
    res.download(zipPath, 'TaxiQ-iOS-Build.zip');
  });

  // Serve static install pages FIRST - before any other routes
  app.get("/install/passenger", (_req, res) => {
    const htmlPath = path.join(publicDir, 'install-passenger.html');
    res.sendFile(htmlPath);
  });
  
  app.get("/install/driver", (_req, res) => {
    const htmlPath = path.join(publicDir, 'install-driver.html');
    res.sendFile(htmlPath);
  });
  
  app.get("/install/admin", (_req, res) => {
    const htmlPath = path.join(publicDir, 'install-admin.html');
    res.sendFile(htmlPath);
  });
  
  app.get("/install/business", (_req, res) => {
    const htmlPath = path.join(publicDir, 'install-business.html');
    res.sendFile(htmlPath);
  });
  
  const express = await import("express");
  
  app.get("/uploads/:filename", async (req, res) => {
    res.status(410).json({ error: "Local uploads no longer supported. Photos are served via /objects/* routes." });
  });
  
  // Serve icons and other static files from public directory
  app.use("/icons", express.default.static(path.join(publicDir, "icons")));
  app.use("/downloads", express.default.static(path.join(publicDir, "downloads")));
  app.use("/download", express.default.static(path.join(publicDir, "download")));
  
