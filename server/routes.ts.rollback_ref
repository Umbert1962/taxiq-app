  // Block/unblock driver
  app.post("/api/admin/drivers/:id/block", requireAdmin, async (req, res) => {
    try {
      const driverId = String(req.params.id);
      const { reason } = req.body;
      
      const driver = await storage.getDriver(driverId);
      if (!driver) {
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      
      await db.update(drivers).set({
        isBlocked: true,
        blockedAt: new Date(),
        blockedReason: reason || "Zablokowany przez administratora",
        isOnline: false, // Force offline when blocked
      }).where(eq(drivers.id, driverId));
      
      res.json({ message: "Kierowca zablokowany" });
    } catch (error) {
      console.error("Error blocking driver:", error);
      res.status(500).json({ error: "Nie udało się zablokować kierowcy" });
    }
  });
  
  app.post("/api/admin/drivers/:id/unblock", requireAdmin, async (req, res) => {
    try {
      const driverId = String(req.params.id);
      
      await db.update(drivers).set({
        isBlocked: false,
        blockedAt: null,
        blockedReason: null,
      }).where(eq(drivers.id, driverId));
      
      res.json({ message: "Kierowca odblokowany" });
    } catch (error) {
      console.error("Error unblocking driver:", error);
      res.status(500).json({ error: "Nie udało się odblokować kierowcy" });
    }
  });
  
  // Update driver
  app.put("/api/admin/drivers/:id", requireAdmin, async (req, res) => {
    try {
      const { name, username, email, phone, vehiclePlate, vehicleModel, taxiLicenseNumber, password, plainPassword } = req.body;
      const updateData: any = {};
      if (name) updateData.name = name;
      if (username) updateData.username = username;
      if (email !== undefined && email !== "") updateData.email = email;
      if (phone !== undefined && phone !== "") updateData.phone = phone;
      if (vehiclePlate !== undefined && vehiclePlate !== "") updateData.vehiclePlate = vehiclePlate;
      if (vehicleModel !== undefined) updateData.vehicleModel = vehicleModel;
      if (taxiLicenseNumber !== undefined && taxiLicenseNumber !== "") {
        const trimmedLic = taxiLicenseNumber.trim();
        const existingWithLicense = await storage.getDriverByLicenseNumber(trimmedLic);
        if (existingWithLicense && existingWithLicense.id !== String(req.params.id)) {
          return res.status(400).json({ error: "Ten numer licencji jest już przypisany do innego kierowcy" });
        }
        updateData.taxiLicenseNumber = trimmedLic;
      }
      if (password) {
        const bcrypt = await import("bcrypt");
        updateData.password = await bcrypt.hash(password, 10);
        updateData.plainPassword = plainPassword;
      }
      const driver = await storage.updateDriver(String(req.params.id), updateData);
      res.json(driver);
    } catch (error) {
      res.status(500).json({ error: "Nie udało się zaktualizować kierowcy" });
    }
  });
  
  // Admin: Get all referrals
  app.get("/api/admin/referrals", requireAdmin, async (req, res) => {
    try {
      const allReferrals = await storage.getAllReferrals();
      const enriched = await Promise.all(allReferrals.map(async (ref) => {
        const referrer = await storage.getDriver(ref.referrerDriverId);
        let referredName = '';
        if (ref.referredDriverId) {
          const d = await storage.getDriver(ref.referredDriverId);
          referredName = d?.name || 'Nieznany kierowca';
        }
        if (ref.referredUserId) {
          const u = await storage.getUser(ref.referredUserId);
          referredName = u ? `${u.firstName || ''} ${u.lastName || ''}`.trim() || 'Nieznany pasażer' : 'Nieznany pasażer';
        }
        return {
          ...ref,
          referrerName: referrer?.name || 'Nieznany',
          referrerCode: referrer?.referralCode,
          referredName,
        };
      }));
      res.json(enriched);
    } catch (error) {
      console.error("Error fetching admin referrals:", error);
      res.status(500).json({ error: "Nie udało się pobrać poleceń" });
    }
  });

  // Get all referral payouts (admin)
  app.get("/api/admin/referral-payouts", requireAdmin, async (req, res) => {
    try {
      const payouts = await storage.getAllReferralPayouts();
      const enriched = await Promise.all(payouts.map(async (payout) => {
