      res.status(500).json({ error: "Błąd pobierania profilu" });
    }
  });

  // Complete driver profile (step 2 - after registration)
  app.patch("/api/drivers/:id/complete-profile", async (req, res) => {
    try {
      const sessionDriverId = (req.session as any).driverId;
      const driverId = req.params.id as string;
      
      if (!sessionDriverId || sessionDriverId !== driverId) {
        return res.status(401).json({ error: "Nieautoryzowany dostęp" });
      }
      
      const { phone, vehiclePlate, vehicleModel, taxiLicenseNumber, termsAccepted } = req.body;
      
      if (!phone || !vehiclePlate || !taxiLicenseNumber) {
        return res.status(400).json({ error: "Wymagane pola: telefon, numer rejestracyjny, numer licencji" });
      }
      
      if (!termsAccepted) {
        return res.status(400).json({ error: "Musisz zaakceptować regulamin" });
      }

      const trimmedLicense = taxiLicenseNumber.trim();
      const existingWithLicense = await storage.getDriverByLicenseNumber(trimmedLicense);
      if (existingWithLicense && existingWithLicense.id !== driverId) {
        return res.status(400).json({ error: "Ten numer licencji jest już przypisany do innego kierowcy" });
      }
      
      // Normalize phone to E.164 format
      let normalizedPhone = phone.replace(/[\s\-\(\)]/g, "");
      if (!normalizedPhone.startsWith("+")) {
        if (normalizedPhone.startsWith("48")) {
          normalizedPhone = "+" + normalizedPhone;
        } else if (normalizedPhone.startsWith("0")) {
          normalizedPhone = "+48" + normalizedPhone.slice(1);
        } else if (normalizedPhone.length === 9) {
          normalizedPhone = "+48" + normalizedPhone;
        }
      }
      
      await db.update(drivers).set({
        phone: normalizedPhone,
        vehiclePlate,
        vehicleModel: vehicleModel || null,
        taxiLicenseNumber: trimmedLicense,
        termsAcceptedAt: new Date(),
      }).where(eq(drivers.id, driverId));
      
      res.json({ success: true, message: "Profil uzupełniony" });
    } catch (error) {
      console.error("Error completing driver profile:", error);
      res.status(500).json({ error: "Błąd uzupełniania profilu" });
    }
  });

  // Update driver profile (phone/email) with verification reset
  app.patch("/api/drivers/:id/profile", async (req, res) => {
    try {
      const sessionDriverId = (req.session as any).driverId;
      const driverId = req.params.id as string;
      
      if (!sessionDriverId || sessionDriverId !== driverId) {
        return res.status(401).json({ error: "Nieautoryzowany dostęp" });
      }
      
      const { phone, email, name, firstName, lastName, vehiclePlate, vehicleModel, vehicleColor, taxiLicenseNumber, languages } = req.body;
      
      // Get current driver to check what changed
      const currentDriver = await storage.getDriver(driverId);
      if (!currentDriver) {
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      
      const updateData: Record<string, any> = {};
      
      // Update firstName/lastName if provided
      if (firstName !== undefined && firstName !== currentDriver.firstName) {
        updateData.firstName = firstName;
      }
      if (lastName !== undefined && lastName !== currentDriver.lastName) {
        updateData.lastName = lastName;
      }
      // Update name (keep in sync with firstName + lastName)
      if (firstName || lastName) {
        const newFirst = firstName || currentDriver.firstName || "";
        const newLast = lastName || currentDriver.lastName || "";
        updateData.name = `${newFirst} ${newLast}`.trim();
      } else if (name && name !== currentDriver.name) {
        updateData.name = name;
      }
      
      // Update phone if provided and different - reset phone verification
      if (phone !== undefined && phone !== currentDriver.phone) {
        // Normalize to E.164 format for consistent storage
        let normalizedPhone = phone.replace(/[\s\-\(\)]/g, "");
        if (normalizedPhone && !normalizedPhone.startsWith("+")) {
          if (normalizedPhone.startsWith("48")) {
            normalizedPhone = "+" + normalizedPhone;
          } else if (normalizedPhone.startsWith("0")) {
            normalizedPhone = "+48" + normalizedPhone.slice(1);
          } else if (normalizedPhone.length === 9) {
            normalizedPhone = "+48" + normalizedPhone;
          }
        }
        updateData.phone = normalizedPhone || phone;
        updateData.phoneVerifiedAt = null; // Reset phone verification
      }
      
      // Update email if provided and different - reset email verification
      if (email !== undefined && email !== currentDriver.email) {
        updateData.email = email;
        updateData.emailVerifiedAt = null; // Reset email verification
      }
      
      // Update vehicle info
      if (vehiclePlate !== undefined && vehiclePlate !== currentDriver.vehiclePlate) {
        updateData.vehiclePlate = vehiclePlate;
      }
      if (vehicleModel !== undefined && vehicleModel !== currentDriver.vehicleModel) {
        updateData.vehicleModel = vehicleModel;
      }
      if (vehicleColor !== undefined && vehicleColor !== currentDriver.vehicleColor) {
        updateData.vehicleColor = vehicleColor;
      }
      if (taxiLicenseNumber !== undefined && taxiLicenseNumber !== currentDriver.taxiLicenseNumber) {
        const trimmedLic = typeof taxiLicenseNumber === "string" ? taxiLicenseNumber.trim() : taxiLicenseNumber;
        if (trimmedLic) {
          const existingWithLicense = await storage.getDriverByLicenseNumber(trimmedLic);
          if (existingWithLicense && existingWithLicense.id !== driverId) {
            return res.status(400).json({ error: "Ten numer licencji jest już przypisany do innego kierowcy" });
          }
        }
        updateData.taxiLicenseNumber = trimmedLic || null;
      }
      if (Array.isArray(languages)) {
        updateData.languages = languages;
      }
      
      if (Object.keys(updateData).length === 0) {
        return res.json({ success: true, message: "Brak zmian", driver: currentDriver });
      }
      
      await db.update(drivers).set(updateData).where(eq(drivers.id, driverId));
      
      const updatedDriver = await storage.getDriver(driverId);
      
      res.json({ 
        success: true, 
        message: "Profil zaktualizowany",
        phoneVerificationReset: updateData.phoneVerifiedAt === null,
        emailVerificationReset: updateData.emailVerifiedAt === null,
        driver: updatedDriver
      });
    } catch (error) {
      console.error("Error updating driver profile:", error);
      res.status(500).json({ error: "Błąd aktualizacji profilu" });
    }
  });

