    }
  });

  // Legacy admin-specific routes delegate to unified auth
  app.post("/auth/admin/request-access", async (req, res) => {
    const { phone } = req.body;
    if (!phone) return res.status(400).json({ error: "Numer telefonu jest wymagany" });
    try {
      const result = await requestAccess(phone, false, "admin");
      if (result.role !== "admin") return res.status(404).json({ error: "Nie znaleziono administratora z tym numerem" });
      res.json({ status: result.status });
    } catch (error: any) {
      const sc = error instanceof AuthError ? error.statusCode : 500;
      res.status(sc).json({ error: error.message || "Błąd serwera" });
    }
  });
  app.post("/auth/admin/verify-otp", async (req, res) => {
    const { phone, otp } = req.body;
    if (!phone || !otp) return res.status(400).json({ error: "Numer telefonu i kod OTP są wymagane" });
    try {
      const result = await verifyOtp(phone, otp, "admin");
      if (result.role !== "admin") return res.status(404).json({ error: "Nie znaleziono administratora" });
      (req.session as any).otpVerifiedUserId = result.userId;
