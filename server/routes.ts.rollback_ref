  // ============= ADMIN ENDPOINTS (LEGACY + PROTECTED) =============
  
  // Admin login (legacy username/password - kept for backward compatibility)
  app.post("/api/admin/login", async (req, res) => {
    const clientIp = req.ip || req.socket.remoteAddress || 'unknown';
    const ts = new Date().toISOString();

    if (!checkLoginRateLimit(clientIp)) {
      console.log(`[AUDIT] ADMIN_LOGIN | ts: ${ts} | ip: ${clientIp} | result: RATE_LIMITED`);
      return res.status(429).json({ error: "Zbyt wiele prób logowania. Spróbuj ponownie za 5 minut." });
    }

    try {
      const { username, password } = req.body;

      if (!username || !password) {
        console.log(`[AUDIT] ADMIN_LOGIN | ts: ${ts} | ip: ${clientIp} | result: BAD_REQUEST | reason: empty_credentials`);
        return res.status(400).json({ error: "Login i hasło są wymagane" });
      }

      const admin = await storage.getAdminByUsername(username);
      if (!admin) {
        recordFailedAttempt(clientIp);
        console.log(`[AUDIT] ADMIN_LOGIN | ts: ${ts} | ip: ${clientIp} | result: FAILURE | reason: user_not_found | username: ${username}`);
        return res.status(401).json({ error: "Nieprawidłowy login lub hasło" });
      }

      let passwordValid = false;
      if (admin.password?.startsWith('$2')) {
        passwordValid = await verifyPassword(password, admin.password);
      }
      if (!passwordValid) {
        recordFailedAttempt(clientIp);
        console.log(`[AUDIT] ADMIN_LOGIN | ts: ${ts} | ip: ${clientIp} | result: FAILURE | reason: invalid_password | adminId: ${admin.id}`);
        return res.status(401).json({ error: "Nieprawidłowy login lub hasło" });
      }

      resetLoginAttempts(clientIp);

      await storage.invalidateAdminSessions(admin.id);

      (req.session as any).adminId = admin.id;
      (req.session as any).adminRole = admin.role;

      console.log(`[AUDIT] ADMIN_LOGIN | ts: ${ts} | ip: ${clientIp} | result: SUCCESS | adminId: ${admin.id} | role: ${admin.role}`);

      res.json({
        id: admin.id,
        username: admin.username,
        name: admin.name,
        role: admin.role
      });
    } catch (error) {
      console.error(`[AUDIT] ADMIN_LOGIN | ts: ${ts} | ip: ${clientIp} | result: ERROR`, error);
      res.status(500).json({ error: "Logowanie nie powiodło się" });
    }
  });
  
  // Admin session check
  app.get("/api/admin/session", async (req, res) => {
    const adminId = (req.session as any)?.adminId;
    if (!adminId) {
      return res.status(401).json({ error: "Nie zalogowany" });
    }
    
    const admin = await storage.getAdmin(adminId);
    if (!admin) {
      return res.status(401).json({ error: "Admin nie znaleziony" });
    }
    
    res.json({ 
      id: admin.id, 
      username: admin.username, 
      name: admin.name,
      role: admin.role 
    });
  });
  
  // Admin logout
  app.post("/api/admin/logout", (req, res) => {
    delete (req.session as any).adminId;
    delete (req.session as any).adminRole;
    res.json({ message: "Wylogowano" });
  });
  
  // Admin middleware
  const requireAdmin = async (req: Request, res: Response, next: NextFunction) => {
    const adminId = (req.session as any)?.adminId;
    if (!adminId) {
      return res.status(401).json({ error: "Wymagane logowanie administratora" });
    }
    (req as any).adminId = adminId;
    next();
  };
  
  // Get all passengers (users)
  app.get("/api/admin/users", requireAdmin, async (req, res) => {
    try {
      const allUsers = await storage.getAllUsers();
      const allRides = await storage.getAllRides();
      
      // Calculate total spending for each user
      const userStats = new Map<string, { totalSpent: number; rideCount: number }>();
      for (const ride of allRides) {
        if (ride.passengerId && ride.status === "completed" && ride.finalPrice) {
          const existing = userStats.get(ride.passengerId) || { totalSpent: 0, rideCount: 0 };
          existing.totalSpent += ride.finalPrice;
          existing.rideCount += 1;
          userStats.set(ride.passengerId, existing);
        }
      }
      
      res.json(allUsers.map(u => {
        const stats = userStats.get(u.id) || { totalSpent: 0, rideCount: 0 };
        return {
          id: u.id,
          username: u.username,
          plainPassword: u.plainPassword,
          firstName: u.firstName,
          lastName: u.lastName,
          email: u.email,
          phone: u.phone,
          homeAddress: u.homeAddress,
          isOnline: u.isOnline,
          isBlocked: u.isBlocked,
          blockedAt: u.blockedAt,
          blockedReason: u.blockedReason,
          createdAt: u.createdAt,
          totalSpent: stats.totalSpent,
          rideCount: stats.rideCount
        };
      }));
    } catch (error) {
      res.status(500).json({ error: "Nie udało się pobrać użytkowników" });
    }
  });
  
  // Get passenger ride history
  app.get("/api/admin/users/:id/rides", requireAdmin, async (req, res) => {
    try {
      const passengerId = String(req.params.id);
      const allRides = await storage.getAllRides();
      const allDrivers = await storage.getAllDrivers();
      const driversMap = new Map(allDrivers.map(d => [d.id, d]));
      
      const passengerRides = allRides
        .filter(r => r.passengerId === passengerId)
        .map(r => {
          const driver = r.driverId ? driversMap.get(r.driverId) : null;
          return {
            id: r.id,
            pickupLocation: r.pickupLocation,
            destination: r.destination,
            status: r.status,
            finalPrice: r.finalPrice,
            driverName: driver?.name || null,
            callerPhone: r.callerPhone || null,
            orderSource: r.orderSource || null,
            createdAt: r.createdAt,
            completedAt: r.completedAt
          };
        })
        .sort((a, b) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime());
      
      res.json(passengerRides);
    } catch (error) {
      res.status(500).json({ error: "Nie udało się pobrać historii przejazdów" });
    }
  });
  
  // Get driver ride history  
  app.get("/api/admin/drivers/:id/rides", requireAdmin, async (req, res) => {
    try {
      const driverId = String(req.params.id);
      const allRides = await storage.getAllRides();
      const allUsers = await storage.getAllUsers();
      const usersMap = new Map(allUsers.map(u => [u.id, u]));
      
      const driverRides = allRides
        .filter(r => r.driverId === driverId)
        .map(r => {
          const passenger = r.passengerId ? usersMap.get(r.passengerId) : null;
          return {
            id: r.id,
            pickupLocation: r.pickupLocation,
            destination: r.destination,
            status: r.status,
            finalPrice: r.finalPrice,
            passengerName: passenger ? `${passenger.firstName} ${passenger.lastName}` : null,
            callerPhone: r.callerPhone || null,
            orderSource: r.orderSource || null,
            createdAt: r.createdAt,
            completedAt: r.completedAt
          };
        })
        .sort((a, b) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime());
      
