  app.post("/api/system-messages/:id/acknowledge", async (req, res) => {
    try {
      const session = req.session as any;
      let userId: string | null = null;
      let role: string | null = null;

      if (session.driverId) { userId = session.driverId; role = "DRIVER"; }
      else if (session.passengerId) { userId = session.passengerId; role = "PASSENGER"; }

      if (!userId || !role) return res.status(401).json({ error: "Nie zalogowany" });

      const msg = await storage.getSystemMessage(req.params.id);
      if (!msg) return res.status(404).json({ error: "Wiadomość nie znaleziona" });
      if (!msg.requireAcknowledgement) return res.status(400).json({ error: "Ta wiadomość nie wymaga potwierdzenia" });

      await storage.markMessageRead(userId, role, req.params.id);
      const result = await storage.acknowledgeMessage(userId, req.params.id);
      res.json(result);
    } catch (error) {
      console.error("Error acknowledging message:", error);
      res.status(500).json({ error: "Nie udało się potwierdzić wiadomości" });
