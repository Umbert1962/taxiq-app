  // Delete company
  app.delete("/api/admin/companies/:id", requireAdmin, async (req, res) => {
    try {
      await storage.deleteCompany(String(req.params.id));
      res.json({ message: "Firma usunięta" });
    } catch (error) {
      res.status(500).json({ error: "Nie udało się usunąć firmy" });
    }
  });
  
  // Delete account (GDPR compliance)
  app.delete("/api/account/delete", async (req, res) => {
    try {
      const { accountType, username, password } = req.body;
      
      if (!accountType || !username || !password) {
        return res.status(400).json({ error: "Wszystkie pola są wymagane" });
      }
      
      if (accountType === "passenger") {
        const user = await storage.getUserByUsername(username);
        if (!user) {
          return res.status(404).json({ error: "Nie znaleziono konta" });
        }
        const isValid = await verifyPassword(password, user.password);
        if (!isValid) {
          return res.status(401).json({ error: "Nieprawidłowe hasło" });
        }
        await storage.deleteUser(user.id);
        res.json({ message: "Konto usunięte" });
      } else if (accountType === "driver") {
        const driver = await storage.getDriverByUsername(username);
        if (!driver) {
          return res.status(404).json({ error: "Nie znaleziono konta" });
        }
        const isValid = await verifyPassword(password, driver.password);
        if (!isValid) {
          return res.status(401).json({ error: "Nieprawidłowe hasło" });
        }
        await storage.deleteDriver(driver.id);
        res.json({ message: "Konto usunięte" });
      } else if (accountType === "company") {
        const company = await storage.getCompanyByEmail(username);
        if (!company) {
          return res.status(404).json({ error: "Nie znaleziono konta" });
        }
        const isValid = await verifyPassword(password, company.password);
        if (!isValid) {
          return res.status(401).json({ error: "Nieprawidłowe hasło" });
        }
        await storage.deleteCompany(company.id);
        res.json({ message: "Konto usunięte" });
      } else {
        return res.status(400).json({ error: "Nieprawidłowy typ konta" });
      }
    } catch (error) {
      console.error("Delete account error:", error);
      res.status(500).json({ error: "Nie udało się usunąć konta" });
    }
  });

  // Create first admin (one-time setup)
  app.post("/api/admin/setup", async (req, res) => {
    try {
      const admins = await storage.getAllAdmins();
      if (admins.length > 0) {
        return res.status(400).json({ error: "Administrator już istnieje" });
      }
      
      const { username, password, name } = req.body;
      if (!username || !password || !name) {
        return res.status(400).json({ error: "Wszystkie pola są wymagane" });
      }
      
      const hashedPassword = await hashPassword(password);
      const admin = await storage.createAdmin({
        username,
        password: hashedPassword,
        name,
        role: "superadmin"
      });
      
      res.json({ message: "Administrator utworzony", id: admin.id });
    } catch (error) {
      res.status(500).json({ error: "Nie udało się utworzyć administratora" });
    }
  });

  // ==================== SUBSCRIPTION PLANS ====================
  
  // Get all subscription plans (public - for drivers to see)
  app.get("/api/subscription-plans", async (req, res) => {
    try {
      const plans = await db.select().from(subscriptionPlans).where(eq(subscriptionPlans.isActive, true));
      res.json(plans);
    } catch (error) {
      console.error("Error getting subscription plans:", error);
      res.status(500).json({ error: "Nie udało się pobrać planów abonamentowych" });
    }
  });

  // Get all subscription plans (admin - includes inactive)
  app.get("/api/admin/subscription-plans", requireAdmin, async (req, res) => {
    try {
      const plans = await db.select().from(subscriptionPlans);
      res.json(plans);
    } catch (error) {
      console.error("Error getting subscription plans:", error);
      res.status(500).json({ error: "Nie udało się pobrać planów abonamentowych" });
    }
  });

  // Create subscription plan
  app.post("/api/admin/subscription-plans", requireAdmin, async (req, res) => {
    try {
      const parsed = insertSubscriptionPlanSchema.safeParse(req.body);
      if (!parsed.success) {
        return res.status(400).json({ error: "Nieprawidłowe dane", details: parsed.error.errors });
      }
      
      const [plan] = await db.insert(subscriptionPlans).values(parsed.data).returning();
      res.status(201).json(plan);
    } catch (error) {
      console.error("Error creating subscription plan:", error);
      res.status(500).json({ error: "Nie udało się utworzyć planu" });
    }
  });

  // Update subscription plan
  app.patch("/api/admin/subscription-plans/:id", requireAdmin, async (req, res) => {
    try {
      const planId = req.params.id;
      const { name, durationDays, price, description, isActive, isDefault } = req.body;
      
      const updateData: any = { updatedAt: new Date() };
      if (name !== undefined) updateData.name = name;
      if (durationDays !== undefined) updateData.durationDays = durationDays;
      if (price !== undefined) updateData.price = price;
      if (description !== undefined) updateData.description = description;
      if (isActive !== undefined) updateData.isActive = isActive;
      if (isDefault !== undefined) updateData.isDefault = isDefault;
      
      // If setting as default, unset other defaults
      if (isDefault === true) {
        await db.update(subscriptionPlans).set({ isDefault: false });
      }
      
      const [updated] = await db.update(subscriptionPlans)
        .set(updateData)
        .where(eq(subscriptionPlans.id, planId))
        .returning();
      
      if (!updated) {
        return res.status(404).json({ error: "Plan nie znaleziony" });
      }
      
      res.json(updated);
    } catch (error) {
      console.error("Error updating subscription plan:", error);
      res.status(500).json({ error: "Nie udało się zaktualizować planu" });
    }
  });

  // Delete subscription plan
  app.delete("/api/admin/subscription-plans/:id", requireAdmin, async (req, res) => {
    try {
      const planId = req.params.id;
      
      await db.delete(subscriptionPlans).where(eq(subscriptionPlans.id, planId));
      res.json({ message: "Plan usunięty" });
    } catch (error) {
      console.error("Error deleting subscription plan:", error);
      res.status(500).json({ error: "Nie udało się usunąć planu" });
    }
  });

  // Update driver subscription discount (admin only)
  app.patch("/api/admin/drivers/:id/subscription-discount", requireAdmin, async (req, res) => {
    try {
      const driverId = req.params.id;
      const { subscriptionDiscount } = req.body;
      
      if (subscriptionDiscount === undefined || subscriptionDiscount < 0) {
        return res.status(400).json({ error: "Nieprawidłowa wartość zniżki" });
      }
      
      const [updated] = await db.update(drivers)
        .set({ subscriptionDiscount })
        .where(eq(drivers.id, driverId))
        .returning();
      
      if (!updated) {
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      
      res.json({ message: "Zniżka zaktualizowana", subscriptionDiscount: updated.subscriptionDiscount });
    } catch (error) {
      console.error("Error updating driver subscription discount:", error);
      res.status(500).json({ error: "Nie udało się zaktualizować zniżki" });
    }
  });

  // Assign subscription plan to driver (admin only)
  app.patch("/api/admin/drivers/:id/assign-plan", requireAdmin, async (req, res) => {
    try {
      const driverId = req.params.id;
      const { planId } = req.body;
      
      // planId can be null to unassign
      if (planId !== null && planId !== undefined) {
        // Verify plan exists
        const [plan] = await db.select().from(subscriptionPlans).where(eq(subscriptionPlans.id, planId));
        if (!plan) {
          return res.status(404).json({ error: "Plan nie znaleziony" });
        }
      }
      
      const [updated] = await db.update(drivers)
        .set({ assignedPlanId: planId || null })
        .where(eq(drivers.id, driverId))
        .returning();
      
      if (!updated) {
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      
      res.json({ message: "Plan przydzielony", assignedPlanId: updated.assignedPlanId });
    } catch (error) {
      console.error("Error assigning plan to driver:", error);
      res.status(500).json({ error: "Nie udało się przydzielić planu" });
    }
  });

  // ========== PAYMENT ENDPOINTS ==========

  // Get payment settings (bank account, BLIK phone)
  app.get("/api/payment-settings", async (req, res) => {
    try {
      const settings = await db.select().from(systemSettings)
        .where(eq(systemSettings.settingKey, "payment_bank_account"))
        .limit(1);
      const blikSettings = await db.select().from(systemSettings)
        .where(eq(systemSettings.settingKey, "payment_blik_phone"))
        .limit(1);
      const recipientSettings = await db.select().from(systemSettings)
        .where(eq(systemSettings.settingKey, "payment_recipient_name"))
        .limit(1);
      
      res.json({
        bankAccount: settings[0]?.settingValue || "",
        blikPhone: blikSettings[0]?.settingValue || "",
        recipientName: recipientSettings[0]?.settingValue || "",
      });
    } catch (error) {
      console.error("Error getting payment settings:", error);
      res.status(500).json({ error: "Nie udało się pobrać ustawień płatności" });
    }
  });

  // Admin: Update payment settings
  app.put("/api/admin/payment-settings", requireAdmin, async (req, res) => {
    try {
      const { bankAccount, blikPhone, recipientName } = req.body;
      
      // Upsert bank account
      if (bankAccount !== undefined) {
        const existing = await db.select().from(systemSettings)
          .where(eq(systemSettings.settingKey, "payment_bank_account"));
        if (existing.length > 0) {
          await db.update(systemSettings)
            .set({ settingValue: bankAccount, updatedAt: new Date() })
            .where(eq(systemSettings.settingKey, "payment_bank_account"));
        } else {
          await db.insert(systemSettings).values({
            settingKey: "payment_bank_account",
            settingValue: bankAccount,
            description: "Numer konta bankowego do wpłat",
          });
        }
      }
      
      // Upsert BLIK phone
      if (blikPhone !== undefined) {
        const existing = await db.select().from(systemSettings)
          .where(eq(systemSettings.settingKey, "payment_blik_phone"));
        if (existing.length > 0) {
          await db.update(systemSettings)
            .set({ settingValue: blikPhone, updatedAt: new Date() })
            .where(eq(systemSettings.settingKey, "payment_blik_phone"));
        } else {
          await db.insert(systemSettings).values({
            settingKey: "payment_blik_phone",
            settingValue: blikPhone,
            description: "Numer telefonu do płatności BLIK",
          });
        }
      }
      
      // Upsert recipient name
      if (recipientName !== undefined) {
        const existing = await db.select().from(systemSettings)
          .where(eq(systemSettings.settingKey, "payment_recipient_name"));
        if (existing.length > 0) {
          await db.update(systemSettings)
            .set({ settingValue: recipientName, updatedAt: new Date() })
            .where(eq(systemSettings.settingKey, "payment_recipient_name"));
        } else {
          await db.insert(systemSettings).values({
            settingKey: "payment_recipient_name",
            settingValue: recipientName,
            description: "Nazwa odbiorcy płatności",
          });
        }
      }
      
      res.json({ message: "Ustawienia płatności zaktualizowane" });
    } catch (error) {
      console.error("Error updating payment settings:", error);
      res.status(500).json({ error: "Nie udało się zaktualizować ustawień płatności" });
    }
  });

  // Driver: Submit payment request
  app.post("/api/payment-requests", async (req, res) => {
    try {
      const { driverId, amount, planId, planName, durationDays, paymentMethod, transactionId, notes } = req.body;
      
      if (!driverId || !amount || !paymentMethod) {
        return res.status(400).json({ error: "Brakuje wymaganych pól" });
      }
      
      const [request] = await db.insert(paymentRequests).values({
        driverId,
        amount,
        planId,
        planName,
        durationDays,
        paymentMethod,
        transactionId,
        notes,
        status: "pending",
      }).returning();
      
      res.json(request);
    } catch (error) {
      console.error("Error creating payment request:", error);
      res.status(500).json({ error: "Nie udało się zgłosić płatności" });
    }
  });

  // Driver: Get my payment requests
  app.get("/api/drivers/:id/payment-requests", async (req, res) => {
    try {
      const driverId = req.params.id;
      const requests = await db.select().from(paymentRequests)
        .where(eq(paymentRequests.driverId, driverId))
        .orderBy(paymentRequests.createdAt);
      
      res.json(requests);
    } catch (error) {
      console.error("Error getting driver payment requests:", error);
      res.status(500).json({ error: "Nie udało się pobrać zgłoszeń płatności" });
    }
  });

  // Admin: Get all payment requests
  app.get("/api/admin/payment-requests", requireAdmin, async (req, res) => {
    try {
      const requests = await db.select().from(paymentRequests)
        .orderBy(paymentRequests.createdAt);
      
      // Get driver names for each request
      const requestsWithDrivers = await Promise.all(requests.map(async (req) => {
        const driver = await storage.getDriver(req.driverId);
        return {
          ...req,
          driverName: driver?.name || "Nieznany kierowca",
          driverPhone: driver?.phone || "",
        };
      }));
      
      res.json(requestsWithDrivers);
    } catch (error) {
      console.error("Error getting payment requests:", error);
      res.status(500).json({ error: "Nie udało się pobrać zgłoszeń płatności" });
    }
  });

  // Admin: Approve payment request and activate subscription
  app.post("/api/admin/payment-requests/:id/approve", requireAdmin, async (req, res) => {
    try {
      const requestId = req.params.id;
      const adminId = req.session?.adminId;
      
      // Get the payment request
      const [request] = await db.select().from(paymentRequests)
        .where(eq(paymentRequests.id, requestId));
      
      if (!request) {
        return res.status(404).json({ error: "Zgłoszenie nie znalezione" });
      }
      
      if (request.status !== "pending") {
        return res.status(400).json({ error: "To zgłoszenie zostało już przetworzone" });
      }
      
      // Update payment request status
      await db.update(paymentRequests)
        .set({ 
          status: "approved",
          processedAt: new Date(),
          processedBy: adminId,
        })
        .where(eq(paymentRequests.id, requestId));
      
      // Activate driver subscription
      const durationDays = request.durationDays || 30;
      const subscriptionEndsAt = new Date();
      subscriptionEndsAt.setDate(subscriptionEndsAt.getDate() + durationDays);
      
      await db.update(drivers)
        .set({
          subscriptionStatus: "active",
          subscriptionEndsAt,
        })
        .where(eq(drivers.id, request.driverId));

      // Referral reward: when referred driver pays first subscription
      try {
        const referral = await storage.getReferralByReferredDriver(request.driverId);
        if (referral && referral.status === 'pending') {
          const plan = request.planId ? await db.select().from(subscriptionPlans).where(eq(subscriptionPlans.id, request.planId)).then(r => r[0]) : null;
          const rewardAmount = plan ? Math.round(plan.price * 0.25) : 0;
          const rewardDesc = rewardAmount > 0 ? `25% subskrypcji: ${(rewardAmount / 100).toFixed(2)} PLN` : 'Bonus za polecenie kierowcy';
          await storage.updateReferralStatus(referral.id, 'rewarded', rewardDesc);
          await storage.incrementDriverReferralCount(referral.referrerDriverId, 'driver');
          await storage.addDriverReferralPoints(referral.referrerDriverId, rewardAmount > 0 ? rewardAmount : 100);

          // Create payout record for referrer driver
          if (rewardAmount > 0) {
            const referrerDriver = await storage.getDriver(referral.referrerDriverId);
            await storage.createReferralPayout({
              referralId: referral.id,
              driverId: referral.referrerDriverId,
              amount: rewardAmount,
              description: rewardDesc,
              bankAccountNumber: referrerDriver?.bankAccountNumber || null,
              bankAccountHolder: referrerDriver?.bankAccountHolder || null,
            });
          }
        }
      } catch (refErr) {
        console.error("Referral reward error:", refErr);
      }
      
      res.json({ message: "Płatność zatwierdzona, subskrypcja aktywowana" });
    } catch (error) {
      console.error("Error approving payment request:", error);
      res.status(500).json({ error: "Nie udało się zatwierdzić płatności" });
    }
  });

  // Admin: Reject payment request
  app.post("/api/admin/payment-requests/:id/reject", requireAdmin, async (req, res) => {
    try {
      const requestId = req.params.id;
      const adminId = req.session?.adminId;
      const { reason } = req.body;
      
      await db.update(paymentRequests)
        .set({ 
          status: "rejected",
          processedAt: new Date(),
          processedBy: adminId,
          notes: reason || "Odrzucono",
        })
        .where(eq(paymentRequests.id, requestId));
      
      res.json({ message: "Zgłoszenie odrzucone" });
    } catch (error) {
      console.error("Error rejecting payment request:", error);
      res.status(500).json({ error: "Nie udało się odrzucić zgłoszenia" });
    }
  });

  // ==================== DRIVER VERIFICATION SYSTEM ====================

  // SECURITY FIX: Rate limit document uploads (max 3 per hour per driver)
  const docUploadRateMap = new Map<string, number[]>();
  const DOC_UPLOAD_MAX = 3;
  const DOC_UPLOAD_WINDOW_MS = 60 * 60 * 1000; // 1 hour

  const idDocUpload = multer({
    storage: multer.diskStorage({
      destination: "/tmp/uploads",
      filename: (_req, file, cb) => cb(null, `iddoc-${Date.now()}-${file.originalname}`),
    }),
    limits: { fileSize: 10 * 1024 * 1024 },
    fileFilter: imageFileFilter,
  });

  app.post("/api/driver/verify-city-id", async (req, res) => {
    try {
      const driverId = (req.session as any).driverId;
      if (!driverId) return res.status(401).json({ error: "Nieautoryzowany" });

      const { cityDriverId } = req.body;
      if (!cityDriverId || typeof cityDriverId !== "string" || !/^\d+$/.test(cityDriverId.trim())) {
        return res.status(400).json({ error: "Podaj prawidłowy numer ID kierowcy (tylko cyfry)" });
      }

      const now = Date.now();
      const driverUploads = (docUploadRateMap.get(driverId) || []).filter(t => now - t < DOC_UPLOAD_WINDOW_MS);
      if (driverUploads.length >= DOC_UPLOAD_MAX) {
        return res.status(429).json({ error: "Przekroczono limit weryfikacji. Maksymalnie 3 na godzinę. Spróbuj ponownie później." });
      }
      driverUploads.push(now);
      docUploadRateMap.set(driverId, driverUploads);

      const driver = await storage.getDriver(driverId);
      if (!driver) return res.status(404).json({ error: "Kierowca nie znaleziony" });

      console.log(`[VERIFY_PIPELINE] City ID verification requested by driver ${driverId}, cityDriverId=${cityDriverId.trim()}`);

      await db.update(drivers).set({
        verificationStatus: "pending",
        verificationError: null,
      }).where(eq(drivers.id, driverId));

      const { processDriverVerification } = require("./services/driverVerification");
      const result = await processDriverVerification(driverId, cityDriverId.trim());

      const isSuccess = result.verificationStatus === "approved_auto";
      const statusMessages: Record<string, string> = {
        approved_auto: "Weryfikacja zakończona pomyślnie. Możesz teraz przejść w tryb online.",
        suspended_medical: "Twoje badania lekarskie lub psychologiczne są nieważne. Zaktualizuj je w urzędzie, aby wrócić online.",
        failed_city_lookup: "Nie udało się zweryfikować danych w systemie miejskim. Spróbuj ponownie później lub skontaktuj się z administracją.",
        manual_review_required: "Dane z systemu miejskiego nie zgadzają się z Twoim profilem. Skontaktuj się z administracją.",
      };

      const responseData = {
        message: statusMessages[result.verificationStatus] || "Weryfikacja przetworzona.",
        verificationStatus: result.verificationStatus,
        cityDriverId: result.cityDriverId || null,
        cityFirstName: result.cityFirstName || null,
        cityLastName: result.cityLastName || null,
        medicalValid: result.medicalValid ?? null,
        psychologicalValid: result.psychologicalValid ?? null,
      };

      if (isSuccess) {
        res.json(responseData);
      } else {
        res.status(422).json(responseData);
      }
    } catch (error) {
      console.error("Error in city ID verification:", error);
      res.status(500).json({ error: "Błąd podczas weryfikacji" });
    }
  });

  app.get("/api/driver/verification-status", async (req, res) => {
    try {
      const driverId = (req.session as any).driverId;
      if (!driverId) return res.status(401).json({ error: "Nieautoryzowany" });
      const driver = await storage.getDriver(driverId);
      if (!driver) return res.status(404).json({ error: "Kierowca nie znaleziony" });
      res.json({
        verificationStatus: driver.verificationStatus,
        taxiqId: driver.taxiqId,
        extractedFirstName: driver.extractedFirstName,
        extractedLastName: driver.extractedLastName,
        extractedLicenseNumber: driver.extractedLicenseNumber,
        nameMatchScore: driver.nameMatchScore,
        verificationNotes: driver.verificationNotes,
        verifiedAt: driver.verifiedAt,
        verificationError: driver.verificationError,
        cityFirstName: driver.cityFirstName,
        cityLastName: driver.cityLastName,
        cityMedicalValid: driver.cityMedicalValid,
        cityPsychologicalValid: driver.cityPsychologicalValid,
      });
    } catch (error) {
      res.status(500).json({ error: "Błąd pobierania statusu weryfikacji" });
    }
  });

  app.get("/api/admin/verification-queue", requireAdmin, async (req, res) => {
    try {
      const allDrivers = await storage.getAllDrivers();
      const queue = allDrivers
        .filter((d: any) => ['PENDING', 'MANUAL_REVIEW', 'REJECTED', 'SUSPENDED', 'pending', 'failed_qr', 'failed_city_lookup', 'suspended_auto', 'manual_review_required', 'approved_auto'].includes(d.verificationStatus))
        .map((d: any) => ({
          id: d.id,
          firstName: d.firstName,
          lastName: d.lastName,
          name: d.name,
          phone: d.phone,
          taxiqId: d.taxiqId,
          verificationStatus: d.verificationStatus,
          extractedFirstName: d.extractedFirstName,
          extractedLastName: d.extractedLastName,
          extractedLicenseNumber: d.extractedLicenseNumber,
          nameMatchScore: d.nameMatchScore,
          taxiLicenseNumber: d.taxiLicenseNumber,
          idDocumentUrl: d.idDocumentUrl,
          documentQrData: d.documentQrData,
          cityVerificationUrl: d.cityVerificationUrl,
          verificationNotes: d.verificationNotes,
          verifiedAt: d.verifiedAt,
          createdAt: d.createdAt,
          isActive: d.isActive,
          photoUrl: d.photoUrl,
          extractedPhotoUrl: d.extractedPhotoUrl,
          cityDriverId: d.cityDriverId,
          cityFirstName: d.cityFirstName,
          cityLastName: d.cityLastName,
          cityLicenseNumbers: d.cityLicenseNumbers,
          cityMedicalValid: d.cityMedicalValid,
          cityPsychologicalValid: d.cityPsychologicalValid,
          verificationCheckedAt: d.verificationCheckedAt,
          verificationError: d.verificationError,
        }));
      res.json(queue);
    } catch (error) {
      console.error("Error fetching verification queue:", error);
      res.status(500).json({ error: "Nie udało się pobrać kolejki weryfikacji" });
    }
  });

  app.get("/api/admin/driver-document/:driverId", requireAdmin, async (req, res) => {
    try {
      const driverId = req.params.driverId as string;
      const driver = await storage.getDriver(driverId);
      if (!driver || !driver.idDocumentUrl) {
        return res.status(404).json({ error: "Dokument nie znaleziony" });
      }
      try {
        const objectFile = await objectStorageService.getObjectEntityFile(driver.idDocumentUrl);
        await objectStorageService.downloadObject(objectFile, res, 0);
      } catch (objError: any) {
        if (objError?.name === "ObjectNotFoundError") {
          return res.status(404).json({ error: "Plik nie istnieje w chmurze" });
        }
        throw objError;
      }
    } catch (error) {
      console.error("Error fetching driver document:", error);
      res.status(500).json({ error: "Nie udało się pobrać dokumentu" });
    }
  });

  app.post("/api/admin/verify-driver/:driverId", requireAdmin, async (req, res) => {
    try {
      const { action, notes } = req.body;
      const driverId = req.params.driverId as string;
      const adminId = (req.session as any).adminId;
      const driver = await storage.getDriver(driverId);
      if (!driver) return res.status(404).json({ error: "Kierowca nie znaleziony" });

      const validActions = ["reject", "suspend"];
      if (!validActions.includes(action)) {
        return res.status(400).json({ error: "Nieprawidłowa akcja. Użyj: reject, suspend. Zatwierdzanie odbywa się wyłącznie automatycznie przez weryfikację miejską." });
      }

      let updateData: any = {};
      if (action === "reject") {
        updateData = {
          verificationStatus: "REJECTED",
          verificationNotes: notes || "Odrzucono przez administratora",
          verifiedByAdminId: adminId,
          isOnline: false,
        };
        console.log(`[ADMIN_VERIFY] Driver ${driverId} REJECTED by admin ${adminId}. Notes: ${notes || "none"}`);
      } else if (action === "suspend") {
        updateData = {
          verificationStatus: "SUSPENDED",
          verificationNotes: notes || "Zawieszono przez administratora",
          verifiedByAdminId: adminId,
          isOnline: false,
        };
        console.log(`[ADMIN_VERIFY] Driver ${driverId} SUSPENDED by admin ${adminId}. Notes: ${notes || "none"}`);
      }

      await db.update(drivers).set(updateData).where(eq(drivers.id, driverId));

      const updated = await storage.getDriver(driverId);
      res.json({
        message: action === "reject" ? "Weryfikacja odrzucona" : "Weryfikacja zawieszona",
        driver: {
          id: updated?.id,
          name: updated?.name,
          verificationStatus: updated?.verificationStatus,
        },
      });
    } catch (error) {
      console.error("Error verifying driver:", error);
      res.status(500).json({ error: "Nie udało się zaktualizować weryfikacji" });
    }
  });

  app.get("/api/verify/:taxiqId", async (req, res) => {
    try {
      const driver = await storage.getDriverByTaxiqId(req.params.taxiqId);
      if (!driver) {
        return res.status(404).json({
          error: "Kierowca nie znaleziony",
          verified: false,
        });
      }
      const isVerifiedAndActive = driver.verificationStatus === "approved_auto" && !!driver.cityDriverId && !!driver.verificationCheckedAt && driver.isActive;
      res.json({
        taxiqId: driver.taxiqId,
        firstName: driver.firstName,
        extractedPhotoUrl: driver.extractedPhotoUrl,
        verificationStatus: driver.verificationStatus,
        taxiLicenseNumber: isVerifiedAndActive ? driver.taxiLicenseNumber : null,
        isActive: driver.isActive,
        verified: isVerifiedAndActive,
        message: isVerifiedAndActive
          ? "Kierowca zweryfikowany i aktywny"
          : "Kierowca nieaktywny lub niezweryfikowany",
      });
    } catch (error) {
      console.error("Error in public verify endpoint:", error);
      res.status(500).json({ error: "Błąd weryfikacji" });
    }
  });

  return httpServer;
}
