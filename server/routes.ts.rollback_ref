  app.patch("/api/business/employees/:id", requireBusinessAuth, async (req, res) => {
    try {
      const employee = await storage.getEmployee(String(req.params.id));
      if (!employee) {
        return res.status(404).json({ error: "Employee not found" });
      }
      if (req.businessSession?.companyId !== employee.companyId) {
        return res.status(403).json({ error: "Access denied" });
      }
      const updated = await storage.updateEmployee(String(req.params.id), req.body);
      res.json(updated);
    } catch (error) {
      res.status(500).json({ error: "Failed to update employee" });
    }
  });

  app.delete("/api/business/employees/:id", requireBusinessAuth, async (req, res) => {
    try {
      const employee = await storage.getEmployee(String(req.params.id));
      if (!employee) {
        return res.status(404).json({ error: "Employee not found" });
      }
      if (req.businessSession?.companyId !== employee.companyId) {
        return res.status(403).json({ error: "Access denied" });
      }
      await storage.deleteEmployee(String(req.params.id));
      res.json({ success: true });
    } catch (error) {
      res.status(500).json({ error: "Failed to delete employee" });
    }
  });

  // Update company profile (by admin/owner)
  app.patch("/api/business/company/:id", requireBusinessAuth, requireCompanyAccess, async (req, res) => {
    try {
      const session = req.businessSession!;
      
      // Only company owner or admin can update company
      if (session.type !== "company" && session.role !== "admin") {
        return res.status(403).json({ error: "Tylko administrator może edytować dane firmy" });
      }
      
      const { name, phone, address, taxId } = req.body;
      
      await db.update(companies).set({
        ...(name && { name }),
        ...(phone !== undefined && { phone }),
        ...(address !== undefined && { address }),
        ...(taxId !== undefined && { taxId }),
      }).where(eq(companies.id, String(req.params.id)));
      
      const updatedCompany = await storage.getCompany(String(req.params.id));
      res.json({ success: true, company: updatedCompany });
    } catch (error) {
      console.error("Error updating company:", error);
      res.status(500).json({ error: "Błąd aktualizacji danych firmy" });
    }
  });

  // Update my own profile (employee or company)
  app.patch("/api/business/my-profile", requireBusinessAuth, async (req, res) => {
    try {
      const session = req.businessSession!;
      const { name, email, phone } = req.body;
      
      if (session.type === "company") {
        // Update company email
        await db.update(companies).set({
          ...(name && { name }),
          ...(phone !== undefined && { phone }),
        }).where(eq(companies.id, session.id));
        
        const updatedCompany = await storage.getCompany(session.id);
        res.json({ success: true, user: updatedCompany });
      } else {
        // Update employee profile
        await db.update(employees).set({
          ...(name && { name }),
          ...(email && { email }),
          ...(phone !== undefined && { phone }),
        }).where(eq(employees.id, session.id));
        
        const updatedEmployee = await storage.getEmployee(session.id);
        res.json({ success: true, user: updatedEmployee });
      }
    } catch (error) {
      console.error("Error updating profile:", error);
      res.status(500).json({ error: "Błąd aktualizacji profilu" });
    }
  });

  // ============ BUSINESS RIDES ============
  app.get("/api/business/company/:id/rides", requireBusinessAuth, requireCompanyAccess, async (req, res) => {
    try {
      const rides = await storage.getCompanyBusinessRides(String(req.params.id));
      res.json(rides);
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch business rides" });
    }
  });

  app.post("/api/business/rides", requireBusinessAuth, async (req, res) => {
    try {
      const session = req.businessSession!;
      const rideData = insertRideSchema.safeParse(req.body.ride);
      if (!rideData.success) {
        return res.status(400).json({ error: "Invalid ride data" });
      }
      
      const ride = await storage.createRide(rideData.data);
      
      const businessRideData = insertBusinessRideSchema.safeParse({
        ...req.body.businessRide,
        companyId: session.companyId,
        employeeId: session.type === "employee" ? session.id : undefined,
        rideId: ride.id
      });
      if (!businessRideData.success) {
        return res.status(400).json({ error: "Invalid business ride data" });
      }
      
      const businessRide = await storage.createBusinessRide(businessRideData.data);
      res.status(201).json({ ride, businessRide });
    } catch (error) {
      res.status(500).json({ error: "Failed to create business ride" });
    }
  });

  app.get("/api/business/company/:id/stats", requireBusinessAuth, requireCompanyAccess, async (req, res) => {
    try {
      const stats = await storage.getCompanyStats(String(req.params.id));
      res.json(stats);
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch stats" });
    }
  });

  // ============ INVOICES ============
  app.get("/api/business/company/:id/invoices", requireBusinessAuth, requireCompanyAccess, async (req, res) => {
    try {
      const invoices = await storage.getCompanyInvoices(String(req.params.id));
      res.json(invoices);
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch invoices" });
    }
  });

  app.get("/api/business/invoices/:id", requireBusinessAuth, async (req, res) => {
    try {
      const invoice = await storage.getInvoice(String(req.params.id));
      if (!invoice) {
        return res.status(404).json({ error: "Invoice not found" });
      }
      if (req.businessSession?.companyId !== invoice.companyId) {
        return res.status(403).json({ error: "Access denied" });
      }
      const items = await storage.getInvoiceItems(String(req.params.id));
      const company = await storage.getCompany(invoice.companyId);
      res.json({ ...invoice, items, company });
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch invoice" });
    }
  });

  app.post("/api/business/company/:id/invoices/generate", requireBusinessAuth, requireCompanyAccess, async (req, res) => {
    try {
      const { periodStart, periodEnd } = req.body;
      const invoice = await storage.generateInvoice(
        String(req.params.id),
        new Date(periodStart),
        new Date(periodEnd)
      );
      if (!invoice) {
        return res.status(400).json({ error: "No rides in this period" });
      }
      res.status(201).json(invoice);
    } catch (error) {
      res.status(500).json({ error: "Failed to generate invoice" });
    }
  });

  app.patch("/api/business/invoices/:id/status", requireBusinessAuth, async (req, res) => {
    try {
      const invoice = await storage.getInvoice(String(req.params.id));
      if (!invoice) {
        return res.status(404).json({ error: "Invoice not found" });
      }
      if (req.businessSession?.companyId !== invoice.companyId) {
        return res.status(403).json({ error: "Access denied" });
      }
      const { status } = req.body;
      const paidAt = status === "paid" ? new Date() : undefined;
      const updated = await storage.updateInvoiceStatus(String(req.params.id), status, paidAt);
      if (!updated) {
        return res.status(404).json({ error: "Invoice not found" });
      }
      res.json(invoice);
    } catch (error) {
      res.status(500).json({ error: "Failed to update invoice status" });
    }
  });

  // ============= REFERRAL ENDPOINTS =============

  // Validate referral code (public - used during registration)
  app.get("/api/referral/validate/:code", async (req, res) => {
    try {
      const driver = await storage.getDriverByReferralCode(req.params.code);
      if (!driver) {
        return res.status(404).json({ valid: false, error: "Nieprawidłowy kod polecający" });
      }
      res.json({ valid: true, driverName: driver.name });
    } catch (error) {
      res.status(500).json({ error: "Błąd walidacji kodu" });
    }
  });

  // Get driver's referral stats (authenticated driver)
  app.get("/api/driver/referrals", async (req, res) => {
    try {
      const driverId = (req.session as any)?.driverId;
      if (!driverId) return res.status(401).json({ error: "Nieautoryzowany" });

      let driver = await storage.getDriver(driverId);
      if (!driver) return res.status(404).json({ error: "Kierowca nie znaleziony" });

      // Check if driver has active subscription (active or trial)
      const hasActiveSubscription = 
        (driver.subscriptionStatus === "active" && driver.subscriptionEndsAt && new Date(driver.subscriptionEndsAt) > new Date()) ||
        (driver.subscriptionStatus === "trial" && driver.trialEndsAt && new Date(driver.trialEndsAt) > new Date());
      
      if (!hasActiveSubscription) {
        return res.status(403).json({ 
          error: "Wymagana aktywna subskrypcja",
          subscriptionRequired: true,
          message: "Aby korzystać z systemu poleceń, musisz mieć aktywną subskrypcję."
        });
      }

      // Auto-generate referral code for existing drivers that don't have one
      if (!driver.referralCode) {
        const newCode = await storage.generateUniqueReferralCode();
        await db.update(drivers).set({ referralCode: newCode }).where(eq(drivers.id, driverId));
        driver = await storage.getDriver(driverId);
        if (!driver) return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }

      const displayCode = driver.taxiLicenseNumber || driver.referralCode;

      const driverReferrals = await storage.getReferralsByDriver(driverId);

      const enrichedReferrals = await Promise.all(driverReferrals.map(async (ref) => {
        let referredDriverName: string | undefined;
        let referredUserName: string | undefined;
        if (ref.referredDriverId) {
          const d = await storage.getDriver(ref.referredDriverId);
          referredDriverName = d?.name;
        }
        if (ref.referredUserId) {
          const u = await storage.getUser(ref.referredUserId);
          referredUserName = u ? `${u.firstName || ''} ${u.lastName || ''}`.trim() : undefined;
        }
        return { ...ref, referredDriverName, referredUserName };
      }));

      res.json({
        referralCode: displayCode,
        referralPoints: driver.referralPoints || 0,
        referredDriversCount: driver.referredDriversCount || 0,
        referredPassengersCount: driver.referredPassengersCount || 0,
        referrals: enrichedReferrals,
      });
    } catch (error) {
      res.status(500).json({ error: "Nie udało się pobrać danych poleceń" });
    }
  });

  const inviteSmsLimiter = new Map<string, number[]>();

  app.post("/api/driver/invite-passenger", async (req, res) => {
    try {
      const driverId = (req.session as any)?.driverId;
      if (!driverId) return res.status(401).json({ error: "Nieautoryzowany" });

      const now = Date.now();
      const driverHistory = inviteSmsLimiter.get(driverId) || [];
      const recentSms = driverHistory.filter(t => now - t < 3600000);
      if (recentSms.length >= 5) {
        return res.status(429).json({ error: "Limit SMS osiągnięty. Spróbuj za godzinę." });
      }

      const driver = await storage.getDriver(driverId);
      if (!driver) return res.status(404).json({ error: "Kierowca nie znaleziony" });

      const { phone } = req.body;
      if (!phone || typeof phone !== "string") {
        return res.status(400).json({ error: "Numer telefonu jest wymagany" });
      }

      const normalized = normalizePolishPhone(phone);
      if (!/^\+48\d{9}$/.test(normalized)) {
        return res.status(400).json({ error: "Nieprawidłowy numer telefonu" });
      }

      const displayCode = driver.taxiLicenseNumber || driver.referralCode || "";
      if (!displayCode) {
        return res.status(400).json({ error: "Brak kodu polecającego" });
      }

      const driverName = driver.firstName || driver.name || "Kierowca TaxiQ";
      const registerLink = `https://taxiq.com.pl/passenger?license=${encodeURIComponent(displayCode)}`;

      const twilioSid = process.env.TWILIO_ACCOUNT_SID;
      const twilioToken = process.env.TWILIO_AUTH_TOKEN;
      const twilioNumber = process.env.TWILIO_PHONE_NUMBER;
      if (!twilioSid || !twilioToken || !twilioNumber) {
        return res.status(500).json({ error: "Usługa SMS nie jest skonfigurowana" });
      }

      const client = Twilio(twilioSid, twilioToken);
      await client.messages.create({
        body: `${driverName} zaprasza Cię do TaxiQ! Zarejestruj się i zamawiaj taksówki wygodnie: ${registerLink}`,
        from: twilioNumber,
        to: normalized,
      });

      recentSms.push(now);
      inviteSmsLimiter.set(driverId, recentSms);

      console.log(`[INVITE_SMS] driver_id=${driverId} phone=${normalized} code=${displayCode}`);
      res.json({ success: true, message: "SMS wysłany pomyślnie" });
    } catch (error: any) {
      console.error("[INVITE_SMS_ERROR]", error?.message);
      res.status(500).json({ error: "Nie udało się wysłać SMS" });
    }
  });

  // Update driver bank account details
  app.patch("/api/driver/bank-account", async (req, res) => {
    try {
      const driverId = (req.session as any)?.driverId;
      if (!driverId) return res.status(401).json({ error: "Nieautoryzowany" });

      const { bankAccountNumber, bankAccountHolder } = req.body;
      if (!bankAccountNumber || !bankAccountHolder) {
        return res.status(400).json({ error: "Numer konta i właściciel są wymagane" });
      }

      // Validate Polish IBAN format (PL + 26 digits) or just 26 digits
      const cleanedNumber = bankAccountNumber.replace(/\s/g, '');
      const ibanRegex = /^(PL)?\d{26}$/;
      if (!ibanRegex.test(cleanedNumber)) {
        return res.status(400).json({ error: "Nieprawidłowy format numeru konta. Podaj 26 cyfr (IBAN PL)." });
      }

      const driver = await storage.updateDriverBankAccount(driverId, cleanedNumber, bankAccountHolder.trim());
      if (!driver) return res.status(404).json({ error: "Kierowca nie znaleziony" });

      res.json({ 
        bankAccountNumber: driver.bankAccountNumber,
        bankAccountHolder: driver.bankAccountHolder,
        message: "Dane konta bankowego zaktualizowane"
      });
    } catch (error) {
      res.status(500).json({ error: "Nie udało się zaktualizować danych konta" });
    }
  });

