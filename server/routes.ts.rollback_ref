  app.post("/auth/admin/set-pin", async (req, res) => {
    const { phone, pin } = req.body;
    if (!phone || !pin) return res.status(400).json({ error: "Numer telefonu i PIN są wymagane" });
    const verifiedUserId = (req.session as any).otpVerifiedUserId;
    if (!verifiedUserId) return res.status(403).json({ error: "Najpierw zweryfikuj kod OTP" });
    try {
      const result = await setPin(phone, pin, verifiedUserId, "admin");
      if (result.role !== "admin") return res.status(404).json({ error: "Nie znaleziono administratora" });
      delete (req.session as any).otpVerifiedUserId;
