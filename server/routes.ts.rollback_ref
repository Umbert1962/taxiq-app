        res.clearCookie('taxiq.sid.v2', {
          path: '/',
          secure: true,
          httpOnly: true,
          sameSite: 'none'
        });
        res.json({ success: true });
      });
    } catch (error) {
      res.status(500).json({ error: "Logout failed" });
    }
  });

  // ============ PASSENGER AUTH ============

  const OTP_MAX_VERIFY_ATTEMPTS = 3;

  function hashOtp(code: string): string {
    return createHash("sha256").update(code).digest("hex");
  }

  function maskPhone(phone: string): string {
    if (phone.length <= 6) return phone;
    return phone.slice(0, 4) + "****" + phone.slice(-2);
  }

  const otpRateLimit = new Map<string, { count: number; firstRequest: number }>();
  const OTP_RATE_LIMIT_MAX = 5;
  const OTP_RATE_LIMIT_WINDOW = 60 * 1000;

  function checkOtpRateLimit(phone: string): boolean {
    const now = Date.now();
    const entry = otpRateLimit.get(phone);
    if (!entry || now - entry.firstRequest > OTP_RATE_LIMIT_WINDOW) {
      otpRateLimit.set(phone, { count: 1, firstRequest: now });
      return true;
    }
    if (entry.count >= OTP_RATE_LIMIT_MAX) return false;
    entry.count++;
    return true;
  }

  app.post("/api/passengers/request-otp", async (req, res) => {
    try {
      const { phone_number } = req.body;
      if (!phone_number) {
        return res.status(400).json({ error: "Numer telefonu jest wymagany" });
      }

      const normalized = normalizePolishPhone(phone_number);

      if (!/^\+48\d{9}$/.test(normalized)) {
        return res.status(400).json({ error: "Nieprawidłowy format numeru telefonu. Użyj formatu +48XXXXXXXXX" });
      }

      if (!checkOtpRateLimit(normalized)) {
        return res.status(429).json({ error: "Zbyt wiele prób. Spróbuj ponownie za minutę." });
      }

      const otpCode = Math.floor(100000 + Math.random() * 900000).toString();
      const otpHash = hashOtp(otpCode);
      const otpExpiresAt = new Date(Date.now() + 5 * 60 * 1000);

      let user = await storage.getUserByPhone(normalized);
      if (user) {
        await db.update(users).set({ otpCode: otpHash, otpExpiresAt, otpAttempts: 0 }).where(eq(users.id, user.id));
      } else {
        user = await storage.createUser({
          username: normalized,
          phone: normalized,
        });
        await db.update(users).set({ otpCode: otpHash, otpExpiresAt, otpAttempts: 0 }).where(eq(users.id, user.id));
      }

      const twilioSid = process.env.TWILIO_ACCOUNT_SID;
      const twilioToken = process.env.TWILIO_AUTH_TOKEN;
      const twilioNumber = process.env.TWILIO_PHONE_NUMBER;

      if (!twilioSid || !twilioToken || !twilioNumber) {
        console.error(`[OTP] Twilio not configured. Cannot send SMS.`);
        return res.status(500).json({ error: "Usługa SMS nie jest skonfigurowana." });
      }

      try {
        const client = Twilio(twilioSid, twilioToken);
        const message = await client.messages.create({
          body: `Twój kod TaxiQ: ${otpCode}`,
          from: twilioNumber,
          to: normalized,
        });
        console.log(`[OTP] SMS sent to ${maskPhone(normalized)} (SID: ${message.sid})`);
      } catch (smsError: any) {
        console.error(`[OTP] SMS failed for ${maskPhone(normalized)}: ${smsError?.code || "unknown"}`);
        return res.status(500).json({ error: "Nie udało się wysłać SMS z kodem. Spróbuj ponownie." });
      }

      res.json({ success: true, message: "Kod OTP został wysłany" });
    } catch (error: any) {
      console.error("[OTP] Request error:", error?.message);
      res.status(500).json({ error: "Nie udało się wysłać kodu OTP" });
    }
  });

  app.post("/api/passengers/verify-otp", async (req, res) => {
    try {
      const { phone_number, otp_code } = req.body;
      if (!phone_number || !otp_code) {
        return res.status(400).json({ error: "Numer telefonu i kod OTP są wymagane" });
      }

      const normalized = normalizePolishPhone(phone_number);
      const user = await storage.getUserByPhone(normalized);

      if (!user) {
        return res.status(401).json({ error: "Nieprawidłowy numer telefonu" });
      }

      if (user.isBlocked) {
        return res.status(403).json({
          error: "Konto zablokowane",
          reason: user.blockedReason || "Twoje konto zostało zablokowane. Skontaktuj się z administratorem.",
          blocked: true
        });
      }

      if (!user.otpCode || !user.otpExpiresAt) {
        return res.status(401).json({ error: "Nie wysłano kodu OTP. Poproś o nowy kod." });
      }

      if (new Date() > new Date(user.otpExpiresAt)) {
        await db.update(users).set({ otpCode: null, otpExpiresAt: null, otpAttempts: 0 }).where(eq(users.id, user.id));
        return res.status(401).json({ error: "Kod OTP wygasł. Poproś o nowy kod." });
      }

      const currentAttempts = (user.otpAttempts ?? 0);
      if (currentAttempts >= OTP_MAX_VERIFY_ATTEMPTS) {
        await db.update(users).set({ otpCode: null, otpExpiresAt: null, otpAttempts: 0 }).where(eq(users.id, user.id));
        return res.status(401).json({ error: "Zbyt wiele nieudanych prób. Poproś o nowy kod." });
      }

      const inputHash = hashOtp(otp_code);
      if (user.otpCode !== inputHash) {
        await db.update(users).set({ otpAttempts: currentAttempts + 1 }).where(eq(users.id, user.id));
        const remaining = OTP_MAX_VERIFY_ATTEMPTS - (currentAttempts + 1);
        return res.status(401).json({ error: `Nieprawidłowy kod OTP. Pozostało prób: ${remaining}` });
      }

      await db.update(users).set({ otpCode: null, otpExpiresAt: null, otpAttempts: 0 }).where(eq(users.id, user.id));

      await storage.invalidatePassengerSessions(user.id);
      await storage.setUserOnline(user.id, true);

      req.session.passengerId = user.id;
      req.session.passengerName = `${user.firstName || ''} ${user.lastName || ''}`.trim() || user.username;
      req.session.passengerLastActivity = Date.now();

      req.session.save((err) => {
        if (err) {
          console.error("[OTP] Session save error");
          return res.status(500).json({ error: "Błąd sesji" });
        }
        console.log(`[OTP] Verified OK for ${maskPhone(normalized)}`);
        res.json({
          id: user.id,
          username: user.username,
          firstName: user.firstName,
          lastName: user.lastName,
          email: user.email,
          phone: user.phone,
          homeAddress: user.homeAddress,
          homeLat: user.homeLat,
          homeLng: user.homeLng,
        });
      });
    } catch (error: any) {
      console.error("[OTP] Verify error");
      res.status(500).json({ error: "Weryfikacja nie powiodła się" });
    }
  });
  
  // Get current passenger session
  app.get("/api/passengers/session", async (req, res) => {
    if (
      process.env.NODE_ENV === "development" &&
      !process.env.NEON_DATABASE_URL &&
      !process.env.DATABASE_URL
    ) {
      return res.json({
        id: "dev-user",
        username: "dev",
        firstName: "Dev",
        lastName: "User",
        email: "dev@localhost",
        phone: "",
        homeAddress: "",
        homeLat: null,
        homeLng: null,
        photoUrl: null,
        termsAcceptedAt: null,
        createdAt: new Date().toISOString(),
      });
    }
    console.log("[PWA DEBUG] Passenger session check:", {
      sessionID: req.sessionID?.slice(0, 8) + "...",
      passengerId: req.session.passengerId,
      hasCookie: !!req.headers.cookie,
      cookiePreview: req.headers.cookie?.slice(0, 50),
      userAgent: req.headers['user-agent']?.slice(0, 60)
    });
    try {
      if (!req.session.passengerId) {
        return res.status(401).json({ error: "Nie zalogowano" });
      }
      
      const user = await storage.getUser(req.session.passengerId);
      if (!user) {
        req.session.destroy(() => {});
        return res.status(401).json({ error: "Użytkownik nie znaleziony" });
      }
      
      res.json({
        id: user.id,
        username: user.username,
        firstName: user.firstName,
        lastName: user.lastName,
        email: user.email,
        phone: user.phone,
        homeAddress: user.homeAddress,
        homeLat: user.homeLat,
        homeLng: user.homeLng,
        photoUrl: user.photoUrl,
        termsAcceptedAt: user.termsAcceptedAt,
        termsVersion: user.termsVersion,
        createdAt: user.createdAt,
      });
    } catch (error) {
      res.status(500).json({ error: "Błąd sesji" });
    }
  });
  
  // Update passenger profile
  app.patch("/api/passengers/profile", async (req, res) => {
    try {
      if (!req.session.passengerId) {
        return res.status(401).json({ error: "Nie zalogowano" });
      }
      
      const { firstName, lastName, email, phone, homeAddress, homeLat, homeLng, termsAcceptedAt, termsVersion } = req.body;
      
      const updateData: any = {
        firstName,
        lastName,
        email,
        phone,
        homeAddress,
        homeLat,
        homeLng,
      };
      if (termsAcceptedAt) updateData.termsAcceptedAt = new Date(termsAcceptedAt);
      if (termsVersion) updateData.termsVersion = termsVersion;
      
      // Update user in database
      const updatedUser = await storage.updateUser(req.session.passengerId, updateData);
      
      if (!updatedUser) {
        return res.status(404).json({ error: "Użytkownik nie znaleziony" });
      }
      
      res.json({
        id: updatedUser.id,
        username: updatedUser.username,
        firstName: updatedUser.firstName,
        lastName: updatedUser.lastName,
        email: updatedUser.email,
        phone: updatedUser.phone,
        homeAddress: updatedUser.homeAddress,
        homeLat: updatedUser.homeLat,
        homeLng: updatedUser.homeLng,
        termsAcceptedAt: updatedUser.termsAcceptedAt,
        termsVersion: updatedUser.termsVersion,
      });
    } catch (error) {
      res.status(500).json({ error: "Aktualizacja profilu nie powiodła się" });
    }
  });
  
  // Upload passenger photo - Uses Object Storage for permanent cloud storage
  app.post("/api/passengers/photo", upload.single("photo"), async (req, res) => {
    try {
      if (!req.session.passengerId) {
        return res.status(401).json({ error: "Nie zalogowano" });
      }
      
      if (!req.file) {
        return res.status(400).json({ error: "Brak pliku zdjęcia" });
      }
      
      // Get presigned URL from Object Storage
      const uploadUrl = await objectStorageService.getObjectEntityUploadURL();
      const objectPath = objectStorageService.normalizeObjectEntityPath(uploadUrl);
      
      // Read the uploaded file and send to Object Storage
      const fileBuffer = fs.readFileSync(req.file.path);
      const uploadResponse = await fetch(uploadUrl, {
        method: "PUT",
        body: fileBuffer,
        headers: {
          "Content-Type": req.file.mimetype,
        },
      });
      
      if (!uploadResponse.ok) {
        throw new Error("Failed to upload to Object Storage");
      }
      
      // Delete local temp file
      fs.unlinkSync(req.file.path);
      
      // Store the Object Storage path
      const photoUrl = objectPath;
      await db.update(users).set({ photoUrl }).where(eq(users.id, req.session.passengerId));
      
      res.json({ photoUrl });
    } catch (error) {
      console.error("Error uploading passenger photo:", error);
      res.status(500).json({ error: "Błąd podczas uploadu zdjęcia" });
    }
  });
  
  // Accept terms of service
  app.post("/api/passengers/accept-terms", async (req, res) => {
    try {
      if (!req.session.passengerId) {
        return res.status(401).json({ error: "Nie zalogowano" });
      }
      
      await db.update(users).set({ termsAcceptedAt: new Date() }).where(eq(users.id, req.session.passengerId));
      
      res.json({ success: true, termsAcceptedAt: new Date() });
    } catch (error) {
      console.error("Error accepting terms:", error);
      res.status(500).json({ error: "Błąd podczas akceptacji regulaminu" });
    }
  });
  
  // Logout passenger
  app.post("/api/passengers/logout", async (req, res) => {
    // Set user offline before destroying session
    if (req.session.passengerId) {
      await storage.setUserOnline(req.session.passengerId, false);
    }
    req.session.destroy((err) => {
      if (err) {
        return res.status(500).json({ error: "Wylogowanie nie powiodło się" });
      }
      res.clearCookie('taxiq.sid.v2', {
        path: '/',
        secure: true,
        httpOnly: true,
        sameSite: 'none'
      });
      res.json({ success: true });
    });
  });

  // ============ DRIVER ENDPOINTS ============
  
  // Get all online drivers (for nearby taxis map)
  app.get("/api/drivers/online", async (_req, res) => {
    try {
      const drivers = await storage.getOnlineDrivers();
      res.json(drivers.map(d => ({
        id: d.id,
        name: d.name,
        vehiclePlate: d.vehiclePlate,
        vehicleModel: d.vehicleModel,
        vehicleColor: d.vehicleColor,
        rating: d.rating,
        currentLat: d.currentLat ? parseFloat(d.currentLat) : null,
        currentLng: d.currentLng ? parseFloat(d.currentLng) : null,
      })));
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch online drivers" });
    }
  });

  // Get nearby online drivers with full pricing info for passenger view
  // Optional query params: pickupLat, pickupLng, destLat, destLng, passengerLat, passengerLng
  app.get("/api/drivers/nearby", async (req, res) => {
    try {
      const ua = req.headers['user-agent'] || '(none)';
      const platform = /Android/i.test(ua) ? 'ANDROID' : /iPhone|iPad/i.test(ua) ? 'IOS' : 'WEB';
      console.log(`[DIAG_NEARBY] === /api/drivers/nearby request ===`);
      console.log(`[DIAG_NEARBY] Platform: ${platform}, UA: ${ua.substring(0, 80)}`);
      console.log(`[DIAG_NEARBY] Query params:`, JSON.stringify(req.query));
      console.log(`[DIAG_NEARBY] Session exists: ${!!req.session}, SessionID: ${req.sessionID || '(none)'}`);
      console.log(`[DIAG_NEARBY] Cookie header: ${req.headers.cookie ? req.headers.cookie.substring(0, 100) : '(none)'}`);
      
      const drivers = await storage.getOnlineDrivers();
      console.log(`[DIAG_NEARBY] getOnlineDrivers() returned ${drivers.length} drivers`);
      if (drivers.length > 0) {
        console.log(`[DIAG_NEARBY] Online drivers:`, JSON.stringify(drivers.map(d => ({
          id: d.id.substring(0, 8),
          name: d.name,
          isOnline: d.isOnline,
          lat: d.currentLat,
          lng: d.currentLng,
          lastLocUpdate: d.lastLocationUpdate,
          approved: (d as any).approved,
          active: (d as any).active,
        }))));
      }
      
      // Parse route coordinates if provided
      const pickupLat = req.query.pickupLat ? parseFloat(req.query.pickupLat as string) : null;
      const pickupLng = req.query.pickupLng ? parseFloat(req.query.pickupLng as string) : null;
      const destLat = req.query.destLat ? parseFloat(req.query.destLat as string) : null;
      const destLng = req.query.destLng ? parseFloat(req.query.destLng as string) : null;
      const passengerLat = req.query.passengerLat ? parseFloat(req.query.passengerLat as string) : null;
      const passengerLng = req.query.passengerLng ? parseFloat(req.query.passengerLng as string) : null;
      
      // Parse stops (przystanki) for route calculation
      let stops: Array<{ lat: number; lng: number; type?: string }> = [];
      if (req.query.stops) {
        try {
          stops = JSON.parse(req.query.stops as string);
        } catch (e) {
          console.error("Failed to parse stops:", e);
        }
      }
      
      // Haversine distance calculation
      const calculateDistance = haversineDistance;
      
      // Helper to check if today is a holiday or Sunday
      const isHolidayOrSunday = () => {
        const now = new Date();
        const day = now.getDay();
        if (day === 0) return true; // Sunday
        
        // Polish holidays (fixed dates)
        const month = now.getMonth() + 1;
        const date = now.getDate();
        const holidays = [
          { m: 1, d: 1 },   // Nowy Rok
          { m: 1, d: 6 },   // Trzech Króli
          { m: 5, d: 1 },   // Święto Pracy
          { m: 5, d: 3 },   // Święto Konstytucji
          { m: 8, d: 15 },  // Wniebowzięcie NMP
          { m: 11, d: 1 },  // Wszystkich Świętych
          { m: 11, d: 11 }, // Niepodległości
          { m: 12, d: 25 }, // Boże Narodzenie
          { m: 12, d: 26 }, // Drugi dzień BN
        ];
        return holidays.some(h => h.m === month && h.d === date);
      };

      const isNightTime = () => {
        const hour = new Date().getHours();
        return hour >= 22 || hour < 6;
      };

      const isHoliday = isHolidayOrSunday();
      const isNight = isNightTime();
      
      // Calculate route distance and duration using Google Directions API for accurate pricing
      // Including all stops (waypoints and extra destinations)
      let routeDistanceKm: number | null = null;
      let routeDurationMinutes: number | null = null; // Time for calculating slow traffic fee
      if (pickupLat && pickupLng && destLat && destLng) {
        try {
          const googleApiKey = process.env.GOOGLE_API_KEY;
          if (googleApiKey) {
            // Build route with all stops
            // waypoints go between pickup and main destination
            // extra_destinations go after main destination (so main dest becomes a waypoint)
            const waypointStops = stops.filter(s => s.type === 'waypoint');
            const extraDestStops = stops.filter(s => s.type === 'extra_destination');
            
            let finalDestLat = destLat;
            let finalDestLng = destLng;
            let allWaypoints: Array<{ lat: number; lng: number }> = [];
            
            // Add waypoints (stops between pickup and destination)
            allWaypoints.push(...waypointStops);
            
            // If there are extra destinations, main destination becomes a waypoint
            // and last extra destination becomes final destination
            if (extraDestStops.length > 0) {
              allWaypoints.push({ lat: destLat, lng: destLng }); // Main dest becomes waypoint
              // Add all extra destinations except last as waypoints
              allWaypoints.push(...extraDestStops.slice(0, -1));
              // Last extra destination is final
              const lastExtra = extraDestStops[extraDestStops.length - 1];
              finalDestLat = lastExtra.lat;
              finalDestLng = lastExtra.lng;
            }
            
            // Build Google Directions URL with waypoints
            let directionsUrl = `https://maps.googleapis.com/maps/api/directions/json?origin=${pickupLat},${pickupLng}&destination=${finalDestLat},${finalDestLng}&key=${googleApiKey}`;
            
            if (allWaypoints.length > 0) {
              const waypointsParam = allWaypoints.map(w => `${w.lat},${w.lng}`).join('|');
              directionsUrl += `&waypoints=${encodeURIComponent(waypointsParam)}`;
            }
            
            const response = await fetch(directionsUrl);
            const data = await response.json();
            if (data.routes && data.routes[0] && data.routes[0].legs) {
              // Sum all legs distances (each waypoint creates a new leg)
              routeDistanceKm = data.routes[0].legs.reduce((total: number, leg: any) => {
                return total + (leg.distance?.value || 0);
              }, 0) / 1000; // Convert meters to km
              
              // Sum all legs duration (in seconds)
              routeDurationMinutes = data.routes[0].legs.reduce((total: number, leg: any) => {
                return total + (leg.duration?.value || 0);
              }, 0) / 60; // Convert seconds to minutes
            }
          }
        } catch (error) {
          console.error("Failed to get route from Google Directions API:", error);
        }
        
        // Fallback to straight line if API fails
        if (routeDistanceKm === null) {
          let straightDistance = calculateDistance(pickupLat, pickupLng, destLat, destLng);
          // Add distances for stops
          if (stops.length > 0) {
            let prevLat = pickupLat;
            let prevLng = pickupLng;
            for (const stop of stops) {
              straightDistance += calculateDistance(prevLat, prevLng, stop.lat, stop.lng);
              prevLat = stop.lat;
              prevLng = stop.lng;
            }
            straightDistance += calculateDistance(prevLat, prevLng, destLat, destLng);
          }
          routeDistanceKm = straightDistance * 1.3;
          // Estimate time based on average speed ~40 km/h in city
          routeDurationMinutes = (routeDistanceKm / 40) * 60;
        }
      }
      
      // Estimate slow traffic time (traffic lights, jams, slow driving <15 km/h)
      // Rush hours (13:00-18:30): 60% of travel time is slow
      // Other hours: 25% of travel time is slow
      let slowTrafficMinutes = 0;
      if (routeDurationMinutes !== null) {
        const now = new Date();
        const hour = now.getHours();
        const minutes = now.getMinutes();
        const timeDecimal = hour + minutes / 60; // e.g. 18:30 = 18.5
        const isRushHour = timeDecimal >= 13 && timeDecimal < 18.5;
        const slowTrafficPercent = isRushHour ? 0.60 : 0.25;
        slowTrafficMinutes = routeDurationMinutes * slowTrafficPercent;
      }

      // Parse ride type for pricing (cito, scheduled, normal)
      const rideType = req.query.rideType as string || 'normal';
      const citoPrice = req.query.citoPrice ? parseInt(req.query.citoPrice as string) : null; // Passenger's CITO price in grosze
      
      const driversWithDistance = drivers.map(d => {
        let distanceToPickup: number | null = null;
        let estimatedArrivalMinutes: number | null = null;
        
        if (pickupLat && pickupLng && d.currentLat && d.currentLng) {
          distanceToPickup = calculateDistance(
            parseFloat(String(d.currentLat)), 
            parseFloat(String(d.currentLng)), 
            pickupLat, 
            pickupLng
          );
          estimatedArrivalMinutes = Math.round(distanceToPickup * 2);
        }
        
        return { driver: d, distanceToPickup, estimatedArrivalMinutes };
      });
      
      const nearbyFiltered = driversWithDistance
        .filter(d => {
          if (d.distanceToPickup === null) return false;
          return d.distanceToPickup <= 30;
        })
        .sort((a, b) => {
          if (a.distanceToPickup !== null && b.distanceToPickup !== null) {
            return a.distanceToPickup - b.distanceToPickup;
          }
          return 0;
        })
        .slice(0, 10);
      
      console.log(`[DIAG_NEARBY] driversWithDistance count: ${driversWithDistance.length}`);
      console.log(`[DIAG_NEARBY] After 30km filter: ${nearbyFiltered.length} drivers`);
      if (driversWithDistance.length > 0 && nearbyFiltered.length === 0) {
        console.log(`[DIAG_NEARBY] All drivers filtered out! Reasons:`, JSON.stringify(driversWithDistance.map(d => ({
          id: d.driver.id.substring(0, 8),
          name: d.driver.name,
          distanceToPickup: d.distanceToPickup,
          hasLat: d.distanceToPickup !== null,
          over30km: d.distanceToPickup !== null ? d.distanceToPickup > 30 : 'N/A',
        }))));
      }
      
      const selectedDrivers = nearbyFiltered.length === 0
        ? driversWithDistance.slice(0, 10)
        : nearbyFiltered;
      
      if (nearbyFiltered.length === 0) {
        console.log(`[DIAG_NEARBY] FALLBACK: Returning ${selectedDrivers.length} online drivers (total online: ${drivers.length})`);
      } else {
        console.log(`[DIAG_NEARBY] Found ${nearbyFiltered.length} drivers within 30km (total online: ${drivers.length})`);
      }
      
      const driversWithPrices = selectedDrivers.map(({ driver: d, distanceToPickup, estimatedArrivalMinutes }) => {
        let currentRateCity = d.rateDayCity || 350;
        let currentRateSuburb = d.rateDaySuburb || 450;
        let rateType: "day" | "night" | "holiday" = "day";

        if (isHoliday) {
          currentRateCity = d.rateHolidayCity || d.rateNightCity || 450;
          currentRateSuburb = d.rateHolidaySuburb || d.rateNightSuburb || 550;
          rateType = "holiday";
        } else if (isNight) {
          currentRateCity = d.rateNightCity || 450;
          currentRateSuburb = d.rateNightSuburb || 550;
          rateType = "night";
        }
        
        let estimatedPrice: number | null = null;
        let pickupFee = 0;
        
        if (routeDistanceKm !== null) {
          const suburbRadiusKm = d.suburbRadiusKm || 15;
          const rateWaitingPerMinute = d.rateWaitingPerMinute || 100;
          let baseFare = d.baseFare || 900;
          
          if (rideType === 'scheduled') {
            baseFare = baseFare * 2;
          }
          
          if (rideType === 'cito' && citoPrice) {
            estimatedPrice = Math.round(citoPrice / 100);
          } else {
            const ratePerKm = routeDistanceKm <= suburbRadiusKm ? currentRateCity : currentRateSuburb;
            let priceGrosze = baseFare + (routeDistanceKm * ratePerKm);
            
            const slowTrafficFee = Math.round(slowTrafficMinutes * rateWaitingPerMinute);
            priceGrosze += slowTrafficFee;
            
            if (rideType !== 'scheduled' && distanceToPickup !== null && distanceToPickup > 5) {
              const extraKm = distanceToPickup - 5;
              pickupFee = Math.round(extraKm * rateWaitingPerMinute);
              priceGrosze += pickupFee;
            }
            
            const discountPercent = d.discountPercent || 0;
            const discountedPrice = priceGrosze * (1 - discountPercent / 100);
            estimatedPrice = Math.round(discountedPrice / 100);
          }
          
          if (estimatedPrice !== null && estimatedPrice < 20) {
            estimatedPrice = 20;
          }
        }

        return {
          id: d.id,
          name: d.name,
          photoUrl: d.photoUrl,
          vehiclePlate: d.vehiclePlate,
          vehicleModel: d.vehicleModel,
          vehicleColor: d.vehicleColor,
          rating: d.rating,
          languages: d.languages || [],
          currentRateCity,
          currentRateSuburb,
          rateType,
          distanceToPickup,
          estimatedArrivalMinutes,
          pickupFee: Math.round(pickupFee / 100),
          estimatedPrice,
          rateDayCity: d.rateDayCity || 350,
          rateDaySuburb: d.rateDaySuburb || 450,
          rateNightCity: d.rateNightCity || 450,
          rateNightSuburb: d.rateNightSuburb || 550,
          rateHolidayCity: d.rateHolidayCity || d.rateNightCity || 450,
          rateHolidaySuburb: d.rateHolidaySuburb || d.rateNightSuburb || 550,
          rateCito: d.rateCito || 700,
          rateWaitingPerMinute: d.rateWaitingPerMinute || 100,
          suburbRadiusKm: d.suburbRadiusKm || 15,
          discountPercent: d.discountPercent || 0,
        };
      });
      
      console.log(`[DIAG_NEARBY] Response (${platform}):`, JSON.stringify(driversWithPrices.map(d => ({ id: d.id.substring(0, 8), name: d.name, distanceToPickup: d.distanceToPickup }))));
      res.json(driversWithPrices);
    } catch (error) {
      console.error(`[DIAG_NEARBY] ERROR:`, error);
      res.status(500).json({ error: "Failed to fetch nearby drivers" });
    }
  });

  app.get("/api/drivers/:id", async (req, res) => {
    try {
      const driver = await storage.getDriver(req.params.id);
      if (!driver) {
        return res.status(404).json({ error: "Driver not found" });
      }
      res.json({
        id: driver.id,
        name: driver.name,
        email: driver.email,
        phone: driver.phone,
        vehiclePlate: driver.vehiclePlate,
        vehicleModel: driver.vehicleModel,
        vehicleColor: driver.vehicleColor,
        languages: driver.languages || [],
        rating: driver.rating,
        totalRides: driver.totalRides,
        totalEarnings: driver.totalEarnings,
        isOnline: driver.isOnline,
        photoUrl: driver.photoUrl,
        photoVerifiedAt: driver.photoVerifiedAt,
        taxiLicenseNumber: driver.taxiLicenseNumber,
        profileCompleted: isDriverProfileComplete(driver),
        termsAcceptedAt: driver.termsAcceptedAt,
        emailVerifiedAt: driver.emailVerifiedAt,
        phoneVerifiedAt: driver.phoneVerifiedAt,
      });
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch driver" });
    }
  });

  app.patch("/api/drivers/:id/status", async (req, res) => {
    try {
      const { isOnline, lat, lng } = req.body;
      
      if (isOnline) {
        const driverCheck = await storage.getDriver(req.params.id);
        if (!driverCheck) {
          return res.status(404).json({ error: "Driver not found" });
        }
        if (driverCheck.verificationStatus !== "approved_auto" || !driverCheck.cityDriverId || !driverCheck.verificationCheckedAt) {
          console.log(`[GATE] Driver ${req.params.id} BLOCKED from going online: status=${driverCheck.verificationStatus}, cityDriverId=${driverCheck.cityDriverId || 'NULL'}, verificationCheckedAt=${driverCheck.verificationCheckedAt || 'NULL'}`);
          
          let errorMsg = "Twój identyfikator kierowcy nie został jeszcze zweryfikowany automatycznie. Prześlij skan identyfikatora i poczekaj na weryfikację miejską.";
          if (driverCheck.verificationStatus === "suspended_medical") {
            errorMsg = "Twoje badania lekarskie lub psychologiczne są nieważne. Zaktualizuj je w urzędzie, aby wrócić online.";
          }
          
          return res.status(403).json({
            error: errorMsg,
            code: "VERIFICATION_REQUIRED",
            verificationStatus: driverCheck.verificationStatus,
          });
        }
        if (!isDriverProfileComplete(driverCheck)) {
          const missing: string[] = [];
          if (!driverCheck.firstName) missing.push("imię");
          if (!driverCheck.lastName) missing.push("nazwisko");
          if (!driverCheck.phone) missing.push("numer telefonu");
          if (!driverCheck.vehiclePlate) missing.push("numer rejestracyjny");
          if (!driverCheck.vehicleModel) missing.push("model pojazdu");
          if (!driverCheck.vehicleColor) missing.push("kolor pojazdu");
          if (!driverCheck.taxiLicenseNumber) missing.push("numer licencji taxi");
          if (!Array.isArray(driverCheck.languages) || driverCheck.languages.length === 0) missing.push("języki komunikacji");
          if (!driverCheck.photoVerifiedAt) missing.push("weryfikacja zdjęcia");
          if (!driverCheck.phoneVerifiedAt) missing.push("weryfikacja telefonu");
          if (!driverCheck.termsAcceptedAt) missing.push("akceptacja regulaminu");
          return res.status(400).json({ 
            error: `Uzupełnij dane przed przejściem online: ${missing.join(", ")}.` 
          });
        }
      }
      
      const driver = await storage.updateDriverOnlineStatus(req.params.id, isOnline);
      if (!driver) {
        return res.status(404).json({ error: "Driver not found" });
      }
      
      if (isOnline && typeof lat === 'number' && typeof lng === 'number') {
        await storage.updateDriverGpsLocation(req.params.id, lat, lng);
        console.log(`[GPS] Driver ${req.params.id.substring(0, 8)} went online with GPS: ${lat}, ${lng}`);
      }
      
      res.json(driver);
    } catch (error) {
      res.status(500).json({ error: "Failed to update status" });
    }
  });
  
  // Update driver location (GPS tracking)
  app.patch("/api/drivers/:id/location", async (req, res) => {
    try {
      const { lat, lng } = req.body;
      if (typeof lat !== 'number' || typeof lng !== 'number') {
        return res.status(400).json({ error: "Invalid coordinates" });
      }
      const driver = await storage.updateDriverGpsLocation(req.params.id, lat, lng);
      if (!driver) {
        return res.status(404).json({ error: "Driver not found" });
      }
      res.json({ success: true });
    } catch (error) {
      res.status(500).json({ error: "Failed to update location" });
    }
  });

  app.get("/api/drivers/:id/rides", async (req, res) => {
    try {
      const rides = await storage.getDriverRides(req.params.id);
      res.json(rides);
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch driver rides" });
    }
  });

  app.get("/api/drivers/:id/stats", async (req, res) => {
    try {
      const driver = await storage.getDriver(req.params.id);
      if (!driver) {
        return res.status(404).json({ error: "Driver not found" });
      }
      
      const driverRides = await storage.getDriverRides(req.params.id);
      const completedRides = driverRides.filter(r => r.status === "completed");
      const todayRides = completedRides.filter(r => {
        if (!r.completedAt) return false;
        const today = new Date();
        const rideDate = new Date(r.completedAt);
        return rideDate.toDateString() === today.toDateString();
      });
      
      const todayEarnings = todayRides.reduce((sum, r) => sum + (r.finalPrice || r.estimatedPrice || 0), 0);
      
      res.json({
        totalRides: driver.totalRides || 0,
        totalEarnings: driver.totalEarnings || 0,
        rating: driver.rating || "5.00",
        todayRides: todayRides.length,
        todayEarnings
      });
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch stats" });
    }
  });

