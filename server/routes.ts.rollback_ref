  app.get("/api/admin/ride-status-log/:rideId", requireAdmin, async (req, res) => {
    try {
      const logs = await db.select().from(rideStatusLog)
        .where(eq(rideStatusLog.rideId, req.params.rideId))
        .orderBy(desc(rideStatusLog.timestamp));
      res.json(logs);
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch status log" });
    }
  });

  // Archiwum niewykonanych zamówień telefonicznych
  app.get("/api/admin/phone-orders/expired", requireAdmin, async (req, res) => {
    try {
      const allRides = await storage.getAllRides();
      
      // Znajdź anulowane zamówienia telefoniczne
      const expiredOrders = allRides.filter(r => 
        r.orderSource === "phone" && 
        r.status === "cancelled" &&
        r.cancelReason?.includes("Wygasło")
      );
      
      // Posortuj od najnowszych
      expiredOrders.sort((a, b) => {
        const dateA = a.createdAt ? new Date(a.createdAt).getTime() : 0;
        const dateB = b.createdAt ? new Date(b.createdAt).getTime() : 0;
        return dateB - dateA;
      });
      
      res.json(expiredOrders);
    } catch (error) {
      res.status(500).json({ error: "Nie udało się pobrać archiwum zamówień" });
    }
  });
  
  // Get dashboard stats
  app.get("/api/admin/stats", requireAdmin, async (req, res) => {
    try {
      const users = await storage.getAllUsers();
      const drivers = await storage.getAllDrivers();
      const rides = await storage.getAllRides();
      const companies = await storage.getAllCompanies();
      
      const onlineUsers = users.filter(u => u.isOnline).length;
      const onlineDrivers = drivers.filter(d => d.isOnline).length;
      const completedRides = rides.filter(r => r.status === "completed").length;
      const pendingRides = rides.filter(r => r.status === "pending").length;
      const totalRevenue = rides
        .filter(r => r.status === "completed" && r.finalPrice)
        .reduce((sum, r) => sum + (r.finalPrice || 0), 0);
      
      res.json({
        totalUsers: users.length,
