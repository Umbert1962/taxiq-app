  // Subscription endpoints
  app.get("/api/drivers/:id/subscription", async (req, res) => {
    try {
      const driver = await storage.getDriver(req.params.id);
      if (!driver) {
        return res.status(404).json({ error: "Driver not found" });
      }
      
      // Get assigned plan (if admin assigned one)
      let assignedPlan = null;
      if (driver.assignedPlanId) {
        const [plan] = await db.select().from(subscriptionPlans)
          .where(eq(subscriptionPlans.id, driver.assignedPlanId));
        assignedPlan = plan || null;
      }
      
      const now = new Date();
      let daysRemaining = 0;
      let isActive = true;
      
      if (driver.subscriptionStatus === "trial" && driver.trialEndsAt) {
        daysRemaining = Math.max(0, Math.ceil((new Date(driver.trialEndsAt).getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
        isActive = daysRemaining > 0;
      } else if (driver.subscriptionStatus === "active" && driver.subscriptionEndsAt) {
        daysRemaining = Math.max(0, Math.ceil((new Date(driver.subscriptionEndsAt).getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
        isActive = daysRemaining > 0;
      } else if (driver.subscriptionStatus === "suspended") {
        daysRemaining = driver.remainingDays || 0;
        isActive = false;
      } else if (driver.subscriptionStatus === "grace") {
        isActive = true;
      } else {
        isActive = false;
      }
      
      res.json({
        status: driver.subscriptionStatus,
        trialEndsAt: driver.trialEndsAt,
        subscriptionEndsAt: driver.subscriptionEndsAt,
        suspendedAt: driver.suspendedAt,
        suspendedUntil: driver.suspendedUntil,
        remainingDays: daysRemaining,
        isActive,
        totalEarnings: driver.totalEarnings || 0,
        subscriptionDiscount: driver.subscriptionDiscount || 0,
        assignedPlan,
        assignedPlanId: driver.assignedPlanId,
        priceToPay: assignedPlan ? assignedPlan.price : null,
      });
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch subscription info" });
    }
  });

  app.post("/api/drivers/:id/subscription/suspend", async (req, res) => {
    try {
      const { returnDate } = req.body;
      if (!returnDate) {
        return res.status(400).json({ error: "Return date is required" });
      }
      
      const parsedDate = new Date(returnDate);
      const now = new Date();
      const minDate = new Date(now.getTime() + 7 * 24 * 60 * 60 * 1000); // Min 7 days
      
      if (parsedDate < minDate) {
        return res.status(400).json({ error: "Minimum suspension period is 7 days" });
      }
      
      const driver = await storage.suspendDriverSubscription(req.params.id, parsedDate);
      if (!driver) {
        return res.status(404).json({ error: "Driver not found" });
      }
      
      res.json({ message: "Subscription suspended", driver });
    } catch (error) {
      res.status(500).json({ error: "Failed to suspend subscription" });
    }
  });

  app.post("/api/drivers/:id/subscription/resume", async (req, res) => {
    try {
      const driver = await storage.resumeDriverSubscription(req.params.id);
      if (!driver) {
        return res.status(404).json({ error: "Driver not found or not suspended" });
      }
      
      res.json({ message: "Subscription resumed", driver });
    } catch (error) {
      res.status(500).json({ error: "Failed to resume subscription" });
    }
  });

  // ============ RIDE ENDPOINTS ============
  app.get("/api/rides", async (req, res) => {
