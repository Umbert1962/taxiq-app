  // Get all rides
  app.get("/api/admin/rides", requireAdmin, async (req, res) => {
    try {
      const ridesData = await storage.getAllRidesWithDrivers();
      const allUsers = await storage.getAllUsers();
      const usersMap = new Map(allUsers.map(u => [u.id, u]));
      
      // Map rides to include passenger info and correct field names
      const mappedRides = ridesData.map(ride => {
        const passenger = ride.passengerId ? usersMap.get(ride.passengerId) : null;
        return {
          ...ride,
          passengerName: passenger ? `${passenger.firstName} ${passenger.lastName}` : "Nieznany",
          passengerLastName: passenger?.lastName || "",
          passengerPhone: passenger?.phone || ride.callerPhone || "",
          passengerEmail: passenger?.email || "",
          pickup: ride.pickupLocation,
        };
      });
      
      res.json(mappedRides);
    } catch (error) {
      res.status(500).json({ error: "Nie udało się pobrać przejazdów" });
