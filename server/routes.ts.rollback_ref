      if (!passengerId) return res.status(401).json({ error: "Nie zalogowano" });
      const favorites = await storage.getFavoriteDrivers(passengerId);
      const driverIds = favorites.map(f => f.driverId);
      const driverDetails = await Promise.all(
        driverIds.map(async (id) => {
          const driver = await storage.getDriver(id);
          if (!driver) return null;
          return {
            id: driver.id,
            firstName: driver.firstName,
            lastName: driver.lastName,
            photoUrl: driver.photoUrl,
            rating: driver.rating,
            isOnline: driver.isOnline,
          };
        })
      );
      res.json(driverDetails.filter(Boolean));
    } catch (error: any) {
      console.error("Error fetching favorite drivers:", error);
      res.status(500).json({ error: "Błąd serwera" });
    }
  });

