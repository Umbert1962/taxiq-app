  app.post("/api/business/company/:id/employees", requireBusinessAuth, requireCompanyAccess, async (req, res) => {
    try {
      const parsed = insertEmployeeSchema.safeParse({
        ...req.body,
        companyId: req.params.id
      });
      if (!parsed.success) {
        return res.status(400).json({ error: "Invalid employee data" });
      }
      
      const existing = await storage.getEmployeeByEmail(parsed.data.email);
      if (existing) {
        return res.status(409).json({ error: "Email already in use" });
      }
      
      const hashedPassword = await hashPassword(parsed.data.password);
      const employee = await storage.createEmployee({
        ...parsed.data,
        password: hashedPassword
      });
      res.status(201).json({
        id: employee.id,
        name: employee.name,
        email: employee.email,
        phone: employee.phone,
        role: employee.role
      });
