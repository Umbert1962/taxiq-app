const tmpDir = os.tmpdir();

const loginAttempts = new Map<string, { count: number; firstAttempt: number }>();
const RATE_LIMIT_MAX = 5;
const RATE_LIMIT_WINDOW_MS = 5 * 60 * 1000;

function checkLoginRateLimit(ip: string): boolean {
  const now = Date.now();
  const record = loginAttempts.get(ip);
  if (!record || now - record.firstAttempt > RATE_LIMIT_WINDOW_MS) {
    return true;
  }
  return record.count < RATE_LIMIT_MAX;
}

function recordFailedAttempt(ip: string): void {
  const now = Date.now();
  const record = loginAttempts.get(ip);
  if (!record || now - record.firstAttempt > RATE_LIMIT_WINDOW_MS) {
    loginAttempts.set(ip, { count: 1, firstAttempt: now });
  } else {
    record.count++;
  }
}

function resetLoginAttempts(ip: string): void {
  loginAttempts.delete(ip);
}

setInterval(() => {
  const now = Date.now();
  for (const [ip, record] of loginAttempts.entries()) {
    if (now - record.firstAttempt > RATE_LIMIT_WINDOW_MS) {
      loginAttempts.delete(ip);
    }
  }
}, 60 * 1000);

setInterval(async () => {
  try {
    const now = new Date();
    const expiredRides = await db.select({
      id: rides.id, status: rides.status, orderSource: rides.orderSource,
      searchStartedAt: rides.searchStartedAt, pickupLat: rides.pickupLat, pickupLng: rides.pickupLng,
      pickupLocation: rides.pickupLocation, destination: rides.destination,
      estimatedPrice: rides.estimatedPrice, citoPrice: rides.citoPrice
    })
      .from(rides)
      .where(
        and(
          eq(rides.status, "pending"),
          isNotNull(rides.offerExpiresAt),
          lt(rides.offerExpiresAt, now)
        )
      );

    for (const ride of expiredRides) {
      if (ride.orderSource === "phone") continue;

      if (!ride.searchStartedAt) {
        await db.update(rides)
          .set({ searchStartedAt: now })
          .where(eq(rides.id, ride.id));
      }
      const searchStart = ride.searchStartedAt ? new Date(ride.searchStartedAt).getTime() : now.getTime();
      const elapsedSeconds = (now.getTime() - searchStart) / 1000;

      if (elapsedSeconds > MAX_SEARCH_DURATION_SECONDS) {
        await db.update(rides)
          .set({ status: "no_driver_found", offerExpiresAt: null })
          .where(eq(rides.id, ride.id));
        rideNotifiedDrivers.delete(ride.id);
        console.log(`[OFFER_CLEANUP] ride_id=${ride.id} action=no_driver_found elapsed=${Math.round(elapsedSeconds)}s`);
        continue;
      }

      await db.update(rides)
        .set({ status: "pending", offerExpiresAt: null })
        .where(eq(rides.id, ride.id));
      rideNotifiedDrivers.delete(ride.id);
      console.log(`[OFFER_CLEANUP] ride_id=${ride.id} action=retry_search elapsed=${Math.round(elapsedSeconds)}s`);

      if (ride.pickupLat && ride.pickupLng) {
        const pLat = parseFloat(ride.pickupLat);
        const pLng = parseFloat(ride.pickupLng);
        if (!isNaN(pLat) && !isNaN(pLng)) {
          searchAndNotifyDrivers(
            ride.id, pLat, pLng,
            ride.pickupLocation || "Nieznany adres",
            ride.destination || "Nieznany cel",
            ride.estimatedPrice || ride.citoPrice,
            ride.orderSource || undefined
          ).catch(err => console.error(`[OFFER_CLEANUP_RETRY_ERROR] ride_id=${ride.id} error=${err.message}`));
        }
      }
    }
  } catch (err: any) {
    console.error(`[OFFER_CLEANUP_ERROR] error=${err.message}`);
  }
}, 30 * 1000);

const DAILY_RECHECK_INTERVAL_MS = 24 * 60 * 60 * 1000;
setInterval(async () => {
  try {
    console.log("[RECHECK] Starting daily verification recheck...");
    const allDrivers = await db.select({
      id: drivers.id,
      verificationStatus: drivers.verificationStatus,
      cityVerificationUrl: drivers.cityVerificationUrl,
    }).from(drivers).where(
      sql`${drivers.verificationStatus} IN ('approved_auto', 'VERIFIED') AND ${drivers.cityVerificationUrl} IS NOT NULL`
    );

    if (allDrivers.length === 0) {
      console.log("[RECHECK] No drivers to recheck");
      return;
    }

    const { recheckDriverVerification } = require("./services/driverVerification");
    let checked = 0;
    let suspended = 0;
    for (const d of allDrivers) {
      const newStatus = await recheckDriverVerification(d.id, d.cityVerificationUrl!);
      checked++;
      if (newStatus === "suspended_auto") suspended++;
      await new Promise(r => setTimeout(r, 2000));
    }
    console.log(`[RECHECK] Complete: ${checked} checked, ${suspended} suspended`);
  } catch (err: any) {
    console.error(`[RECHECK] Error: ${err.message}`);
  }
}, DAILY_RECHECK_INTERVAL_MS);

const imageFileFilter = (req: any, file: Express.Multer.File, cb: multer.FileFilterCallback) => {
  const allowedTypes = /jpeg|jpg|png|gif|webp/;
  const extname = allowedTypes.test(path.extname(file.originalname).toLowerCase());
  const mimetype = allowedTypes.test(file.mimetype);
  if (extname && mimetype) {
    cb(null, true);
  } else {
    cb(new Error("Tylko obrazy (jpg, png, gif, webp) są dozwolone"));
  }
};

