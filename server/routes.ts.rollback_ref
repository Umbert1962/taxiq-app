      let rides = await storage.getPendingRides();
      
      // In new flow: driver only sees rides where passenger selected them specifically
      if (driverId) {
        rides = rides.filter(r => r.preferredDriverId === driverId);
      }
      
      res.json(rides);
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch pending rides" });
    }
  });

  // Giełda zleceń - zamówienia telefoniczne dostępne dla wszystkich kierowców
  app.get("/api/driver/rides/available", async (req, res) => {
    try {
      const driverId = (req.session as any).driverId;
      let driverLat: number | null = null;
      let driverLng: number | null = null;
      
      // Get driver's current location if logged in
      if (driverId) {
        const driver = await storage.getDriver(driverId);
        if (driver?.currentLat && driver?.currentLng) {
          driverLat = parseFloat(driver.currentLat);
          driverLng = parseFloat(driver.currentLng);
        }
      }
      
      const allPendingRides = await storage.getPendingRides();
      const now = new Date();
      const fifteenMinutesAgo = new Date(now.getTime() - 15 * 60 * 1000);
      
      // Filtruj tylko zamówienia telefoniczne bez przydzielonego kierowcy
      const phoneOrders = allPendingRides.filter(r => 
        r.orderSource === "phone" && !r.driverId
      );
      
      // Podziel na aktualne i wygasłe (starsze niż 15 min)
      const expiredOrders = phoneOrders.filter(r => 
        r.createdAt && new Date(r.createdAt) < fifteenMinutesAgo
      );
      const availableRides = phoneOrders.filter(r => 
        !r.createdAt || new Date(r.createdAt) >= fifteenMinutesAgo
      );
      
      // Automatycznie archiwizuj wygasłe zamówienia (status: expired)
      for (const order of expiredOrders) {
        await db.update(rides)
          .set({ status: "cancelled", cancelReason: "Wygasło - brak odpowiedzi po 15 min" })
          .where(eq(rides.id, order.id));
        await storage.logStatusTransition(order.id, order.status, "cancelled", "system");
        console.log(`Phone order ${order.id} expired - archived`);
      }
      
      const calculateDistance = haversineDistance;
      
      // WAŻNE: Nie zwracaj numeru telefonu pasażera w giełdzie - jest ukryty dla nieprzypisanych kierowców
      // Add distance to each ride if driver location is known
      const sanitizedRides = availableRides.map(r => {
        const { callerPhone, ...safeRide } = r;
        
        // Calculate distance if both driver and ride have coordinates
        let distanceKm: number | null = null;
        if (driverLat && driverLng && r.pickupLat && r.pickupLng) {
          const rideLat = parseFloat(r.pickupLat);
          const rideLng = parseFloat(r.pickupLng);
          distanceKm = Math.round(calculateDistance(driverLat, driverLng, rideLat, rideLng) * 10) / 10;
        }
        
        return {
          ...safeRide,
          distanceKm, // Add distance to response
        };
      });
      
      // Sort by distance (closest first), rides without distance at the end
      sanitizedRides.sort((a, b) => {
        if (a.distanceKm === null && b.distanceKm === null) return 0;
        if (a.distanceKm === null) return 1;
        if (b.distanceKm === null) return -1;
        return a.distanceKm - b.distanceKm;
      });
      
      res.json(sanitizedRides);
    } catch (error) {
      console.error("Error fetching available rides:", error);
      res.status(500).json({ error: "Failed to fetch available rides" });
    }
  });

  // Kierowca akceptuje zlecenie z giełdy
  app.post("/api/driver/rides/:id/claim", async (req, res) => {
    try {
      const rideId = req.params.id;
      const driverId = (req.session as any).driverId;
      
      if (!driverId) {
        return res.status(401).json({ error: "Musisz być zalogowany jako kierowca" });
      }
      
      const ride = await storage.getRide(rideId);
      if (!ride) {
        return res.status(404).json({ error: "Zlecenie nie znalezione" });
      }
      
      if (ride.status !== "pending") {
        return res.status(400).json({ error: "To zlecenie zostało już przyjęte" });
      }
      
      if (ride.driverId) {
        return res.status(400).json({ error: "To zlecenie ma już przydzielonego kierowcę" });
      }
      
      // Przydziel kierowcę i zmień status
      await db.update(rides)
        .set({ 
          driverId: driverId,
          status: "accepted",
          acceptedAt: new Date()
        })
        .where(eq(rides.id, rideId));
      
      await storage.logStatusTransition(rideId, "pending", "accepted", "driver", driverId);
      console.log(`Driver ${driverId} claimed phone order ${rideId}`);
      
      res.json({ message: "Zlecenie przyjęte! Zadzwoń do klienta żeby ustalić adres." });
    } catch (error) {
      console.error("Error claiming ride:", error);
      res.status(500).json({ error: "Nie udało się przyjąć zlecenia" });
    }
  });

  // Kierowca zwalnia zlecenie (po nieudanej rozmowie) - wraca na giełdę
  app.post("/api/driver/rides/:id/release", async (req, res) => {
    try {
      const rideId = req.params.id;
      const driverId = (req.session as any).driverId;
      
      if (!driverId) {
        return res.status(401).json({ error: "Musisz być zalogowany jako kierowca" });
      }
      
      const ride = await storage.getRide(rideId);
      if (!ride) {
        return res.status(404).json({ error: "Zlecenie nie znalezione" });
      }
      
      // Tylko zlecenia telefoniczne mogą być zwolnione
      if (ride.orderSource !== "phone") {
        return res.status(400).json({ error: "Tylko zamówienia telefoniczne mogą być zwolnione" });
      }
      
      // Tylko przydzielony kierowca może zwolnić
      if (ride.driverId !== driverId) {
        return res.status(403).json({ error: "Możesz zwolnić tylko swoje zlecenia" });
      }
      
      // Tylko accepted zlecenia mogą być zwolnione
      if (ride.status !== "accepted") {
        return res.status(400).json({ error: "To zlecenie jest już w realizacji" });
      }
      
      // Zwolnij zlecenie - wraca na giełdę
      await db.update(rides)
        .set({ 
          driverId: null,
          status: "pending",
          acceptedAt: null
        })
        .where(eq(rides.id, rideId));
      
      await storage.logStatusTransition(rideId, "accepted", "pending", "driver", driverId);
      console.log(`Driver ${driverId} released phone order ${rideId} - back to marketplace`);
      
      res.json({ message: "Zlecenie zwolnione. Wróciło na giełdę." });
    } catch (error) {
      console.error("Error releasing ride:", error);
      res.status(500).json({ error: "Nie udało się zwolnić zlecenia" });
    }
  });

  app.get("/api/rides/:id", async (req, res) => {
    try {
      const ride = await storage.getRideWithDriver(req.params.id);
      if (!ride) {
        return res.status(404).json({ error: "Ride not found" });
      }
      res.json(ride);
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch ride" });
    }
  });

  app.post("/api/rides", async (req, res) => {
    try {
      console.log("[POST /api/rides] Attempt. Session passengerId:", req.session.passengerId || "NONE", "SessionID:", req.sessionID);
      console.log("[POST /api/rides] Body keys:", Object.keys(req.body).join(", "));
      console.log("[POST /api/rides] pickup:", req.body.pickupLocation, "dest:", req.body.destination);
      
      if (!req.session.passengerId) {
        console.warn("[POST /api/rides] REJECTED: No passengerId in session. Cookie:", req.headers.cookie ? "present" : "MISSING");
        return res.status(401).json({ error: "Musisz być zalogowany jako pasażer" });
      }

      const passenger = await storage.getUser(req.session.passengerId);
      if (!passenger || passenger.isActive === false) {
        return res.status(403).json({ error: "Konto pasażera jest dezaktywowane" });
      }
      
      // Convert scheduledAt string to Date if provided
      const bodyWithDate = {
        ...req.body,
        passengerId: req.session.passengerId,
        scheduledAt: req.body.scheduledAt ? new Date(req.body.scheduledAt) : null,
      };
      
      const parsed = insertRideSchema.safeParse(bodyWithDate);
      if (!parsed.success) {
        console.warn("[POST /api/rides] VALIDATION FAILED:", JSON.stringify(parsed.error.errors));
        return res.status(400).json({ error: "Invalid ride data", details: parsed.error.errors });
      }
      
      // Server-side validation: CITO requires a price
      if (parsed.data.isCito && (!parsed.data.citoPrice || parsed.data.citoPrice < 20)) {
        return res.status(400).json({ error: "CITO rides require a price of at least 20 PLN" });
      }
      
      // Add passengerId from session (not in insertRideSchema to prevent spoofing)
      const rideData = {
        ...parsed.data,
        passengerId: req.session.passengerId,
      };
      
      const ride = await storage.createRide(rideData);
      
      if (ride.pickupLat && ride.pickupLng) {
        const pLat = parseFloat(ride.pickupLat);
        const pLng = parseFloat(ride.pickupLng);
        if (!isNaN(pLat) && !isNaN(pLng)) {
          searchAndNotifyDrivers(
            ride.id, pLat, pLng,
            ride.pickupLocation || "Nieznany adres",
            ride.destination || "Nieznany cel",
            ride.estimatedPrice || ride.citoPrice
          ).catch(err => console.error(`[POST /api/rides] Search notify error: ${err.message}`));
        }
      }
      
      res.status(201).json(ride);
    } catch (error: any) {
      console.error("[POST /api/rides] Error creating ride:", error?.message || error);
      console.error("[POST /api/rides] Stack:", error?.stack);
      console.error("[POST /api/rides] Request body:", JSON.stringify(req.body));
      res.status(500).json({ error: "Failed to create ride", details: error?.message || "Unknown error" });
    }
  });

  app.patch("/api/rides/:id/accept", async (req, res) => {
    try {
      const { driverId } = req.body;
      if (!driverId) {
        return res.status(400).json({ error: "Driver ID required" });
      }
      
      // Check if ride has a preferred driver
      const existingRide = await storage.getRide(req.params.id);
      if (!existingRide) {
        return res.status(404).json({ error: "Ride not found" });
      }
      
      // If preferredDriverId is set, only that driver can accept
      if (existingRide.preferredDriverId && existingRide.preferredDriverId !== driverId) {
        return res.status(403).json({ error: "This ride is reserved for another driver" });
      }

      if (existingRide.orderSource !== "phone" && existingRide.offerExpiresAt && new Date(existingRide.offerExpiresAt) < new Date()) {
        return res.status(410).json({ error: "Oferta wygasła" });
      }
      
      const result = await storage.assignDriver(req.params.id, driverId);
      if (!result.ride && !result.alreadyTaken) {
        return res.status(404).json({ error: "Ride not found" });
      }
      if (result.alreadyTaken) {
        return res.status(409).json({ error: "Ride already taken" });
      }
      await clearOfferExpiry(req.params.id);
      rideNotifiedDrivers.delete(req.params.id);
      res.json(result.ride);
    } catch (error) {
      res.status(500).json({ error: "Failed to accept ride" });
    }
  });

  app.patch("/api/rides/:id/status", async (req, res) => {
    try {
      const { status } = req.body;
      const driverId = (req.session as any).driverId;
      const actor = driverId ? "driver" : "system";
      const actorId = driverId || undefined;
      const ride = await storage.updateRideStatus(req.params.id, status, actor, actorId);
      if (!ride) {
        return res.status(404).json({ error: "Ride not found" });
      }
      res.json(ride);
    } catch (error) {
      res.status(500).json({ error: "Failed to update ride status" });
    }
  });

  // Real-time location tracking endpoints
  app.patch("/api/rides/:id/driver-location", async (req, res) => {
    try {
      const { lat, lng } = req.body;
      if (!lat || !lng) {
        return res.status(400).json({ error: "Latitude and longitude required" });
      }
      const existingRide = await storage.getRide(req.params.id);
      if (!existingRide) {
        return res.status(404).json({ error: "Ride not found" });
      }
      if (existingRide.status !== "accepted" && existingRide.status !== "in_progress") {
        return res.status(400).json({ error: "Location updates only allowed for active rides" });
      }
      const ride = await storage.updateDriverLocation(req.params.id, lat, lng);
      res.json(ride);
    } catch (error) {
      res.status(500).json({ error: "Failed to update driver location" });
    }
  });

  app.patch("/api/rides/:id/passenger-location", async (req, res) => {
    try {
      const { lat, lng } = req.body;
      if (!lat || !lng) {
        return res.status(400).json({ error: "Latitude and longitude required" });
      }
      const existingRide = await storage.getRide(req.params.id);
      if (!existingRide) {
        return res.status(404).json({ error: "Ride not found" });
      }
      if (existingRide.status !== "accepted" && existingRide.status !== "in_progress") {
        return res.status(400).json({ error: "Location updates only allowed for active rides" });
      }
      const ride = await storage.updatePassengerLocation(req.params.id, lat, lng);
      res.json(ride);
    } catch (error) {
      res.status(500).json({ error: "Failed to update passenger location" });
    }
  });

  app.get("/api/rides/:id/locations", async (req, res) => {
    try {
      const ride = await storage.getRide(req.params.id);
      if (!ride) {
        return res.status(404).json({ error: "Ride not found" });
      }
      if (ride.status !== "accepted" && ride.status !== "in_progress") {
        return res.status(400).json({ error: "Location data only available for active rides" });
      }
      res.json({
        driver: {
          lat: ride.driverCurrentLat,
          lng: ride.driverCurrentLng,
          updatedAt: ride.driverLocationUpdatedAt,
        },
        passenger: {
          lat: ride.passengerCurrentLat,
          lng: ride.passengerCurrentLng,
          updatedAt: ride.passengerLocationUpdatedAt,
        },
      });
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch locations" });
    }
  });

  app.patch("/api/rides/:id/complete", async (req, res) => {
    try {
      const { finalPrice } = req.body;
      
      // Sprawdź czy to zamówienie telefoniczne - wymaga ceny z taksometru
      const existingRide = await storage.getRide(req.params.id);
      if (!existingRide) {
        return res.status(404).json({ error: "Ride not found" });
      }
      
      if (existingRide.orderSource === "phone" && (!finalPrice || finalPrice <= 0)) {
        return res.status(400).json({ 
          error: "Zamówienia telefoniczne wymagają wpisania ceny z taksometru" 
        });
      }
      
      const driverId = (req.session as any).driverId;
      const ride = await storage.completeRide(req.params.id, finalPrice, driverId);
      if (!ride) {
        return res.status(404).json({ error: "Ride not found" });
      }

      // Referral reward: when referred passenger completes first ride
      if (ride.passengerId) {
        try {
          const referral = await storage.getReferralByReferredUser(ride.passengerId);
          if (referral && referral.status === 'pending') {
            await storage.updateReferralStatus(referral.id, 'rewarded', 'Pierwszy przejazd poleconego pasażera');
            await storage.incrementDriverReferralCount(referral.referrerDriverId, 'passenger');
            await storage.addDriverReferralPoints(referral.referrerDriverId, 50);
            await db.update(users).set({ referralStatus: 'rewarded' }).where(eq(users.id, ride.passengerId));
          }
        } catch (refErr) {
          console.error("Passenger referral reward error:", refErr);
        }
      }

      res.json(ride);
    } catch (error) {
      res.status(500).json({ error: "Failed to complete ride" });
    }
  });

  app.patch("/api/rides/:id/cancel", async (req, res) => {
    try {
      const driverId = (req.session as any).driverId;
      const passengerId = (req.session as any).passengerId;

      const existingRide = await storage.getRide(req.params.id);
      if (!existingRide) {
        return res.status(404).json({ error: "Ride not found" });
      }

      const blockedStatuses = ["completed", "cancelled", "cancelled_by_passenger", "cancelled_by_driver"];
      if (passengerId && blockedStatuses.includes(existingRide.status)) {
        return res.status(400).json({ error: "Nie można anulować tego przejazdu" });
      }

      if (passengerId && existingRide.passengerId !== passengerId) {
        return res.status(403).json({ error: "Brak uprawnień do anulowania tego przejazdu" });
      }

      const cancelStatus = passengerId ? "cancelled_by_passenger" : driverId ? "cancelled_by_driver" : "cancelled";
      const actor = driverId ? "driver" : passengerId ? "passenger" : "system";
      const actorId = driverId || passengerId || undefined;
      const ride = await storage.cancelRide(req.params.id, actor, actorId, cancelStatus);
      if (!ride) {
        return res.status(404).json({ error: "Ride not found" });
      }
      await clearOfferExpiry(req.params.id);
      rideNotifiedDrivers.delete(req.params.id);
      res.json(ride);
    } catch (error) {
      res.status(500).json({ error: "Failed to cancel ride" });
    }
  });

  // Update ride destination (during ride - increases price by 20% server-side)
  app.patch("/api/rides/:id/destination", async (req, res) => {
    try {
      // Validate request body with Zod schema
      const parsed = updateRideDestinationSchema.safeParse(req.body);
      if (!parsed.success) {
        return res.status(400).json({ error: "Invalid destination data", details: parsed.error.errors });
      }
      
      const { destination, destLat, destLng } = parsed.data;
      
      const ride = await storage.getRide(req.params.id);
      if (!ride) {
        return res.status(404).json({ error: "Ride not found" });
      }
      
      // Only allow editing during pending, accepted or in_progress rides
      if (!["pending", "accepted", "in_progress"].includes(ride.status)) {
        return res.status(400).json({ error: "Cannot edit destination for this ride status" });
      }
      
      // Calculate additional price server-side (20% of current estimated price)
      const additionalPrice = Math.round((ride.estimatedPrice || 0) * 0.2);
      
      const updatedRide = await storage.updateRideDestination(
        req.params.id, 
        destination, 
        destLat, 
        destLng, 
        additionalPrice
      );
      
      res.json(updatedRide);
    } catch (error) {
      res.status(500).json({ error: "Failed to update destination" });
    }
  });

  // Add stop to ride (driver can add during ride)
  app.post("/api/rides/:id/stops", async (req, res) => {
    try {
      const { addRideStopSchema } = await import("@shared/schema");
      const parsed = addRideStopSchema.safeParse(req.body);
      if (!parsed.success) {
        return res.status(400).json({ error: "Invalid stop data", details: parsed.error.errors });
      }
      
      const { address, lat, lng } = parsed.data;
      
      const ride = await storage.getRide(req.params.id);
      if (!ride) {
        return res.status(404).json({ error: "Ride not found" });
      }
      
      if (!["accepted", "in_progress"].includes(ride.status)) {
        return res.status(400).json({ error: "Can only add stops during active rides" });
      }
      
      const currentStops = (ride.stops as Array<{ address: string; lat: string; lng: string }>) || [];
      const newStops = [...currentStops, { address, lat, lng }];
      
      // Każdy dodatkowy przystanek zwiększa cenę o 10 PLN
      const stopSurcharge = 10;
      const newPrice = (ride.estimatedPrice || 0) + stopSurcharge;
      
      const updatedRide = await storage.updateRide(req.params.id, { 
        stops: newStops,
        estimatedPrice: newPrice,
      });
      res.json(updatedRide);
    } catch (error) {
      res.status(500).json({ error: "Failed to add stop" });
    }
  });

  // Remove stop from ride by exact match (address + lat + lng)
  app.post("/api/rides/:id/stops/remove", async (req, res) => {
    try {
      const { addRideStopSchema } = await import("@shared/schema");
      const parsed = addRideStopSchema.safeParse(req.body);
      if (!parsed.success) {
        return res.status(400).json({ error: "Invalid stop data", details: parsed.error.errors });
      }
      
      const { address, lat, lng } = parsed.data;
      
      const ride = await storage.getRide(req.params.id);
      if (!ride) {
        return res.status(404).json({ error: "Ride not found" });
      }
      
      if (!["accepted", "in_progress"].includes(ride.status)) {
        return res.status(400).json({ error: "Can only remove stops during active rides" });
      }
      
      const currentStops = (ride.stops as Array<{ address: string; lat: string; lng: string }>) || [];
      const newStops = currentStops.filter((stop) => 
        !(stop.address === address && stop.lat === lat && stop.lng === lng)
      );
      
      if (newStops.length === currentStops.length) {
        return res.status(404).json({ error: "Stop not found" });
      }
      
      // Usunięcie przystanku zmniejsza cenę o 10 PLN (ale minimum 20 PLN)
      const stopSurcharge = 10;
      const newPrice = Math.max(20, (ride.estimatedPrice || 0) - stopSurcharge);
      
      const updatedRide = await storage.updateRide(req.params.id, { 
        stops: newStops,
        estimatedPrice: newPrice,
      });
      res.json(updatedRide);
    } catch (error) {
      res.status(500).json({ error: "Failed to remove stop" });
    }
  });

  // Select driver for a pending ride (passenger selects driver from offers)
  // Also handles resetting driver selection when preferredDriverId is null
  app.patch("/api/rides/:id/select-driver", async (req, res) => {
    try {
      const { preferredDriverId, estimatedPrice } = req.body;
      
      const ride = await storage.getRide(req.params.id);
      if (!ride) {
        return res.status(404).json({ error: "Ride not found" });
      }
      
      if (ride.status !== "pending") {
        return res.status(400).json({ error: "Can only select driver for pending rides" });
      }
      
      // If preferredDriverId is null, reset driver selection
      if (preferredDriverId === null) {
        const updatedRide = await storage.updateRide(req.params.id, {
          preferredDriverId: null,
          driverRequestedAt: null,
        });
        return res.json(updatedRide);
      }
      
      if (!preferredDriverId) {
        return res.status(400).json({ error: "preferredDriverId is required" });
      }
      
      const updatedRide = await storage.updateRide(req.params.id, {
        preferredDriverId,
        estimatedPrice: estimatedPrice || ride.estimatedPrice,
        driverRequestedAt: new Date(),
      });
      
      const driver = await storage.getDriver(preferredDriverId);
      if (driver) {
        let distanceKm: number | null = null;
        let withinRadius = true;

        if (ride.pickupLat && ride.pickupLng && driver.currentLat && driver.currentLng) {
          const pLat = parseFloat(ride.pickupLat);
          const pLng = parseFloat(ride.pickupLng);
          const dLat = parseFloat(driver.currentLat);
          const dLng = parseFloat(driver.currentLng);

          if (!isNaN(pLat) && !isNaN(pLng) && !isNaN(dLat) && !isNaN(dLng)) {
            distanceKm = haversineDistance(dLat, dLng, pLat, pLng);
            withinRadius = distanceKm <= LONG_PICKUP_MAX_DISTANCE_KM;
          }
        }

        console.log(`[PREFERRED_DRIVER_CHECK] ride_id=${ride.id}, driver_id=${preferredDriverId}, distance_km=${distanceKm !== null ? distanceKm.toFixed(2) : 'unknown'}, max_km=${LONG_PICKUP_MAX_DISTANCE_KM}, within_radius=${withinRadius}`);

        if (withinRadius) {
          await sendPushNotification(preferredDriverId, {
            title: "Nowe zlecenie!",
            body: `${ride.pickupLocation} → ${ride.destination}. Cena: ${estimatedPrice || ride.estimatedPrice || '?'} PLN`,
            data: {
              type: "ride_request",
              rideId: ride.id,
              pickup: ride.pickupLocation,
              destination: ride.destination,
              price: estimatedPrice || ride.estimatedPrice,
              driverId: preferredDriverId
            },
            tag: 'taxiq-ride-request-' + ride.id
          });
          console.log(`[PREFERRED_DRIVER_PUSH_SENT] driver_id=${preferredDriverId}, ride_id=${ride.id}`);
        } else {
          console.log(`[PREFERRED_DRIVER_BLOCKED] driver_id=${preferredDriverId}, ride_id=${ride.id}, distance_km=${distanceKm?.toFixed(2)}, reason=too_far`);
        }
      }
      
      res.json(updatedRide);
    } catch (error) {
      console.error("Error selecting driver:", error);
      res.status(500).json({ error: "Failed to select driver" });
    }
  });

  // ============ MESSAGES ============
  app.get("/api/rides/:id/messages", async (req, res) => {
    try {
      const messages = await storage.getRideMessages(req.params.id);
      res.json(messages);
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch messages" });
    }
  });

  app.post("/api/rides/:id/messages", async (req, res) => {
    try {
      const parsed = insertMessageSchema.safeParse({
        ...req.body,
        rideId: req.params.id
      });
      if (!parsed.success) {
        return res.status(400).json({ error: "Invalid message data" });
      }
      
      const message = await storage.createMessage(parsed.data);
      res.status(201).json(message);
    } catch (error) {
      res.status(500).json({ error: "Failed to send message" });
    }
  });

  app.patch("/api/rides/:id/messages/read", async (req, res) => {
    try {
      const { recipientType } = req.body;
      await storage.markMessagesAsRead(req.params.id, recipientType);
      res.json({ success: true });
    } catch (error) {
      res.status(500).json({ error: "Failed to mark messages as read" });
    }
  });

  app.get("/api/rides/:id/messages/unread", async (req, res) => {
    try {
      const { recipientType } = req.query;
      if (!recipientType || typeof recipientType !== "string") {
        return res.status(400).json({ error: "recipientType query param required" });
      }
      const count = await storage.getUnreadMessageCount(req.params.id, recipientType);
      res.json({ count });
    } catch (error) {
      res.status(500).json({ error: "Failed to get unread count" });
    }
  });

  // ============ RATINGS ============
  app.post("/api/ratings", async (req, res) => {
    try {
      const parsed = insertRatingSchema.safeParse(req.body);
      if (!parsed.success) {
        return res.status(400).json({ error: "Invalid rating data" });
      }
      
      const existing = await storage.getRideRating(parsed.data.rideId);
      if (existing) {
        return res.status(409).json({ error: "Ride already rated" });
      }
      
      const rating = await storage.createRating(parsed.data);
      res.status(201).json(rating);
    } catch (error) {
      res.status(500).json({ error: "Failed to create rating" });
    }
  });

  app.get("/api/rides/:id/rating", async (req, res) => {
    try {
      const rating = await storage.getRideRating(req.params.id);
      res.json(rating || null);
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch rating" });
    }
  });

  // ============ BUSINESS AUTH ============
  app.post("/api/business/register", async (req, res) => {
    try {
      const parsed = insertCompanySchema.safeParse(req.body);
      if (!parsed.success) {
        return res.status(400).json({ error: "Invalid company data", details: parsed.error.errors });
      }
      
      const existing = await storage.getCompanyByEmail(parsed.data.email);
      if (existing) {
        return res.status(409).json({ error: "Email already registered" });
      }
      
      const hashedPassword = await hashPassword(parsed.data.password);
      const company = await storage.createCompany({
        ...parsed.data,
        password: hashedPassword
      });
      res.status(201).json({ 
        id: company.id, 
        name: company.name, 
        email: company.email,
        type: company.type 
      });
    } catch (error) {
      res.status(500).json({ error: "Failed to register company" });
    }
  });

  app.post("/api/business/login", async (req, res) => {
    const clientIp = req.ip || req.socket.remoteAddress || 'unknown';
    if (!checkLoginRateLimit(clientIp)) {
      return res.status(429).json({ error: "Zbyt wiele prób logowania. Spróbuj ponownie za 5 minut." });
    }
    console.log(`[LOGIN] POST /api/business/login | ip: ${clientIp} | ts: ${new Date().toISOString()}`);
    try {
      const { email, password, isEmployee } = req.body;
      if (!email || !password) {
        return res.status(400).json({ error: "Email i hasło są wymagane" });
      }
      
      if (isEmployee) {
        const employee = await storage.getEmployeeByEmail(email);
        if (!employee) {
          recordFailedAttempt(clientIp);
          return res.status(401).json({ error: "Nieprawidłowy email lub hasło" });
        }
        let passwordValid = employee.password === password;
        if (!passwordValid && employee.password?.startsWith('$2')) {
          passwordValid = await verifyPassword(password, employee.password);
        }
        if (!passwordValid) {
          recordFailedAttempt(clientIp);
          return res.status(401).json({ error: "Nieprawidłowy email lub hasło" });
        }
        resetLoginAttempts(clientIp);
        
        invalidateBusinessSessions(employee.id, "employee");
        
        // Set employee online
        await storage.setEmployeeOnline(employee.id, true);
        
        const company = await storage.getCompany(employee.companyId);
        const token = generateToken();
        businessSessions.set(token, {
          type: "employee",
          id: employee.id,
          companyId: employee.companyId,
          role: employee.role
        });
        res.json({
          token,
          type: "employee",
          id: employee.id,
          name: employee.name,
          email: employee.email,
          role: employee.role,
          companyId: employee.companyId,
          companyName: company?.name
        });
      } else {
        const company = await storage.getCompanyByEmail(email);
        if (!company) {
          recordFailedAttempt(clientIp);
          return res.status(401).json({ error: "Nieprawidłowy email lub hasło" });
        }
        let passwordValid = company.password === password;
        if (!passwordValid && company.password?.startsWith('$2')) {
          passwordValid = await verifyPassword(password, company.password);
        }
        if (!passwordValid) {
          recordFailedAttempt(clientIp);
          return res.status(401).json({ error: "Nieprawidłowy email lub hasło" });
        }
        resetLoginAttempts(clientIp);
        
        invalidateBusinessSessions(company.id, "company");
        
        // Set company online
        await storage.setCompanyOnline(company.id, true);
        
        const token = generateToken();
        businessSessions.set(token, {
          type: "company",
          id: company.id,
          companyId: company.id,
          role: "admin"
        });
        res.json({
          token,
          type: "company",
          id: company.id,
          name: company.name,
          email: company.email,
          companyType: company.type,
          phone: company.phone,
          address: company.address,
          taxId: company.taxId
        });
      }
    } catch (error: any) {
      console.error("[DIAG] /api/business/login - EXCEPTION:", error?.message);
      console.error("[DIAG] /api/business/login - Stack:", error?.stack);
      res.status(500).json({ error: "Logowanie nie powiodło się" });
    }
  });
  
  app.post("/api/business/logout", async (req, res) => {
    const token = req.headers["x-business-token"] as string;
    if (token) {
      const session = businessSessions.get(token);
      if (session) {
        // Set offline before removing session
        if (session.type === "employee") {
          await storage.setEmployeeOnline(session.id, false);
        } else {
          await storage.setCompanyOnline(session.id, false);
        }
        businessSessions.delete(token);
      }
    }
    res.json({ success: true });
  });

  // ============ BUSINESS COMPANY ============
  app.get("/api/business/company/:id", requireBusinessAuth, requireCompanyAccess, async (req, res) => {
    try {
      const company = await storage.getCompany(String(req.params.id));
      if (!company) {
        return res.status(404).json({ error: "Company not found" });
      }
      res.json({
        id: company.id,
        name: company.name,
        email: company.email,
        phone: company.phone,
        address: company.address,
        taxId: company.taxId,
        type: company.type
      });
    } catch (error) {
      res.status(500).json({ error: "Failed to fetch company" });
    }
  });

  app.patch("/api/business/company/:id", requireBusinessAuth, requireCompanyAccess, async (req, res) => {
    try {
      const company = await storage.updateCompany(String(req.params.id), req.body);
      if (!company) {
        return res.status(404).json({ error: "Company not found" });
      }
      res.json(company);
    } catch (error) {
      res.status(500).json({ error: "Failed to update company" });
    }
  });

  // ============ EMPLOYEES ============
  app.get("/api/business/company/:id/employees", requireBusinessAuth, requireCompanyAccess, async (req, res) => {
