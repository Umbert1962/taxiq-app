  // ==================== SYSTEM MESSAGES (ADMIN) ====================

  app.post("/api/admin/system-messages", requireAdmin, async (req, res) => {
    try {
      const { title, content, targetRole, type, deliveryMode, requireAcknowledgement, forceOnLogin, expiresAt } = req.body;
      if (!title || !content || !targetRole || !type) {
        return res.status(400).json({ error: "Wymagane pola: title, content, targetRole, type" });
      }
      const validRoles = ["DRIVER", "PASSENGER", "ALL"];
      const validTypes = ["INFO", "WARNING", "CRITICAL", "PROMO"];
      const validModes = ["INBOX", "INBOX_AND_PUSH", "LOGIN_MODAL_ONLY"];
      if (!validRoles.includes(targetRole)) return res.status(400).json({ error: "targetRole musi być DRIVER, PASSENGER lub ALL" });
      if (!validTypes.includes(type)) return res.status(400).json({ error: "type musi być INFO, WARNING, CRITICAL lub PROMO" });
      if (deliveryMode && !validModes.includes(deliveryMode)) return res.status(400).json({ error: "Nieprawidłowy deliveryMode" });

      const adminId = (req.session as any).adminId;
      const msg = await storage.createSystemMessage({
        title, content, targetRole, type,
        deliveryMode: deliveryMode || "INBOX",
        requireAcknowledgement: requireAcknowledgement || false,
        forceOnLogin: forceOnLogin || false,
        expiresAt: expiresAt ? new Date(expiresAt) : null,
        createdByAdminId: adminId,
      });
      res.json(msg);
    } catch (error) {
      console.error("Error creating system message:", error);
      res.status(500).json({ error: "Nie udało się utworzyć wiadomości" });
    }
  });

  app.put("/api/admin/system-messages/:id/new-version", requireAdmin, async (req, res) => {
    try {
      const oldMsg = await storage.getSystemMessage(req.params.id);
      if (!oldMsg) return res.status(404).json({ error: "Wiadomość nie znaleziona" });

      const { title, content, targetRole, type, deliveryMode, requireAcknowledgement, forceOnLogin, expiresAt } = req.body;
      const validRoles = ["DRIVER", "PASSENGER", "ALL"];
      const validTypes = ["INFO", "WARNING", "CRITICAL", "PROMO"];
      const validModes = ["INBOX", "INBOX_AND_PUSH", "LOGIN_MODAL_ONLY"];
      const finalRole = targetRole || oldMsg.targetRole;
      const finalType = type || oldMsg.type;
      const finalMode = deliveryMode || oldMsg.deliveryMode;
      if (!validRoles.includes(finalRole)) return res.status(400).json({ error: "targetRole musi być DRIVER, PASSENGER lub ALL" });
      if (!validTypes.includes(finalType)) return res.status(400).json({ error: "type musi być INFO, WARNING, CRITICAL lub PROMO" });
      if (!validModes.includes(finalMode)) return res.status(400).json({ error: "Nieprawidłowy deliveryMode" });

      await storage.deactivateSystemMessage(oldMsg.id);

      const adminId = (req.session as any).adminId;
      const newMsg = await storage.createSystemMessage({
        title: title || oldMsg.title,
        content: content || oldMsg.content,
        targetRole: targetRole || oldMsg.targetRole,
        type: type || oldMsg.type,
        deliveryMode: deliveryMode || oldMsg.deliveryMode,
        requireAcknowledgement: requireAcknowledgement !== undefined ? requireAcknowledgement : oldMsg.requireAcknowledgement,
        forceOnLogin: forceOnLogin !== undefined ? forceOnLogin : oldMsg.forceOnLogin,
        expiresAt: expiresAt ? new Date(expiresAt) : oldMsg.expiresAt,
        createdByAdminId: adminId,
        version: (oldMsg.version || 1) + 1,
        parentMessageId: oldMsg.id,
      });
      res.json(newMsg);
    } catch (error) {
      console.error("Error creating new version:", error);
      res.status(500).json({ error: "Nie udało się utworzyć nowej wersji" });
    }
  });

  app.patch("/api/admin/system-messages/:id/deactivate", requireAdmin, async (req, res) => {
    try {
      await storage.deactivateSystemMessage(req.params.id);
      res.json({ success: true });
    } catch (error) {
      console.error("Error deactivating message:", error);
      res.status(500).json({ error: "Nie udało się dezaktywować wiadomości" });
    }
  });

  app.get("/api/admin/system-messages", requireAdmin, async (req, res) => {
    try {
      const allMessages = await storage.getSystemMessages();
      const messagesWithStats = await Promise.all(allMessages.map(async (msg) => {
        const stats = await storage.getMessageReadStats(msg.id);
        let totalTargeted = 0;
        if (msg.targetRole === "DRIVER") {
          const allDrivers = await storage.getAllDrivers();
          totalTargeted = allDrivers.filter((d: any) => d.isActive !== false).length;
        } else if (msg.targetRole === "PASSENGER") {
          const allUsers = await storage.getAllUsers();
          totalTargeted = allUsers.filter((u: any) => u.isActive !== false).length;
        } else if (msg.targetRole === "ALL") {
          const allDrivers = await storage.getAllDrivers();
          const allUsers = await storage.getAllUsers();
          totalTargeted = allDrivers.filter((d: any) => d.isActive !== false).length + allUsers.filter((u: any) => u.isActive !== false).length;
        }
        return {
          ...msg,
          totalTargeted,
          totalRead: stats.totalRead,
          totalAcknowledged: stats.totalAcknowledged,
          readRate: totalTargeted > 0 ? Math.round((stats.totalRead / totalTargeted) * 100) : 0,
          ackRate: totalTargeted > 0 ? Math.round((stats.totalAcknowledged / totalTargeted) * 100) : 0,
        };
      }));
      res.json(messagesWithStats);
    } catch (error) {
      console.error("Error getting system messages:", error);
      res.status(500).json({ error: "Nie udało się pobrać wiadomości" });
    }
  });

  // ==================== SYSTEM MESSAGES (USER) ====================

  app.get("/api/system-messages", async (req, res) => {
    try {
      const session = req.session as any;
      let userId: string | null = null;
      let role: string | null = null;

      if (session.driverId) {
        userId = session.driverId;
        role = "DRIVER";
      } else if (session.passengerId) {
        userId = session.passengerId;
        role = "PASSENGER";
      }

      if (!userId || !role) {
        return res.status(401).json({ error: "Nie zalogowany" });
      }

      const messages = await storage.getActiveMessagesForRole(role);
      const readStatuses = await storage.getUserMessageReadStatus(userId, messages.map(m => m.id));
      const readMap = new Map(readStatuses.map(r => [r.messageId, r]));

      const result = messages.map(m => ({
        ...m,
        isRead: readMap.has(m.id),
        isAcknowledged: readMap.get(m.id)?.acknowledgedAt !== null && readMap.get(m.id)?.acknowledgedAt !== undefined,
      }));

      res.json(result);
    } catch (error) {
      console.error("Error getting user system messages:", error);
      res.status(500).json({ error: "Nie udało się pobrać wiadomości" });
    }
  });

