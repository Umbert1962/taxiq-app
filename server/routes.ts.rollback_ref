  app.post("/api/passenger/add-favorite-by-license", async (req, res) => {
    try {
      const passengerId = (req.session as any).passengerId;
      if (!passengerId) return res.status(401).json({ error: "Nie zalogowano" });

      const { licenseNumber } = req.body;
      if (!licenseNumber || typeof licenseNumber !== "string" || !licenseNumber.trim()) {
        return res.status(400).json({ error: "Numer licencji jest wymagany" });
      }

      const sanitized = licenseNumber.trim().slice(0, 50);
      if (!sanitized) {
        return res.status(400).json({ error: "Numer licencji jest wymagany" });
      }

      const driver = await storage.getDriverByLicenseNumber(sanitized);
      if (!driver) {
        return res.status(404).json({ error: "Nie znaleziono kierowcy o podanym numerze licencji" });
      }

      if (passengerId === driver.id) {
        return res.status(400).json({ error: "Nie można dodać siebie jako ulubionego kierowcę" });
      }

      const fav = await storage.addFavoriteDriver(passengerId, driver.id);
      res.json({ success: true, driverName: `${driver.firstName || ""} ${driver.lastName || ""}`.trim() || driver.name, favorite: fav });
    } catch (error: any) {
      console.error("Error adding favorite by license:", error);
      res.status(500).json({ error: "Błąd serwera" });
    }
  });

