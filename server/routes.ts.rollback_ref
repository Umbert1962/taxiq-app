  // Push notification subscription
  app.post("/api/push/subscribe", async (req, res) => {
    try {
      const { driverId, subscription } = req.body;
      
      if (!driverId || !subscription) {
        return res.status(400).json({ error: "driverId and subscription are required" });
      }

      const parsed = insertPushSubscriptionSchema.safeParse({
        driverId,
        endpoint: subscription.endpoint,
        p256dh: subscription.keys.p256dh,
        auth: subscription.keys.auth
      });

      if (!parsed.success) {
        return res.status(400).json({ error: "Invalid subscription data" });
      }

      await storage.savePushSubscription(parsed.data);
      res.json({ success: true });
    } catch (error) {
      console.error("Error saving push subscription:", error);
      res.status(500).json({ error: "Failed to save subscription" });
    }
  });

  // FCM token registration (for Capacitor native apps) - requires authenticated session
  app.post("/api/fcm/register", async (req, res) => {
    try {
      const { token, platform } = req.body;
      
      if (!token || !platform) {
        return res.status(400).json({ error: "token and platform are required" });
      }
      
      if (!['android', 'ios', 'web'].includes(platform)) {
        return res.status(400).json({ error: "platform must be 'android', 'ios', or 'web'" });
      }
      
      // Derive userId and userType from authenticated session
      let userId: string | undefined;
      let userType: "driver" | "passenger" | undefined;
      
      const session = req.session as any;
      if (session?.driverId) {
        userId = session.driverId;
        userType = "driver";
      } else if (session?.userId) {
        userId = session.userId;
        userType = "passenger";
      }
      
      if (!userId || !userType) {
        return res.status(401).json({ error: "Authentication required" });
      }
      
      const parsed = insertFcmTokenSchema.safeParse({ userId, userType, token, platform });
      
      if (!parsed.success) {
        return res.status(400).json({ error: "Invalid FCM token data" });
      }
      
      await storage.saveFcmToken(parsed.data);
      console.log(`[FCM_REGISTER] user=${userId}, type=${userType}, platform=${platform}`);
      res.json({ success: true });
    } catch (error) {
      console.error("Error registering FCM token:", error);
      res.status(500).json({ error: "Failed to register FCM token" });
    }
  });

  // FCM token removal - requires authenticated session
  app.post("/api/fcm/unregister", async (req, res) => {
    try {
      const { token } = req.body;
      if (!token) {
        return res.status(400).json({ error: "token is required" });
      }
      
      const session = req.session as any;
      if (!session?.driverId && !session?.userId) {
        return res.status(401).json({ error: "Authentication required" });
      }
      
      await storage.deleteFcmToken(token);
      console.log(`[FCM_UNREGISTER] token removed`);
      res.json({ success: true });
    } catch (error) {
      console.error("Error unregistering FCM token:", error);
      res.status(500).json({ error: "Failed to unregister FCM token" });
    }
  });

  // FCM status check
  app.get("/api/fcm/status", async (_req, res) => {
    res.json({ 
      fcmReady: isFCMReady(),
      webPushReady: !!(vapidPublicKey && vapidPrivateKey)
    });
  });

  // ============ TWILIO IVR WEBHOOKS ============
  // Main voice webhook - initial IVR menu
  app.post("/api/twilio/voice", async (req, res) => {
    console.log("=== TWILIO VOICE WEBHOOK ===", req.body);
    
    const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Gather numDigits="1" action="/api/twilio/handle-key" method="POST" timeout="10">
    <Say language="pl-PL" voice="Polly.Ewa">
      Witamy w Taxi Q. Taksówka bez pośredników. Aby zamówić taksówkę, naciśnij jeden.
    </Say>
  </Gather>
  <Say language="pl-PL" voice="Polly.Ewa">
    Nie otrzymaliśmy wyboru. Do usłyszenia.
  </Say>
</Response>`;
    
    res.type('text/xml');
    res.send(twiml);
  });

  // Handle key press (digit 1 = order taxi) - now asks for address recording
  app.post("/api/twilio/handle-key", async (req, res) => {
    console.log("=== TWILIO HANDLE KEY ===", req.body);
    
    const digit = req.body.Digits;
    const callerPhone = req.body.From || req.body.Caller;
    const baseUrl = process.env.PUBLIC_BASE_URL || "https://taxiq.com.pl";
    
    if (digit === "1") {
      // Ask caller to say their pickup address using Polish speech recognition
      const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Gather input="speech" language="pl-PL" speechTimeout="3" timeout="10" action="${baseUrl}/api/twilio/address-spoken?callerPhone=${encodeURIComponent(callerPhone)}">
    <Say language="pl-PL" voice="Polly.Ewa">
      Proszę powiedzieć swój adres odbioru. Na przykład: ulica Marszałkowska dziesięć, Warszawa.
    </Say>
  </Gather>
  <Say language="pl-PL" voice="Polly.Ewa">
    Nie usłyszeliśmy adresu. Do usłyszenia.
  </Say>
</Response>`;
      
      res.type('text/xml');
      res.send(twiml);
    } else {
      // Wrong key pressed
      const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say language="pl-PL" voice="Polly.Ewa">
    Nieprawidłowy wybór. Do usłyszenia.
  </Say>
</Response>`;
      
      res.type('text/xml');
      res.send(twiml);
    }
  });
  
  // Handle spoken address - ask for confirmation
  app.post("/api/twilio/address-spoken", async (req, res) => {
    console.log("=== TWILIO ADDRESS SPOKEN ===", req.body, req.query);
    
    const callerPhone = req.query.callerPhone as string;
    const spokenAddress = req.body.SpeechResult;
    const confidence = req.body.Confidence;
    const baseUrl = process.env.PUBLIC_BASE_URL || "https://taxiq.com.pl";
    
    console.log(`Recognized address: "${spokenAddress}" with confidence: ${confidence}`);
    
    if (!spokenAddress) {
      // No speech detected - ask to try again
      const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Gather input="speech" language="pl-PL" speechTimeout="3" timeout="10" action="${baseUrl}/api/twilio/address-spoken?callerPhone=${encodeURIComponent(callerPhone)}">
    <Say language="pl-PL" voice="Polly.Ewa">
      Nie usłyszeliśmy adresu. Proszę spróbować ponownie. Powiedz swój adres odbioru.
    </Say>
  </Gather>
  <Say language="pl-PL" voice="Polly.Ewa">
    Przepraszamy, nie udało się rozpoznać adresu. Do usłyszenia.
  </Say>
</Response>`;
      res.type('text/xml');
      return res.send(twiml);
    }
    
    // Ask for confirmation
    const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Gather numDigits="1" action="${baseUrl}/api/twilio/confirm-address?callerPhone=${encodeURIComponent(callerPhone)}&amp;address=${encodeURIComponent(spokenAddress)}" timeout="10">
    <Say language="pl-PL" voice="Polly.Ewa">
      Zrozumiałam: ${spokenAddress}. Jeśli adres jest poprawny, naciśnij jeden. Aby powiedzieć adres ponownie, naciśnij dwa.
    </Say>
  </Gather>
  <Say language="pl-PL" voice="Polly.Ewa">
    Nie otrzymaliśmy odpowiedzi. Do usłyszenia.
  </Say>
</Response>`;
    
    res.type('text/xml');
    res.send(twiml);
  });
  
  // Handle address confirmation
  app.post("/api/twilio/confirm-address", async (req, res) => {
    console.log("=== TWILIO CONFIRM ADDRESS ===", req.body, req.query);
    
    const callerPhone = req.query.callerPhone as string;
    const address = req.query.address as string;
    const digit = req.body.Digits;
    const baseUrl = process.env.PUBLIC_BASE_URL || "https://taxiq.com.pl";
    
    if (digit === "2") {
      // User wants to repeat address
      const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Gather input="speech" language="pl-PL" speechTimeout="3" timeout="10" action="${baseUrl}/api/twilio/address-spoken?callerPhone=${encodeURIComponent(callerPhone)}">
    <Say language="pl-PL" voice="Polly.Ewa">
      Proszę powiedzieć swój adres odbioru ponownie.
    </Say>
  </Gather>
  <Say language="pl-PL" voice="Polly.Ewa">
    Nie usłyszeliśmy adresu. Do usłyszenia.
  </Say>
</Response>`;
      res.type('text/xml');
      return res.send(twiml);
    }
    
    if (digit === "1") {
      // User confirmed address - create order
      try {
        // Geocode the address
        let pickupLat: number | null = null;
        let pickupLng: number | null = null;
        let geocodedAddress = address;
        
        const googleApiKey = process.env.GOOGLE_API_KEY;
        if (googleApiKey && address) {
          try {
            const geocodeUrl = `https://maps.googleapis.com/maps/api/geocode/json?address=${encodeURIComponent(address + ", Polska")}&key=${googleApiKey}&language=pl`;
            const geocodeResponse = await fetch(geocodeUrl);
            const geocodeData = await geocodeResponse.json() as any;
            
            if (geocodeData.status === "OK" && geocodeData.results?.[0]) {
              const location = geocodeData.results[0].geometry.location;
              pickupLat = location.lat;
              pickupLng = location.lng;
              geocodedAddress = geocodeData.results[0].formatted_address || address;
              console.log(`Geocoded: ${geocodedAddress} -> ${pickupLat}, ${pickupLng}`);
            }
          } catch (geoError) {
            console.error("Geocoding error:", geoError);
          }
        }
        
        // Create phone order
        const ride = await storage.createRide({
          pickupLocation: geocodedAddress,
          destination: "Do ustalenia telefonicznie",
          passengerCount: 1,
        });
        
        await db.update(rides)
          .set({ 
            orderSource: "phone",
            callerPhone: callerPhone,
            pickupLat: pickupLat?.toString() || null,
            pickupLng: pickupLng?.toString() || null,
          })
          .where(eq(rides.id, ride.id));
        
        console.log(`Phone order created: ${ride.id} from ${callerPhone}, address: ${geocodedAddress}`);
        
        if (pickupLat && pickupLng) {
          await searchAndNotifyDrivers(ride.id, pickupLat, pickupLng, geocodedAddress, "Do ustalenia telefonicznie", null, "phone");
        } else {
          console.log(`[PROXIMITY_SKIP] ride_id=${ride.id}, reason=no_pickup_coordinates`);
        }
        
        const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say language="pl-PL" voice="Polly.Ewa">
    Dziękujemy. Twoje zamówienie zostało przyjęte. Kierowca z okolicy wkrótce oddzwoni pod ten numer. Do usłyszenia.
  </Say>
</Response>`;
        
        res.type('text/xml');
        res.send(twiml);
      } catch (error) {
        console.error("Error creating confirmed phone order:", error);
        const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say language="pl-PL" voice="Polly.Ewa">
    Przepraszamy, wystąpił błąd. Spróbuj ponownie później.
  </Say>
</Response>`;
        res.type('text/xml');
        res.send(twiml);
      }
    } else {
      // Invalid choice
      const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say language="pl-PL" voice="Polly.Ewa">
    Nieprawidłowy wybór. Do usłyszenia.
  </Say>
</Response>`;
      res.type('text/xml');
      res.send(twiml);
    }
  });
  
  // Legacy: Handle recorded address (kept for backward compatibility)
  app.post("/api/twilio/address-recorded", async (req, res) => {
    console.log("=== TWILIO ADDRESS RECORDED (legacy) ===", req.body, req.query);
    
    const callerPhone = req.query.callerPhone as string;
    const recordingUrl = req.body.RecordingUrl;
    const recordingSid = req.body.RecordingSid;
    
    try {
      // Create phone order in database
      const ride = await storage.createRide({
        pickupLocation: "Adres nagrany - oczekuje na transkrypcję",
        destination: "Do ustalenia telefonicznie",
        passengerCount: 1,
      });
      
      await db.update(rides)
        .set({ 
          orderSource: "phone",
          callerPhone: callerPhone,
          notes: `RecordingSid:${recordingSid}`, // Store recording reference
        })
        .where(eq(rides.id, ride.id));
      
      console.log(`Phone order created: ${ride.id} from ${callerPhone}, RecordingSid: ${recordingSid}`);
      
      // Confirm to caller
      const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say language="pl-PL" voice="Polly.Ewa">
    Dziękujemy. Twoje zamówienie zostało przyjęte. Kierowca z Twojej okolicy wkrótce oddzwoni pod ten numer. Do usłyszenia.
  </Say>
</Response>`;
      
      res.type('text/xml');
      res.send(twiml);
    } catch (error) {
      console.error("Error creating phone order with recording:", error);
      
      const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say language="pl-PL" voice="Polly.Ewa">
    Przepraszamy, wystąpił błąd. Spróbuj ponownie później.
  </Say>
</Response>`;
      
      res.type('text/xml');
      res.send(twiml);
    }
  });
  
  // Handle transcription complete - update address and notify nearby drivers
  app.post("/api/twilio/transcription-complete", async (req, res) => {
    console.log("=== TWILIO TRANSCRIPTION COMPLETE ===", req.body);
    
    const transcriptionText = req.body.TranscriptionText;
    const recordingSid = req.body.RecordingSid;
    const transcriptionStatus = req.body.TranscriptionStatus;
    
    if (transcriptionStatus !== "completed" || !transcriptionText) {
      console.log("Transcription failed or empty:", transcriptionStatus);
      return res.status(200).send("OK");
    }
    
    try {
      // Find the ride by recording SID stored in notes
      const allRides = await storage.getAllRides();
      const ride = allRides.find(r => r.notes?.includes(`RecordingSid:${recordingSid}`));
      
      if (!ride) {
        console.log(`No ride found for RecordingSid: ${recordingSid}`);
        return res.status(200).send("OK");
      }
      
      console.log(`Found ride ${ride.id} for transcription: "${transcriptionText}"`);
      
      // Try to geocode the address using Google Geocoding API
      let pickupLat: number | null = null;
      let pickupLng: number | null = null;
      let geocodedAddress = transcriptionText;
      
      const googleApiKey = process.env.GOOGLE_API_KEY;
      if (googleApiKey) {
        try {
          const geocodeUrl = `https://maps.googleapis.com/maps/api/geocode/json?address=${encodeURIComponent(transcriptionText + ", Polska")}&key=${googleApiKey}&language=pl`;
          const geocodeResponse = await fetch(geocodeUrl);
          const geocodeData = await geocodeResponse.json() as any;
          
          if (geocodeData.status === "OK" && geocodeData.results?.[0]) {
            const location = geocodeData.results[0].geometry.location;
            pickupLat = location.lat;
            pickupLng = location.lng;
            geocodedAddress = geocodeData.results[0].formatted_address || transcriptionText;
            console.log(`Geocoded address: ${geocodedAddress} -> ${pickupLat}, ${pickupLng}`);
          } else {
            console.log(`Geocoding failed for: ${transcriptionText}`, geocodeData.status);
          }
        } catch (geoError) {
          console.error("Geocoding error:", geoError);
        }
      }
      
      // Update ride with transcribed address and coordinates
      await db.update(rides)
        .set({ 
          pickupLocation: geocodedAddress,
          pickupLat: pickupLat ? pickupLat.toString() : null,
          pickupLng: pickupLng ? pickupLng.toString() : null,
          notes: null, // Clear recording reference
        })
        .where(eq(rides.id, ride.id));
      
      if (pickupLat && pickupLng) {
        await searchAndNotifyDrivers(ride.id, pickupLat, pickupLng, geocodedAddress, "Do ustalenia telefonicznie", null, "phone");
      } else {
        console.log(`[PROXIMITY_SKIP] ride_id=${ride.id}, reason=no_pickup_coordinates`);
      }
      
      res.status(200).send("OK");
    } catch (error) {
      console.error("Error processing transcription:", error);
      res.status(500).send("Error");
    }
  });

  // ============ MASKED CALLS (Ukryte numery) ============
  
  // Kierowca inicjuje połączenie do pasażera przez TaxiQ
  app.post("/api/driver/call/:rideId", async (req, res) => {
    try {
      const rideId = req.params.rideId;
      const driverId = (req.session as any).driverId;
      
      if (!driverId) {
        return res.status(401).json({ error: "Musisz być zalogowany jako kierowca" });
      }
      
      const driver = await storage.getDriver(driverId);
      if (!driver || !driver.phone) {
        return res.status(400).json({ error: "Brak numeru telefonu kierowcy w profilu" });
      }
      
      const ride = await storage.getRide(rideId);
      if (!ride) {
        return res.status(404).json({ error: "Zlecenie nie znalezione" });
      }
      
      if (!ride.callerPhone) {
        return res.status(400).json({ error: "Brak numeru telefonu pasażera" });
      }
      
      // Initialize Twilio client
      const accountSid = process.env.TWILIO_ACCOUNT_SID;
      const authToken = process.env.TWILIO_AUTH_TOKEN;
      const twilioNumber = "+48732125585"; // Nasz numer Twilio (PL)
      
      if (!accountSid || !authToken) {
        return res.status(500).json({ error: "Twilio nie skonfigurowane" });
      }
      
      const client = Twilio(accountSid, authToken);
      
      // Get base URL for webhook - use production domain
      const baseUrl = process.env.PUBLIC_BASE_URL || "https://taxiq.com.pl";
      
      const normalizedDriverPhone = normalizePolishPhone(driver.phone);
      const normalizedPassengerPhone = normalizePolishPhone(ride.callerPhone);

      console.log(`=== INITIATING MASKED CALL ===`);
      console.log(`Driver phone (raw): ${driver.phone} -> (normalized): ${normalizedDriverPhone}`);
      console.log(`Passenger phone (raw): ${ride.callerPhone} -> (normalized): ${normalizedPassengerPhone}`);
      console.log(`Webhook URL: ${baseUrl}/api/twilio/connect-to-passenger?passengerPhone=${encodeURIComponent(normalizedPassengerPhone)}`);
      
      if (normalizedDriverPhone === normalizedPassengerPhone) {
        console.log(`WARNING: Driver phone equals passenger phone after normalization!`);
        return res.status(400).json({ 
          error: "Nie można zadzwonić - numer kierowcy i pasażera są takie same." 
        });
      }
      
      const call = await client.calls.create({
        to: normalizedDriverPhone,
        from: twilioNumber,
        url: `${baseUrl}/api/twilio/connect-to-passenger?passengerPhone=${encodeURIComponent(normalizedPassengerPhone)}`,
        statusCallback: `${baseUrl}/api/twilio/call-status`,
        statusCallbackEvent: ['completed'],
      });
      
      console.log(`Masked call initiated: Driver ${driverId} -> Passenger (${normalizedPassengerPhone}), CallSID: ${call.sid}`);
      
      res.json({ 
        success: true, 
        message: "Połączenie inicjowane. Za chwilę zadzwonimy na Twój telefon.",
        callSid: call.sid 
      });
    } catch (error: any) {
      console.error("Error initiating masked call:", error);
      res.status(500).json({ error: error.message || "Nie udało się zainicjować połączenia" });
    }
  });

  // Webhook: Twilio dzwoni do kierowcy, ten odbiera i łączymy z pasażerem
  app.post("/api/twilio/connect-to-passenger", async (req, res) => {
    console.log("=== TWILIO CONNECT TO PASSENGER ===", req.query);
    
    const rawPassengerPhone = req.query.passengerPhone as string;
    
    if (!rawPassengerPhone) {
      const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say language="pl-PL" voice="Polly.Ewa">
    Błąd. Brak numeru pasażera.
  </Say>
</Response>`;
      res.type('text/xml');
      return res.send(twiml);
    }
    
    const passengerPhone = normalizePolishPhone(rawPassengerPhone);
    console.log(`Connecting to passenger: raw=${rawPassengerPhone}, normalized=${passengerPhone}`);
    
    const twiml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say language="pl-PL" voice="Polly.Ewa">
    Łączenie z klientem. Proszę czekać.
  </Say>
  <Dial callerId="+48732125585" timeout="30">
    <Number>${passengerPhone}</Number>
  </Dial>
  <Say language="pl-PL" voice="Polly.Ewa">
    Klient nie odebrał. Spróbuj ponownie później.
  </Say>
</Response>`;
    
    res.type('text/xml');
    res.send(twiml);
  });

  // Webhook: Status połączenia (opcjonalny, do logowania)
  app.post("/api/twilio/call-status", async (req, res) => {
    console.log("=== TWILIO CALL STATUS ===", req.body);
    res.sendStatus(200);
  });

  // ============ DRIVER AUTH ============
  app.post("/api/drivers/register", async (req, res) => {
    console.log("=== DRIVER REGISTER CALLED ===", req.body);
    try {
      const { firstName, lastName, phone: rawPhone, referralCode } = req.body;
      if (!firstName || !lastName || !rawPhone) {
        return res.status(400).json({ error: "Imię, nazwisko i numer telefonu są wymagane" });
      }

      const normalized = normalizePolishPhone(rawPhone);
      if (!/^\+48\d{9}$/.test(normalized)) {
        return res.status(400).json({ error: "Nieprawidłowy format numeru telefonu" });
      }

      const existingDriver = await storage.getDriverByUsername(normalized);
      if (existingDriver) {
        if (existingDriver.isActive === false) {
          await db.update(drivers).set({
            isActive: true,
            deletedAt: null,
            deactivationReason: null,
            deactivatedBy: null,
            name: `${firstName} ${lastName}`,
            firstName,
            lastName,
          }).where(eq(drivers.id, existingDriver.id));
          console.log(`[AUTH] Reactivated driver account during registration: ${normalized} (id: ${existingDriver.id})`);

          if (referralCode && typeof referralCode === 'string') {
            const referrer = await storage.getDriverByReferralCode(referralCode);
            if (referrer && referrer.id !== existingDriver.id) {
              await storage.createReferral({
                referrerDriverId: referrer.id,
                referredDriverId: existingDriver.id,
                referralType: 'driver',
                referralCode: referralCode,
              });
            }
          }

          const result = await requestAccess(normalized, false, "driver");
          return res.status(200).json({
            id: existingDriver.id,
            name: `${firstName} ${lastName}`,
            status: result.status,
            role: "driver",
            reactivated: true,
          });
        }
        return res.status(409).json({ error: "Ten numer telefonu jest już zarejestrowany jako kierowca" });
      }

      const name = `${firstName} ${lastName}`;
      const driver = await storage.createDriver({
        username: normalized,
        name,
        firstName,
        lastName,
        phone: normalized,
      });

      if (referralCode && typeof referralCode === 'string') {
        const referrer = await storage.getDriverByReferralCode(referralCode);
        if (referrer && referrer.id !== driver.id) {
          await storage.createReferral({
            referrerDriverId: referrer.id,
            referredDriverId: driver.id,
            referralType: 'driver',
            referralCode: referralCode,
          });
        }
      }

      const result = await requestAccess(normalized, false, "driver");
      console.log(`[AUTH] Driver registered: ${authMaskPhone(normalized)} (id: ${driver.id}), OTP sent`);
      
      res.status(201).json({ 
        id: driver.id, 
        name: driver.name,
        status: result.status,
        role: "driver",
      });
    } catch (error: any) {
      console.error("[REGISTER] Driver registration error:", error?.message);
      res.status(error?.statusCode || 500).json({ error: error?.message || "Nie udało się zarejestrować" });
    }
  });

  // Upload driver photo (requires authenticated driver session)
  // Uses Object Storage for permanent cloud storage
  app.post("/api/drivers/:id/photo", upload.single("photo"), async (req, res) => {
    try {
      const sessionDriverId = (req.session as any).driverId;
      const driverId = req.params.id as string;
      
      // Verify driver is authenticated and uploading their own photo
      if (!sessionDriverId || sessionDriverId !== driverId) {
        return res.status(401).json({ error: "Nieautoryzowany dostęp" });
      }
      
      if (!req.file) {
        return res.status(400).json({ error: "Brak pliku zdjęcia" });
      }
      
      // Get presigned URL from Object Storage
      const uploadUrl = await objectStorageService.getObjectEntityUploadURL();
      const objectPath = objectStorageService.normalizeObjectEntityPath(uploadUrl);
      
      // Read the uploaded file and send to Object Storage
      const fileBuffer = fs.readFileSync(req.file.path);
      const uploadResponse = await fetch(uploadUrl, {
        method: "PUT",
        body: fileBuffer,
        headers: {
          "Content-Type": req.file.mimetype,
        },
      });
      
      if (!uploadResponse.ok) {
        throw new Error("Failed to upload to Object Storage");
      }
      
      // Delete local temp file
      fs.unlinkSync(req.file.path);
      
      // Store the Object Storage path (served via /objects/* route)
      const photoUrl = objectPath;
      await db.update(drivers).set({ photoUrl, photoVerifiedAt: null }).where(eq(drivers.id, driverId));
      
      res.json({ photoUrl });
    } catch (error) {
      console.error("Error uploading driver photo:", error);
      res.status(500).json({ error: "Błąd podczas uploadu zdjęcia" });
    }
  });

  // Upload driver verification photo (requires authenticated driver session)
  // Verification photos stored in Object Storage (private)
  app.post("/api/drivers/:id/verification-photo", verificationUpload.single("photo"), async (req, res) => {
    try {
      const sessionDriverId = (req.session as any).driverId;
      const driverId = req.params.id as string;
      
      // Verify driver is authenticated and uploading their own photo
      if (!sessionDriverId || sessionDriverId !== driverId) {
        return res.status(401).json({ error: "Nieautoryzowany dostęp" });
      }
      
      if (!req.file) {
        return res.status(400).json({ error: "Brak pliku zdjęcia weryfikacyjnego" });
      }
      
      // Get presigned URL from Object Storage
      const uploadUrl = await objectStorageService.getObjectEntityUploadURL();
      const objectPath = objectStorageService.normalizeObjectEntityPath(uploadUrl);
      
      // Read the uploaded file and send to Object Storage
      const fileBuffer = fs.readFileSync(req.file.path);
      const uploadResponse = await fetch(uploadUrl, {
        method: "PUT",
        body: fileBuffer,
        headers: {
          "Content-Type": req.file.mimetype,
        },
      });
      
      if (!uploadResponse.ok) {
        throw new Error("Failed to upload to Object Storage");
      }
      
      // Delete local temp file
      fs.unlinkSync(req.file.path);
      
      // Store the Object Storage path
      const verificationPhotoUrl = objectPath;
      await db.update(drivers).set({ verificationPhotoUrl }).where(eq(drivers.id, driverId));
      
      res.json({ success: true, message: "Zdjęcie weryfikacyjne przesłane" });
    } catch (error) {
      console.error("Error uploading verification photo:", error);
      res.status(500).json({ error: "Błąd podczas uploadu zdjęcia weryfikacyjnego" });
    }
  });

  // Send email verification link
  // Store email verification codes temporarily (in production use Redis or database)
  const emailVerificationCodes = new Map<string, { code: string; expiresAt: number }>();
  
  // Helper to check if email verification is enabled
  async function isEmailVerificationEnabled(): Promise<boolean> {
    try {
      const result = await db.select().from(systemSettings).where(eq(systemSettings.settingKey, "email_verification_enabled"));
      return result.length > 0 && result[0].settingValue === "true";
    } catch {
      return false; // Default: disabled
    }
  }

  // Public endpoint to check if email verification is enabled
  app.get("/api/settings/email-verification-enabled", async (req, res) => {
    const enabled = await isEmailVerificationEnabled();
    res.json({ enabled });
  });

  app.post("/api/drivers/:id/send-email-verification", async (req, res) => {
    console.log("=== SEND EMAIL VERIFICATION CALLED ===");
    try {
      // Check if email verification is enabled
      const emailEnabled = await isEmailVerificationEnabled();
      if (!emailEnabled) {
        return res.status(400).json({ error: "Weryfikacja email jest obecnie wyłączona", disabled: true });
      }

      const sessionDriverId = (req.session as any).driverId;
      const urlDriverId = req.params.id as string;
      
      // Use session driverId or URL param - session takes priority for security
      const driverId = sessionDriverId || urlDriverId;
      
      console.log("Email verification:", { sessionDriverId, urlDriverId, usingId: driverId });
      
      if (!driverId) {
        return res.status(401).json({ error: "Nieautoryzowany dostęp" });
      }
      
      const driver = await storage.getDriver(driverId);
      if (!driver) {
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      
      if (!driver.email) {
        return res.status(400).json({ error: "Brak adresu email" });
      }
      
      if (driver.emailVerifiedAt) {
        return res.status(400).json({ error: "Email już zweryfikowany" });
      }
      
      // Generate 6-digit verification code
      const code = Math.floor(100000 + Math.random() * 900000).toString();
      
      // Store code with 10 minute expiration
      emailVerificationCodes.set(driverId, {
        code,
        expiresAt: Date.now() + 10 * 60 * 1000,
      });
      
      // Send email via Resend
      const resend = new Resend(process.env.RESEND_API_KEY);
      await resend.emails.send({
        from: "TaxiQ <noreply@taxiq.com.pl>",
        to: driver.email,
        subject: "Kod weryfikacyjny - TaxiQ",
        html: `
          <h2>Witaj ${driver.name}!</h2>
          <p>Twój kod weryfikacyjny to:</p>
          <h1 style="font-size:36px;letter-spacing:8px;background-color:#84cc16;color:#000;padding:16px 32px;display:inline-block;border-radius:8px;">${code}</h1>
          <p>Kod jest ważny przez 10 minut.</p>
          <p>Jeśli nie rejestrowałeś się w TaxiQ, zignoruj tę wiadomość.</p>
          <p>Pozdrawiamy,<br>Zespół TaxiQ</p>
        `,
      });
      
      console.log("Email verification code sent to:", driver.email);
      
      res.json({ success: true, message: "Kod weryfikacyjny wysłany na email" });
    } catch (error) {
      console.error("Error sending email verification:", error);
      res.status(500).json({ error: "Błąd wysyłania kodu weryfikacyjnego" });
    }
  });

  // Verify email code
  app.post("/api/drivers/:id/verify-email-code", async (req, res) => {
    try {
      const sessionDriverId = (req.session as any).driverId;
      const urlDriverId = req.params.id as string;
      const { code } = req.body;
      
      const driverId = sessionDriverId || urlDriverId;
      
      console.log("Email code verification:", { sessionDriverId, urlDriverId, usingId: driverId, code });
      
      if (!driverId) {
        return res.status(401).json({ error: "Nieautoryzowany dostęp" });
      }
      
      if (!code || code.length !== 6) {
        return res.status(400).json({ error: "Nieprawidłowy kod weryfikacyjny" });
      }
      
      const driver = await storage.getDriver(driverId);
      if (!driver) {
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      
      if (!driver.email) {
        return res.status(400).json({ error: "Brak adresu email" });
      }
      
      // Check stored verification code
      const storedCode = emailVerificationCodes.get(driverId);
      
      if (!storedCode) {
        return res.status(400).json({ error: "Brak kodu weryfikacyjnego. Wyślij nowy kod." });
      }
      
      if (Date.now() > storedCode.expiresAt) {
        emailVerificationCodes.delete(driverId);
        return res.status(400).json({ error: "Kod wygasł. Wyślij nowy kod." });
      }
      
      if (storedCode.code !== code) {
        return res.status(400).json({ error: "Nieprawidłowy kod weryfikacyjny" });
      }
      
      // Code is valid - update driver
      emailVerificationCodes.delete(driverId);
      await db.update(drivers).set({ emailVerifiedAt: new Date() }).where(eq(drivers.id, driverId));
      
      console.log("Email verified for driver:", driverId);
      res.json({ success: true, message: "Email zweryfikowany" });
    } catch (error) {
      console.error("Error verifying email code:", error);
      res.status(500).json({ error: "Błąd weryfikacji kodu" });
    }
  });

  // Send phone verification SMS
  app.post("/api/drivers/:id/send-phone-verification", async (req, res) => {
    console.log("=== SEND PHONE VERIFICATION CALLED ===");
    try {
      const sessionDriverId = (req.session as any).driverId;
      const urlDriverId = req.params.id as string;
      
      // Use session driverId or URL param - session takes priority for security
      const driverId = sessionDriverId || urlDriverId;
      
      console.log("Phone verification:", { sessionDriverId, urlDriverId, usingId: driverId });
      
      if (!driverId) {
        return res.status(401).json({ error: "Nieautoryzowany dostęp" });
      }
      
      const driver = await storage.getDriver(driverId);
      if (!driver) {
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      
      if (!driver.phone) {
        return res.status(400).json({ error: "Brak numeru telefonu" });
      }
      
      if (driver.phoneVerifiedAt) {
        return res.status(400).json({ error: "Telefon już zweryfikowany" });
      }
      
      // Send SMS via Twilio Verify API
      const accountSid = process.env.TWILIO_ACCOUNT_SID;
      const authToken = process.env.TWILIO_AUTH_TOKEN;
      const verifyServiceSid = process.env.TWILIO_VERIFY_SERVICE_SID;
      
      if (!accountSid || !authToken || !verifyServiceSid) {
        console.error("[SMS] Twilio credentials missing:", { 
          hasAccountSid: !!accountSid, 
          hasAuthToken: !!authToken, 
          hasVerifyServiceSid: !!verifyServiceSid 
        });
        return res.status(500).json({ error: "Usługa SMS nie jest skonfigurowana. Skontaktuj się z administratorem." });
      }
      
      // Normalize phone to E.164 format (remove spaces, dashes, parentheses)
      let normalizedPhone = driver.phone.replace(/[\s\-\(\)]/g, "");
      // Ensure it starts with + for international format
      if (!normalizedPhone.startsWith("+")) {
        // Assume Polish number if no country code
        if (normalizedPhone.startsWith("48")) {
          normalizedPhone = "+" + normalizedPhone;
        } else if (normalizedPhone.startsWith("0")) {
          normalizedPhone = "+48" + normalizedPhone.slice(1);
        } else {
          normalizedPhone = "+48" + normalizedPhone;
        }
      }
      
      console.log("[SMS] Sending verification to:", normalizedPhone, "(original:", driver.phone, ")");
      
      try {
        const twilioResponse = await fetch(
          `https://verify.twilio.com/v2/Services/${verifyServiceSid}/Verifications`,
          {
            method: "POST",
            headers: {
              "Authorization": "Basic " + Buffer.from(`${accountSid}:${authToken}`).toString("base64"),
              "Content-Type": "application/x-www-form-urlencoded",
            },
            body: new URLSearchParams({
              To: normalizedPhone,
              Channel: "sms",
            }),
          }
        );
        
        const twilioData = await twilioResponse.json();
        console.log("[SMS] Twilio Verify response:", JSON.stringify(twilioData));
        
        if (!twilioResponse.ok) {
          console.error("[SMS] Twilio error:", JSON.stringify(twilioData));
          let userMessage = "Błąd wysyłania SMS. ";
          if (twilioData.code === 60200) {
            userMessage += "Nieprawidłowy numer telefonu. Sprawdź numer w profilu.";
          } else if (twilioData.code === 60203) {
            userMessage += "Przekroczono limit prób. Spróbuj ponownie za 10 minut.";
          } else if (twilioData.code === 60205) {
            userMessage += "SMS nie może być wysłany na ten numer. Sprawdź numer telefonu.";
          } else {
            userMessage += twilioData.message || "Spróbuj ponownie później.";
          }
          return res.status(500).json({ error: userMessage });
        }
        
        res.json({ success: true, message: "Kod weryfikacyjny wysłany na telefon" });
      } catch (twilioError) {
        console.error("[SMS] Twilio API connection error:", twilioError);
        return res.status(500).json({ error: "Błąd połączenia z usługą SMS. Sprawdź połączenie internetowe." });
      }
    } catch (error) {
      console.error("Error sending phone verification:", error);
      res.status(500).json({ error: "Błąd wysyłania SMS" });
    }
  });
  
  // Verify phone code endpoint
  app.post("/api/drivers/:id/verify-phone-code", async (req, res) => {
    try {
      const sessionDriverId = (req.session as any).driverId;
      const urlDriverId = req.params.id as string;
      const { code } = req.body;
      
      const driverId = sessionDriverId || urlDriverId;
      
      console.log("Verify phone code:", { sessionDriverId, urlDriverId, usingId: driverId, code });
      
      if (!driverId) {
        return res.status(401).json({ error: "Nieautoryzowany dostęp" });
      }
      
      if (!code || code.length !== 6) {
        return res.status(400).json({ error: "Nieprawidłowy kod weryfikacyjny" });
      }
      
      const driver = await storage.getDriver(driverId);
      if (!driver) {
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      
      if (driver.phoneVerifiedAt) {
        return res.status(400).json({ error: "Telefon już zweryfikowany" });
      }
      
      // Verify code via Twilio Verify API
      const accountSid = process.env.TWILIO_ACCOUNT_SID;
      const authToken = process.env.TWILIO_AUTH_TOKEN;
      const verifyServiceSid = process.env.TWILIO_VERIFY_SERVICE_SID;
      
      if (!accountSid || !authToken || !verifyServiceSid) {
        return res.status(500).json({ error: "Usługa SMS nie jest skonfigurowana" });
      }
      
      // Normalize phone to E.164 format (must match what was used in send-phone-verification)
      let normalizedPhone = driver.phone!.replace(/[\s\-\(\)]/g, "");
      if (!normalizedPhone.startsWith("+")) {
        if (normalizedPhone.startsWith("48")) {
          normalizedPhone = "+" + normalizedPhone;
        } else if (normalizedPhone.startsWith("0")) {
          normalizedPhone = "+48" + normalizedPhone.slice(1);
        } else {
          normalizedPhone = "+48" + normalizedPhone;
        }
      }
      
      console.log("[SMS] Verifying code for:", normalizedPhone);
      
      try {
        const twilioResponse = await fetch(
          `https://verify.twilio.com/v2/Services/${verifyServiceSid}/VerificationCheck`,
          {
            method: "POST",
            headers: {
              "Authorization": "Basic " + Buffer.from(`${accountSid}:${authToken}`).toString("base64"),
              "Content-Type": "application/x-www-form-urlencoded",
            },
            body: new URLSearchParams({
              To: normalizedPhone,
              Code: code,
            }),
          }
        );
        
        const twilioData = await twilioResponse.json();
        console.log("[SMS] Twilio VerificationCheck response:", JSON.stringify(twilioData));
        
        if (!twilioResponse.ok || twilioData.status !== "approved") {
          return res.status(400).json({ error: "Nieprawidłowy kod weryfikacyjny" });
        }
        
        // Update phone verification status
        await db.update(drivers).set({ phoneVerifiedAt: new Date() }).where(eq(drivers.id, driverId));
        
        res.json({ success: true, message: "Telefon zweryfikowany pomyślnie" });
      } catch (twilioError) {
        console.error("Twilio API error:", twilioError);
        return res.status(500).json({ error: "Błąd weryfikacji kodu" });
      }
    } catch (error) {
      console.error("Error verifying phone code:", error);
      res.status(500).json({ error: "Błąd weryfikacji kodu" });
    }
  });
  
  // Accept terms endpoint
  app.post("/api/drivers/:id/accept-terms", async (req, res) => {
    try {
      const sessionDriverId = (req.session as any).driverId;
      const urlDriverId = req.params.id as string;
      
      // Use session driverId or URL param - session takes priority for security
      const driverId = sessionDriverId || urlDriverId;
      
      console.log("Accept terms:", { sessionDriverId, urlDriverId, usingId: driverId });
      
      if (!driverId) {
        return res.status(401).json({ error: "Nieautoryzowany dostęp" });
      }
      
      const driver = await storage.getDriver(driverId);
      if (!driver) {
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      
      await db.update(drivers).set({ termsAcceptedAt: new Date() }).where(eq(drivers.id, driverId));
      
      res.json({ success: true, message: "Regulamin zaakceptowany" });
    } catch (error) {
      console.error("Error accepting terms:", error);
      res.status(500).json({ error: "Błąd akceptacji regulaminu" });
    }
  });
  
  // Admin-only endpoint to get verification photo
  app.get("/api/admin/drivers/:id/verification-photo", async (req, res) => {
    try {
      const adminId = (req.session as any).adminId;
      if (!adminId) {
        return res.status(401).json({ error: "Unauthorized" });
      }
      
      const driverId = req.params.id as string;
      const driver = await storage.getDriver(driverId);
      
      if (!driver || !driver.verificationPhotoUrl) {
        return res.status(404).json({ error: "Zdjęcie weryfikacyjne nie znalezione" });
      }
      
      try {
        const objectFile = await objectStorageService.getObjectEntityFile(driver.verificationPhotoUrl);
        await objectStorageService.downloadObject(objectFile, res, 0);
      } catch (objError: any) {
        if (objError?.name === "ObjectNotFoundError") {
          return res.status(404).json({ error: "Plik nie istnieje w chmurze" });
        }
        throw objError;
      }
    } catch (error) {
