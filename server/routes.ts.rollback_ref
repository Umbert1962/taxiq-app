  // Get driver public profile (for passengers - limited info)
  app.get("/api/drivers/:id/profile", async (req, res) => {
    try {
      const driverId = req.params.id as string;
      const driver = await storage.getDriver(driverId);
      
      if (!driver) {
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      
      // Check if requester is the driver themselves (can see more info)
      const sessionDriverId = (req.session as any).driverId;
      const isOwner = sessionDriverId === driverId;
      
      // Return public info for passengers, full info for driver themselves
      res.json({
        id: driver.id,
        name: driver.name,
        firstName: driver.firstName,
        lastName: driver.lastName,
        phone: isOwner ? driver.phone : undefined, // Phone only visible to driver
        email: isOwner ? driver.email : undefined, // Email only visible to driver
        vehiclePlate: driver.vehiclePlate,
        vehicleModel: driver.vehicleModel,
        vehicleColor: driver.vehicleColor,
        taxiLicenseNumber: driver.taxiLicenseNumber,
        photoUrl: driver.photoUrl,
        languages: driver.languages,
        photoVerifiedAt: driver.photoVerifiedAt ? true : false, // Just boolean, not timestamp
        phoneVerifiedAt: isOwner ? driver.phoneVerifiedAt : undefined, // Only visible to driver
        emailVerifiedAt: isOwner ? driver.emailVerifiedAt : undefined, // Only visible to driver
        termsAcceptedAt: isOwner ? driver.termsAcceptedAt : undefined, // Only visible to driver
        createdAt: isOwner ? driver.createdAt : undefined, // Only show to driver themselves
      });
