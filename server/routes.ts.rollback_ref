  app.post("/api/drivers/login", async (req, res) => {
    const clientIp = req.ip || req.socket.remoteAddress || 'unknown';
    if (!checkLoginRateLimit(clientIp)) {
      return res.status(429).json({ error: "Zbyt wiele prób logowania. Spróbuj ponownie za 5 minut." });
    }
    console.log(`[LOGIN] POST /api/drivers/login | ip: ${clientIp} | ts: ${new Date().toISOString()}`);
    try {
      let { username, password } = req.body;
      if (!username || !password) {
        return res.status(400).json({ error: "Login i hasło są wymagane" });
      }
      // Normalize phone number for login lookup
      let normalized = username.replace(/[\s\-\(\)]/g, "");
      if (normalized && !normalized.startsWith("+")) {
        if (normalized.startsWith("48") && normalized.length === 11) {
          normalized = "+" + normalized;
        } else if (normalized.startsWith("0")) {
          normalized = "+48" + normalized.slice(1);
        } else if (normalized.length === 9) {
          normalized = "+48" + normalized;
        }
      }
      username = normalized;
      console.log("[DIAG] /api/drivers/login - DB lookup for:", username);
      const driver = await storage.getDriverByUsername(username);
      console.log("[DIAG] /api/drivers/login - DB result:", driver ? `found (id=${driver.id})` : "NOT FOUND");
      
      if (!driver) {
        recordFailedAttempt(clientIp);
        return res.status(401).json({ error: "Nieprawidłowy login lub hasło" });
      }
      
      // Check if driver is blocked
      if (driver.isBlocked) {
        return res.status(403).json({ 
          error: "Konto zablokowane", 
          reason: driver.blockedReason || "Twoje konto zostało zablokowane. Skontaktuj się z administratorem.",
          blocked: true
        });
      }
      
      // Check password - try plain text first, then bcrypt hash
      let passwordValid = driver.password === password;
      if (!passwordValid && driver.password?.startsWith('$2')) {
        // Password is hashed, verify with bcrypt
        passwordValid = await verifyPassword(password, driver.password);
      }
      
      if (!passwordValid) {
        recordFailedAttempt(clientIp);
        return res.status(401).json({ error: "Nieprawidłowy login lub hasło" });
      }

      resetLoginAttempts(clientIp);
      
      // SINGLE SESSION ENFORCEMENT: Remove all previous sessions for this driver
      console.log("[DIAG] /api/drivers/login - Invalidating old sessions for:", driver.id);
      await storage.invalidateDriverSessions(driver.id);
      console.log("[DIAG] /api/drivers/login - Sessions invalidated OK");
      
      // AUTO ONLINE: Set driver as online upon login (only if verified)
      console.log("[DIAG] /api/drivers/login - Setting online status...");
      if (driver.verificationStatus === "approved_auto" && driver.cityDriverId && driver.verificationCheckedAt) {
        await storage.updateDriverOnlineStatus(driver.id, true);
        console.log(`[GATE] /api/drivers/login - Auto-online OK for driver ${driver.id} (approved_auto + cityDriverId + verificationCheckedAt)`);
      } else {
        console.log(`[GATE] /api/drivers/login - BLOCKED auto-online for driver ${driver.id}: status=${driver.verificationStatus}, cityDriverId=${driver.cityDriverId || 'NULL'}, verificationCheckedAt=${driver.verificationCheckedAt || 'NULL'}`);
      }
      
      // Save GPS coordinates if provided in login request
      const { lat, lng } = req.body;
      if (typeof lat === 'number' && typeof lng === 'number') {
        console.log(`[DIAG] /api/drivers/login - Saving GPS: ${lat}, ${lng}`);
        await storage.updateDriverGpsLocation(driver.id, lat, lng);
        console.log("[DIAG] /api/drivers/login - GPS saved OK");
      } else {
        console.log("[DIAG] /api/drivers/login - No GPS in request body");
      }
      
      // Save driver session
      req.session.driverId = driver.id;
      req.session.driverName = driver.firstName ? `${driver.firstName} ${driver.lastName || ''}`.trim() : driver.name;
      req.session.driverLastActivity = Date.now(); // Initialize activity timestamp
      
      // Explicitly save session before responding (critical for PWA)
      console.log("[DIAG] /api/drivers/login - Saving session, sessionID:", req.sessionID);
      req.session.save((err) => {
        if (err) {
          console.error("[DIAG] /api/drivers/login - SESSION SAVE ERROR:", err?.message, err?.stack);
          return res.status(500).json({ error: "Błąd sesji" });
        }
        console.log("[DIAG] /api/drivers/login - SUCCESS, sessionID:", req.sessionID, "cookie:", JSON.stringify(req.session.cookie));
        res.json({ 
          id: driver.id, 
          name: driver.name, 
          firstName: driver.firstName,
          lastName: driver.lastName,
          username: driver.username,
          phone: driver.phone,
          vehiclePlate: driver.vehiclePlate,
          vehicleModel: driver.vehicleModel,
          vehicleColor: driver.vehicleColor,
          languages: driver.languages || [],
          rating: driver.rating,
          totalRides: driver.totalRides,
          totalEarnings: driver.totalEarnings,
          isOnline: true,
          profileCompleted: isDriverProfileComplete(driver)
        });
      });
    } catch (error: any) {
      console.error("[DIAG] /api/drivers/login - EXCEPTION:", error?.message);
      console.error("[DIAG] /api/drivers/login - Stack:", error?.stack);
      res.status(500).json({ error: "Logowanie nie powiodło się" });
    }
  });

  // Get current driver session
  app.get("/api/drivers/session", async (req, res) => {
    console.log("[PWA DEBUG] Driver session check:", {
