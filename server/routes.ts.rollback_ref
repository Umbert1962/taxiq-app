  // ============= UNIFIED AUTH (Phone + OTP + PIN for all roles) =============

  function setSessionByRole(req: Request, role: AuthRole, userId: string, extra?: Record<string, any>) {
    switch (role) {
      case "admin":
        (req.session as any).adminId = userId;
        (req.session as any).adminRole = extra?.adminRole || "admin";
        break;
      case "driver":
        (req.session as any).driverId = userId;
        if (extra?.driverName) (req.session as any).driverName = extra.driverName;
        break;
      case "passenger":
        (req.session as any).passengerId = userId;
        if (extra?.passengerName) (req.session as any).passengerName = extra.passengerName;
        (req.session as any).passengerLastActivity = Date.now();
        break;
    }
  }

  app.post("/auth/request-access", async (req, res) => {
    const ts = new Date().toISOString();
    try {
      const { phone, role } = req.body;
      if (!phone) return res.status(400).json({ error: "Numer telefonu jest wymagany" });

      const result = await requestAccess(phone, role === "passenger", role || undefined);
      const normalized = normalizePolishPhone(phone);
      console.log(`[AUDIT] AUTH_REQUEST_ACCESS | ts: ${ts} | result: ${result.status} | role: ${result.role} | userId: ${result.userId} | phone: ${authMaskPhone(normalized)}`);
      res.json({ status: result.status, role: result.role });
    } catch (error: any) {
      const statusCode = error instanceof AuthError ? error.statusCode : 500;
      const message = error instanceof AuthError ? error.message : "Błąd serwera";
      console.log(`[AUDIT] AUTH_REQUEST_ACCESS | ts: ${ts} | result: ERROR | error: ${error?.message}`);
      res.status(statusCode).json({ error: message });
    }
  });

  app.post("/auth/verify-otp", async (req, res) => {
    const ts = new Date().toISOString();
    try {
      const { phone, otp, role } = req.body;
      if (!phone || !otp) return res.status(400).json({ error: "Numer telefonu i kod OTP są wymagane" });

      const result = await verifyOtp(phone, otp, role || undefined);
      (req.session as any).otpVerifiedUserId = result.userId;

      console.log(`[AUDIT] AUTH_VERIFY_OTP | ts: ${ts} | result: SUCCESS | role: ${result.role} | userId: ${result.userId}`);
      res.json({ status: result.status, role: result.role });
    } catch (error: any) {
      const statusCode = error instanceof AuthError ? error.statusCode : 500;
      const message = error instanceof AuthError ? error.message : "Błąd serwera";
      console.log(`[AUDIT] AUTH_VERIFY_OTP | ts: ${ts} | result: ERROR | error: ${error?.message}`);
      res.status(statusCode).json({ error: message });
    }
  });

  app.post("/auth/set-pin", async (req, res) => {
    const ts = new Date().toISOString();
    try {
      const { phone, pin, role } = req.body;
      if (!phone || !pin) return res.status(400).json({ error: "Numer telefonu i PIN są wymagane" });

      const verifiedUserId = (req.session as any).otpVerifiedUserId;
      if (!verifiedUserId) {
        return res.status(403).json({ error: "Najpierw zweryfikuj kod OTP" });
      }

      const result = await setPin(phone, pin, verifiedUserId, role || undefined);
      delete (req.session as any).otpVerifiedUserId;

      await invalidateSessionsByRole(result.role, result.userId);

      if (result.role === "admin") {
        const admin = await storage.getAdmin(result.userId);
        setSessionByRole(req, result.role, result.userId, { adminRole: admin?.role });
      } else if (result.role === "driver") {
        const driver = await storage.getDriver(result.userId);
        if (driver) {
          if (driver.verificationStatus === "approved_auto" && driver.cityDriverId && driver.verificationCheckedAt) {
            await storage.updateDriverOnlineStatus(driver.id, true);
            console.log(`[GATE] /auth/set-pin - Auto-online OK for driver ${driver.id}`);
          } else {
            console.log(`[GATE] /auth/set-pin BLOCKED auto-online for driver ${driver.id}: status=${driver.verificationStatus}, cityDriverId=${driver.cityDriverId || 'NULL'}, verificationCheckedAt=${driver.verificationCheckedAt || 'NULL'}`);
          }
          setSessionByRole(req, result.role, result.userId, { driverName: driver.name });
        }
      } else {
        const user = await storage.getUser(result.userId);
        if (user) {
          await storage.setUserOnline(user.id, true);
          setSessionByRole(req, result.role, result.userId, { passengerName: result.name });
        }
      }

      req.session.save((err) => {
        if (err) {
          console.error(`[AUDIT] AUTH_SET_PIN | ts: ${ts} | result: SESSION_ERROR`);
          return res.status(500).json({ error: "Błąd sesji" });
        }
        console.log(`[AUDIT] AUTH_SET_PIN | ts: ${ts} | result: SUCCESS | role: ${result.role} | userId: ${result.userId}`);
        res.json({ status: "PIN_SET", role: result.role, name: result.name });
      });
    } catch (error: any) {
      const statusCode = error instanceof AuthError ? error.statusCode : 500;
      const message = error instanceof AuthError ? error.message : "Błąd serwera";
      console.log(`[AUDIT] AUTH_SET_PIN | ts: ${ts} | result: ERROR | error: ${error?.message}`);
      res.status(statusCode).json({ error: message });
    }
  });

  app.post("/auth/login", async (req, res) => {
    const ts = new Date().toISOString();
    const clientIp = req.ip || req.socket.remoteAddress || 'unknown';
    try {
      const { phone, pin, role } = req.body;
      if (!phone || !pin) return res.status(400).json({ error: "Numer telefonu i PIN są wymagane" });

      const result = await loginWithPin(phone, pin, role || undefined);
      await invalidateSessionsByRole(result.role, result.userId);

      if (result.role === "admin") {
        const admin = await storage.getAdmin(result.userId);
        setSessionByRole(req, result.role, result.userId, { adminRole: admin?.role });
      } else if (result.role === "driver") {
        const driver = await storage.getDriver(result.userId);
        if (driver) {
          if (driver.verificationStatus === "approved_auto" && driver.cityDriverId && driver.verificationCheckedAt) {
            await storage.updateDriverOnlineStatus(driver.id, true);
            const { lat, lng } = req.body;
            if (typeof lat === 'number' && typeof lng === 'number') {
              await storage.updateDriverGpsLocation(driver.id, lat, lng);
            }
            console.log(`[GATE] /auth/login - Auto-online OK for driver ${driver.id}`);
          } else {
            console.log(`[GATE] /auth/login BLOCKED auto-online for driver ${driver.id}: status=${driver.verificationStatus}, cityDriverId=${driver.cityDriverId || 'NULL'}, verificationCheckedAt=${driver.verificationCheckedAt || 'NULL'}`);
          }
          setSessionByRole(req, result.role, result.userId, { driverName: driver.name });
        }
      } else {
        const user = await storage.getUser(result.userId);
        if (user) {
          await storage.setUserOnline(user.id, true);
          setSessionByRole(req, result.role, result.userId, { passengerName: result.name });
        }
      }

      req.session.save((err) => {
        if (err) {
          console.error(`[AUDIT] AUTH_LOGIN | ts: ${ts} | ip: ${clientIp} | result: SESSION_ERROR`);
          return res.status(500).json({ error: "Błąd sesji" });
        }
        console.log(`[AUDIT] AUTH_LOGIN | ts: ${ts} | ip: ${clientIp} | result: SUCCESS | role: ${result.role} | userId: ${result.userId}`);
        res.json({ role: result.role, name: result.name });
      });
    } catch (error: any) {
      const statusCode = error instanceof AuthError ? error.statusCode : 500;
      const message = error instanceof AuthError ? error.message : "Błąd serwera";
      console.log(`[AUDIT] AUTH_LOGIN | ts: ${ts} | ip: ${clientIp} | result: ERROR | error: ${error?.message}`);
      res.status(statusCode).json({ error: message });
    }
  });

  app.post("/auth/forgot-pin", async (req, res) => {
    const ts = new Date().toISOString();
    try {
