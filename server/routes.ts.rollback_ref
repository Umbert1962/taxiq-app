  const promoVideoUpload = multer({
    storage: multer.diskStorage({
      destination: tmpDir,
      filename: (_req, file, cb) => {
        const uniqueName = `promo-video-${Date.now()}${path.extname(file.originalname)}`;
        cb(null, uniqueName);
      },
    }),
    limits: { fileSize: 20 * 1024 * 1024 },
    fileFilter: (_req, file, cb) => {
      if (file.mimetype !== "video/mp4") {
        cb(new Error("Dozwolony format wideo: MP4 (H.264)"));
      } else {
        cb(null, true);
      }
    },
  });

  const promoImageUpload = multer({
    storage: multer.diskStorage({
      destination: tmpDir,
      filename: (_req, file, cb) => {
        const uniqueName = `promo-img-${Date.now()}${path.extname(file.originalname)}`;
        cb(null, uniqueName);
      },
    }),
    limits: { fileSize: 1 * 1024 * 1024 },
    fileFilter: (_req, file, cb) => {
      const allowed = /jpeg|jpg|png|webp/;
      const extOk = allowed.test(path.extname(file.originalname).toLowerCase());
      const mimeOk = allowed.test(file.mimetype);
      if (extOk && mimeOk) {
        cb(null, true);
      } else {
        cb(new Error("Dozwolony format obrazu: JPG, PNG lub WebP"));
      }
    },
  });

  function probeMedia(filePath: string): Promise<{ width: number; height: number; codec?: string }> {
    const { execSync } = require("child_process");
    try {
      const result = execSync(
        `ffprobe -v error -select_streams v:0 -show_entries stream=width,height,codec_name -of json "${filePath}"`,
        { timeout: 10000 }
      ).toString();
      const parsed = JSON.parse(result);
      const stream = parsed.streams?.[0] || {};
      return Promise.resolve({
        width: stream.width || 0,
        height: stream.height || 0,
        codec: stream.codec_name || "",
      });
    } catch {
      return Promise.resolve({ width: 0, height: 0 });
    }
  }

  app.post("/api/admin/promo-video", promoVideoUpload.single("video"), async (req, res) => {
    try {
      if (!req.file) {
        return res.status(400).json({ error: "Nie przesłano pliku wideo" });
      }
      const fullPath = req.file.path;
      const meta = await probeMedia(fullPath);

      if (meta.codec && meta.codec !== "h264") {
        fs.unlinkSync(fullPath);
        return res.status(400).json({ error: "Wymagany kodek wideo: H.264" });
      }
      if (meta.width > 1920 || meta.height > 1080) {
        fs.unlinkSync(fullPath);
        return res.status(400).json({ error: "Maksymalna rozdzielczość: 1920x1080" });
      }
      if (meta.width > 0 && meta.height > 0) {
        const ratio = meta.width / meta.height;
        if (Math.abs(ratio - 16 / 9) > 0.05) {
          fs.unlinkSync(fullPath);
          return res.status(400).json({ error: "Wymagany format wideo: 16:9" });
        }
      }

      const uploadUrl = await objectStorageService.getObjectEntityUploadURL();
      const objectPath = objectStorageService.normalizeObjectEntityPath(uploadUrl);
      const fileBuffer = fs.readFileSync(fullPath);
      const uploadResponse = await fetch(uploadUrl, {
        method: "PUT",
        body: fileBuffer,
        headers: { "Content-Type": req.file.mimetype },
      });
      if (!uploadResponse.ok) {
        throw new Error("Failed to upload to Object Storage");
      }
      fs.unlinkSync(fullPath);
      res.json({ url: objectPath });
    } catch (error: any) {
      res.status(400).json({ error: error.message || "Błąd przesyłania wideo" });
    }
  });

  app.post("/api/admin/promo-image", promoImageUpload.single("image"), async (req, res) => {
    try {
      if (!req.file) {
        return res.status(400).json({ error: "Nie przesłano obrazu" });
      }
      const fullPath = req.file.path;
      const meta = await probeMedia(fullPath);

      if (meta.width > 0 && meta.height > 0) {
        const ratio = meta.width / meta.height;
        const validRatio = [1, 4 / 3].some((ar) => Math.abs(ratio - ar) < 0.05);
        if (!validRatio) {
          fs.unlinkSync(fullPath);
          return res.status(400).json({ error: "Wymagany format obrazu: 1:1 lub 4:3" });
        }
      }

      const uploadUrl = await objectStorageService.getObjectEntityUploadURL();
      const objectPath = objectStorageService.normalizeObjectEntityPath(uploadUrl);
      const fileBuffer = fs.readFileSync(fullPath);
      const uploadResponse = await fetch(uploadUrl, {
        method: "PUT",
        body: fileBuffer,
        headers: { "Content-Type": req.file.mimetype },
      });
      if (!uploadResponse.ok) {
        throw new Error("Failed to upload to Object Storage");
      }
      fs.unlinkSync(fullPath);
      res.json({ url: objectPath });
    } catch (error: any) {
      res.status(400).json({ error: error.message || "Błąd przesyłania obrazu" });
    }
  });

  // ==================== CONTACT FORM ====================

  const contactSchema = z.object({
    name: z.string().min(1).max(200),
    email: z.string().email().max(200),
    message: z.string().min(1).max(5000),
  });

  app.post("/api/contact", async (req, res) => {
    try {
      const parsed = contactSchema.safeParse(req.body);
      if (!parsed.success) {
        return res.status(400).json({ error: "Wszystkie pola są wymagane" });
      }
      const { name, email, message } = parsed.data;

      const resendApiKey = process.env.RESEND_API_KEY;
      if (!resendApiKey) {
        console.error("RESEND_API_KEY not configured");
        return res.status(500).json({ error: "Email service not configured" });
      }

      const resend = new Resend(resendApiKey);
      await resend.emails.send({
        from: "TaxiQ <noreply@taxiq.com.pl>",
        to: "taxiq1@icloud.com",
        subject: `Kontakt TaxiQ - ${name}`,
        html: `
          <h2>Nowa wiadomość z formularza kontaktowego TaxiQ</h2>
          <p><strong>Imię:</strong> ${name}</p>
          <p><strong>Email:</strong> ${email}</p>
          <p><strong>Wiadomość:</strong></p>
          <p>${message.replace(/\n/g, "<br>")}</p>
        `,
        replyTo: email,
      });

      res.json({ success: true });
    } catch (error) {
      console.error("Error sending contact email:", error);
      res.status(500).json({ error: "Nie udało się wysłać wiadomości" });
    }
  });

