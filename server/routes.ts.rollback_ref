  app.post("/auth/admin/login", async (req, res) => {
    const { phone, pin } = req.body;
    if (!phone || !pin) return res.status(400).json({ error: "Numer telefonu i PIN są wymagane" });
    try {
      const result = await loginWithPin(phone, pin, "admin");
      if (result.role !== "admin") return res.status(401).json({ error: "Nieprawidłowy numer lub PIN" });
      await invalidateSessionsByRole("admin", result.userId);
      const admin = await storage.getAdmin(result.userId);
      setSessionByRole(req, "admin", result.userId, { adminRole: admin?.role });
      req.session.save(() => res.json({ id: result.userId, username: admin?.username, name: result.name, role: admin?.role }));
    } catch (error: any) {
