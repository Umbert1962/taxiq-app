  // Admin upload driver photo
  app.post("/api/admin/drivers/:id/upload-photo", requireAdmin, upload.single("photo"), async (req, res) => {
    try {
      const driverId = String(req.params.id);
      if (!req.file) {
        return res.status(400).json({ error: "Brak pliku zdjęcia" });
      }
      const [driver] = await db.select().from(drivers).where(eq(drivers.id, driverId));
      if (!driver) {
        fs.unlinkSync(req.file.path);
        return res.status(404).json({ error: "Kierowca nie znaleziony" });
      }
      const uploadUrl = await objectStorageService.getObjectEntityUploadURL();
      const objectPath = objectStorageService.normalizeObjectEntityPath(uploadUrl);
      const fileBuffer = fs.readFileSync(req.file.path);
      const uploadResponse = await fetch(uploadUrl, {
        method: "PUT",
        body: fileBuffer,
        headers: { "Content-Type": req.file.mimetype },
      });
      if (!uploadResponse.ok) {
        throw new Error("Failed to upload to Object Storage");
      }
      fs.unlinkSync(req.file.path);
      const photoUrl = objectPath;
      await db.update(drivers).set({ photoUrl }).where(eq(drivers.id, driverId));
      res.json({ photoUrl });
    } catch (error) {
      console.error("Error uploading driver photo (admin):", error);
      if (req.file && fs.existsSync(req.file.path)) {
        fs.unlinkSync(req.file.path);
      }
      res.status(500).json({ error: "Błąd podczas uploadu zdjęcia" });
    }
  });

  // Admin change own password
  app.post("/api/admin/change-password", requireAdmin, async (req, res) => {
    try {
      const adminId = (req.session as any).adminId;
      const { currentPassword, newPassword } = req.body;
      if (!currentPassword || !newPassword) {
        return res.status(400).json({ error: "Podaj aktualne i nowe hasło" });
      }
      if (newPassword.length < 4) {
        return res.status(400).json({ error: "Nowe hasło musi mieć minimum 4 znaki" });
      }
      const [admin] = await db.select().from(admins).where(eq(admins.id, adminId));
      if (!admin) {
        return res.status(404).json({ error: "Admin nie znaleziony" });
      }
      let passwordValid = admin.password === currentPassword;
      if (!passwordValid && admin.password?.startsWith('$2')) {
        passwordValid = await verifyPassword(currentPassword, admin.password);
      }
      if (!passwordValid) {
        return res.status(401).json({ error: "Aktualne hasło jest nieprawidłowe" });
      }
      const hashedPassword = await hashPassword(newPassword);
      await db.update(admins).set({ password: hashedPassword, plainPassword: newPassword }).where(eq(admins.id, adminId));
      res.json({ message: "Hasło zostało zmienione" });
    } catch (error) {
      console.error("Error changing admin password:", error);
      res.status(500).json({ error: "Nie udało się zmienić hasła" });
    }
  });

  // Delete driver
  app.delete("/api/admin/drivers/:id", requireAdmin, async (req, res) => {
    try {
      await db.update(drivers).set({
        isActive: false,
        deletedAt: new Date(),
        deactivationReason: 'Administrative deactivation',
        deactivatedBy: 'admin',
        isOnline: false,
      }).where(eq(drivers.id, String(req.params.id)));
      res.json({ message: "Konto kierowcy dezaktywowane" });
    } catch (error) {
      res.status(500).json({ error: "Nie udało się dezaktywować kierowcy" });
    }
  });
  
  app.post("/api/admin/drivers/:id/reactivate", requireAdmin, async (req, res) => {
    try {
      await db.update(drivers).set({
        isActive: true,
        deletedAt: null,
        deactivationReason: null,
        deactivatedBy: null,
      }).where(eq(drivers.id, String(req.params.id)));
      res.json({ message: "Konto kierowcy reaktywowane" });
    } catch (error) {
      res.status(500).json({ error: "Nie udało się reaktywować kierowcy" });
