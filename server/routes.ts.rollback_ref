      if (!passengerId) return res.status(401).json({ error: "Nie zalogowano" });
      const { driverId } = req.params;
      const driver = await storage.getDriver(driverId);
      if (!driver) return res.status(404).json({ error: "Kierowca nie znaleziony" });
      const fav = await storage.addFavoriteDriver(passengerId, driverId);
      res.json(fav);
